/**
 * RetryMiddleware - Automatic retry with exponential backoff for LLM and tool calls.
 *
 * Uses wrapLLMCall and wrapToolCall hooks to wrap the actual invocation in a
 * retry loop. Each failure sleeps for backoffFactor^attemptNumber seconds before
 * the next attempt, where attemptNumber is 1-based (first retry = backoffFactor^1).
 *
 * Backoff schedule (default backoffFactor=1.5, maxRetries=3):
 *   Attempt 1 fails → wait 1.5^1 = 1.50 s → attempt 2
 *   Attempt 2 fails → wait 1.5^2 = 2.25 s → attempt 3
 *   Attempt 3 fails → wait 1.5^3 = 3.375 s → attempt 4 (final)
 *   Attempt 4 fails → rethrow
 *
 * Usage:
 *   new RetryMiddleware()
 *   new RetryMiddleware( maxRetries: 5, backoffFactor: 2.0, retryOn: [ "NetworkException" ] )
 *   new RetryMiddleware( retryLLM: false, retryTools: true )
 */
component
    extends   = "models.middleware.BaseAiMiddleware"
    accessors = "true"
    {

    // =========================================================================
    // PROPERTIES
    // =========================================================================

    /**
     * Maximum number of retry attempts after the first failure.
     * Total attempts = maxRetries + 1.
     * Example: maxRetries=3 → up to 4 total attempts.
     */
    property name="maxRetries" type="numeric" default=3;

    /**
     * Exponential backoff base.
     * Wait time before retry N (1-based) = backoffFactor^N seconds.
     * Default 1.5 gives: 1.5s, 2.25s, 3.375s...
     */
    property name="backoffFactor" type="numeric" default=1.5;

    /**
     * Exception types that trigger a retry.
     * Empty array = retry on ALL exception types.
     * Example: [ "NetworkException", "TimeoutException" ]
     *
     * Note: default=[] on the property declaration is a placeholder only.
     * The constructor always assigns a fresh array to variables.retryOn,
     * preventing any shared-state issue across instances.
     */
    property name="retryOn" type="array" default=[];

    /**
     * Whether to apply retry logic to LLM HTTP calls.
     */
    property name="retryLLM" type="boolean" default=true;

    /**
     * Whether to apply retry logic to tool invocations.
     */
    property name="retryTools" type="boolean" default=true;

    // =========================================================================
    // CONSTRUCTOR
    // =========================================================================

    /**
     * @maxRetries    Retry attempts after first failure (default: 3)
     * @backoffFactor Exponential base for sleep duration (default: 1.5)
     * @retryOn       Exception types to retry on — empty = retry all (default: [])
     * @retryLLM      Retry LLM calls (default: true)
     * @retryTools    Retry tool calls (default: true)
     */
    function init(
        numeric maxRetries    = 3,
        numeric backoffFactor = 1.5,
        array   retryOn       = [],
        boolean retryLLM      = true,
        boolean retryTools    = true
    ) {
        // Assign each arg explicitly — avoids shared mutable default on retryOn array
        variables.maxRetries    = arguments.maxRetries;
        variables.backoffFactor = arguments.backoffFactor;
        variables.retryOn       = arguments.retryOn;
        variables.retryLLM      = arguments.retryLLM;
        variables.retryTools    = arguments.retryTools;
        return this;
    }

    // =========================================================================
    // WRAP HOOKS
    // =========================================================================

    /**
     * Wraps the LLM HTTP call with retry logic.
     *
     * If retryLLM=false, calls handler() once with no retry wrapper.
     * Otherwise delegates to executeWithRetry().
     *
     * @context { model, chatRequest, messages }
     * @handler Closure that executes the actual LLM call — call it to proceed
     */
    any function wrapLLMCall( required struct context, required function handler ) {
        if ( !variables.retryLLM ) {
            return arguments.handler();
        }

        var callLabel = "LLM call";
        if ( arguments.context.keyExists( "model" ) ) {
            callLabel &= " [model: #arguments.context.model#]";
        }

        return executeWithRetry( arguments.handler, callLabel );
    }

    /**
     * Wraps each tool invocation with retry logic.
     *
     * If retryTools=false, calls handler() once with no retry wrapper.
     * Otherwise delegates to executeWithRetry().
     *
     * @context { tool, toolName, toolArgs, toolCallId }
     * @handler Closure that executes the actual tool call — call it to proceed
     */
    any function wrapToolCall( required struct context, required function handler ) {
        if ( !variables.retryTools ) {
            return arguments.handler();
        }

        var callLabel = "tool call";
        if ( arguments.context.keyExists( "toolName" ) ) {
            callLabel &= " [tool: #arguments.context.toolName#]";
        }

        return executeWithRetry( arguments.handler, callLabel );
    }

    // =========================================================================
    // PRIVATE HELPERS
    // =========================================================================

    /**
     * Core retry loop shared by wrapLLMCall and wrapToolCall.
     *
     * attemptIndex is 0-based and increments AFTER each failure.
     * The backoff exponent uses (attemptIndex + 1) so the first wait
     * is backoffFactor^1, the second is backoffFactor^2, and so on.
     *
     * Attempt numbering:
     *   attemptIndex=0 → first try
     *   attemptIndex=0 fails → sleep backoffFactor^1 s → attemptIndex=1
     *   attemptIndex=1 fails → sleep backoffFactor^2 s → attemptIndex=2
     *   ...
     *   attemptIndex=maxRetries fails → rethrow (total attempts = maxRetries+1)
     *
     * All locals are declared at the top — BoxLang var scope is function-wide.
     * Arithmetic is pre-computed into named locals before string interpolation
     * because BoxLang does not evaluate expressions inside #...#.
     *
     * sleep() is invoked via java.lang.Thread.sleep() for portability —
     * BoxLang does not guarantee a native sleep() built-in.
     *
     * @fn        The closure to invoke on each attempt
     * @callLabel Human-readable label used in log messages
     */
    private any function executeWithRetry( required function fn, required string callLabel ) {
        var attemptIndex  = 0;
        var totalAttempts = variables.maxRetries + 1;
        var exponent      = 0;
        var waitSeconds   = 0;
        var waitMs        = 0;
        var attemptNumber = 0;
        var retriesLeft   = 0;
        var waitFormatted = "";

        while ( true ) {
            try {
                return arguments.fn();

            } catch ( any e ) {

                // Non-retryable exception type — propagate immediately
                if ( !shouldRetry( e ) ) {
                    logEntry(
                        "warning",
                        "#arguments.callLabel# failed with non-retryable exception type '#e.type#': #e.message#"
                    );
                    rethrow;
                }

                // Exhausted all retries — propagate the last exception
                if ( attemptIndex >= variables.maxRetries ) {
                    logEntry(
                        "error",
                        "#arguments.callLabel# failed after #totalAttempts# attempt(s). Last error (#e.type#): #e.message#"
                    );
                    rethrow;
                }

                // Compute backoff using (attemptIndex + 1) so the first sleep
                // is backoffFactor^1, not backoffFactor^0 = 1 regardless of factor
                exponent      = attemptIndex + 1;
                waitSeconds   = variables.backoffFactor ^ exponent;
                waitMs        = fix( waitSeconds * 1000 );
                attemptNumber = attemptIndex + 1;
                retriesLeft   = variables.maxRetries - attemptIndex;
                waitFormatted = numberFormat( waitSeconds, "0.00" );

                logEntry(
                    "information",
                    "#arguments.callLabel# failed on attempt #attemptNumber# (#e.type#: #e.message#) — retrying in #waitFormatted# s (#retriesLeft# attempt(s) remaining)"
                );

                // Use java.lang.Thread.sleep() — portable across all BoxLang runtimes
                createObject( "java", "java.lang.Thread" ).sleep( waitMs );

                attemptIndex++;
            }
        }
    }

    /**
     * Returns true if the exception should trigger a retry.
     *
     * If retryOn is empty, every exception type is retryable.
     * Otherwise only exceptions whose .type appears in the retryOn array
     * (case-insensitive) are retried — all others propagate immediately.
     *
     * @exception The caught exception struct — must have a .type key
     */
    private boolean function shouldRetry( required any exception ) {
        if ( !arrayLen( variables.retryOn ) ) {
            return true;
        }
        return variables.retryOn.findNoCase( arguments.exception.type ) > 0;
    }

    /**
     * Write a log entry to the "ai" log.
     *
     * Valid type values for BoxLang writeLog: information | warning | error | fatal
     *
     * @level   writeLog type string
     * @message Log message body (the [bx-ai][RetryMiddleware] prefix is added here)
     */
    private void function logEntry( required string level, required string message ) {
        writeLog(
            text : "[bx-ai][RetryMiddleware] #arguments.message#",
            type : arguments.level,
            log  : "ai"
        );
    }

}
