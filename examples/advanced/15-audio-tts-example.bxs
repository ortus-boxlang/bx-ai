/**
 * Audio Text-to-Speech (TTS) Example
 *
 * Demonstrates the aiSpeak() BIF for converting text to natural-sounding speech
 * using multiple providers: OpenAI and ElevenLabs.
 *
 * Prerequisites:
 *   - OPENAI_API_KEY env var set for OpenAI examples
 *   - ELEVENLABS_API_KEY env var set for ElevenLabs examples
 *   - Ollama running locally (docker compose up -d ollama) for local examples
 *
 * Usage:
 *   boxlang examples/advanced/15-audio-tts-example.bxs
 */

println( "=== BoxLang AI — Text-to-Speech Examples ===" )
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 1. Basic TTS — save directly to file (returns file path as string)
// ─────────────────────────────────────────────────────────────────────
println( "1. Basic TTS — save to file" )

var outputFile = expandPath( "/tmp/boxlang-tts-basic.mp3" )

var savedPath = aiSpeak(
    text   : "Hello! BoxLang makes building AI-powered voice applications simple and expressive.",
    options: { outputFile: outputFile }
)

println( "   Saved to: " & savedPath )
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 2. TTS with custom voice and model — returns AiSpeechResponse object
// ─────────────────────────────────────────────────────────────────────
println( "2. TTS with custom voice (nova) — response object" )

var response = aiSpeak(
    text  : "The quick brown fox jumps over the lazy dog.",
    params: { voice: "nova", model: "tts-1-hd" }
)

println( "   Provider:     " & response.getProvider() )
println( "   Model:        " & response.getModel() )
println( "   Format:       " & response.getAudioFormat() )
println( "   Size (bytes): " & response.getSize() )
println( "   Has audio:    " & response.hasAudio() )
println( "   Base64 (50 chars): " & left( response.getBase64(), 50 ) & "..." )

// Save programmatically
response.saveToFile( expandPath( "/tmp/boxlang-tts-nova.mp3" ) )
println( "   Saved nova voice to /tmp/boxlang-tts-nova.mp3" )
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 3. Multiple voices comparison
// ─────────────────────────────────────────────────────────────────────
println( "3. Multiple voices — OpenAI" )

var voices = [ "alloy", "echo", "fable", "onyx", "nova", "shimmer" ]
var sampleText = "BoxLang AI — where imagination meets voice."

voices.each( function( voice ) {
    var filePath = expandPath( "/tmp/boxlang-voice-" & voice & ".mp3" )
    aiSpeak(
        text   : sampleText,
        params : { voice: voice },
        options: { outputFile: filePath }
    )
    println( "   Voice '" & voice & "' → " & filePath )
} )
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 4. ElevenLabs TTS — premium multilingual voice
// ─────────────────────────────────────────────────────────────────────
println( "4. ElevenLabs TTS (requires ELEVENLABS_API_KEY)" )

try {
    var elevenResponse = aiSpeak(
        text   : "ElevenLabs provides stunningly realistic voices for your AI applications.",
        options: { provider: "elevenlabs" }
    )

    println( "   Provider: " & elevenResponse.getProvider() )
    println( "   Format:   " & elevenResponse.getAudioFormat() )
    println( "   Size:     " & elevenResponse.getSize() & " bytes" )

    elevenResponse.saveToFile( expandPath( "/tmp/boxlang-elevenlabs.mp3" ) )
    println( "   Saved to /tmp/boxlang-elevenlabs.mp3" )
} catch ( any e ) {
    println( "   Skipped: " & e.message )
}
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 5. ElevenLabs with custom voice ID
// ─────────────────────────────────────────────────────────────────────
println( "5. ElevenLabs with custom voice ID" )

try {
    var customVoiceResponse = aiSpeak(
        text  : "Custom voice selection makes your application unique.",
        params: {
            voice_id: "pNInz6obpgDQGcFmaJgB",  // Adam voice ID
            model_id: "eleven_multilingual_v2"
        },
        options: { provider: "elevenlabs" }
    )

    customVoiceResponse.saveToFile( expandPath( "/tmp/boxlang-elevenlabs-adam.mp3" ) )
    println( "   Saved Adam voice to /tmp/boxlang-elevenlabs-adam.mp3" )
} catch ( any e ) {
    println( "   Skipped: " & e.message )
}
println( "" )

// ─────────────────────────────────────────────────────────────────────
// 6. Gemini TTS
// ─────────────────────────────────────────────────────────────────────
println( "6. Gemini TTS (requires GEMINI_API_KEY)" )

try {
    var geminiResponse = aiSpeak(
        text   : "Gemini 2.5 Flash delivers expressive, natural-sounding text to speech.",
        params : { voice: "Kore" },
        options: { provider: "gemini" }
    )

    geminiResponse.saveToFile( expandPath( "/tmp/boxlang-gemini-tts.mp3" ) )
    println( "   Saved Gemini TTS to /tmp/boxlang-gemini-tts.mp3" )
    println( "   Size: " & geminiResponse.getSize() & " bytes" )
} catch ( any e ) {
    println( "   Skipped: " & e.message )
}
println( "" )

println( "=== TTS Examples Complete ===" )
println( "Check /tmp/ for generated audio files." )
