/**
 * Core tools example - using the built-in now@bx-ai tool
 */

// now@bx-ai is auto-registered on module load
nowTool = aiToolRegistry().get( "now@bx-ai" )
currentTime = nowTool.invoke( {} )
println( "Current time: " & currentTime )

