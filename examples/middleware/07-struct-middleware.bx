/**
 * 07-struct-middleware.bx
 * Struct-of-closures syntax — lightweight inline middleware without a class file.
 *
 * Useful for one-off hooks, debugging, and quick prototyping.
 * Any hook key can be omitted — missing hooks default to continue() / handler().
 */

// Simple logging inline — no class file required
var inlineLogger = {
    beforeToolCall : function( ctx ) {
        println( "[inline] About to call tool: #ctx.toolName#" );
        println( "[inline] Args: #serializeJSON( ctx.toolArgs )#" );
        return AiMiddlewareResult.continue();
    },
    afterToolCall : function( ctx ) {
        println( "[inline] Tool #ctx.toolName# returned: #ctx.result#" );
        return AiMiddlewareResult.continue();
    }
};

var agent = aiAgent(
    name       : "InlineAgent",
    middleware : [ inlineLogger ]
);

var result = agent.run( "List all open orders" );
println( result );

// Block a tool inline — useful for testing
var blockDeleteInTest = {
    beforeToolCall : function( ctx ) {
        if ( ctx.toolName == "deleteRecord" ) {
            return AiMiddlewareResult.reject( "deleteRecord is disabled in test mode" );
        }
        return AiMiddlewareResult.continue();
    }
};

// Mix struct-of-closures with class instances freely
var mixedAgent = aiAgent()
    .withMiddleware( new LoggingMiddleware() )       // class instance
    .withMiddleware( blockDeleteInTest )             // struct-of-closures
    .withMiddleware( new RetryMiddleware() );        // class instance

result = mixedAgent.run( "Process the order queue" );
println( result );

// Full hook coverage example — shows every available hook key
var fullCoverageMiddleware = {
    beforeAgentRun : function( ctx ) {
        println( "Agent starting with input: #ctx.input#" );
        return AiMiddlewareResult.continue();
    },
    afterAgentRun : function( ctx ) {
        println( "Agent done. Response: #ctx.response#" );
        return AiMiddlewareResult.continue();
    },
    beforeLLMCall : function( ctx ) {
        println( "Calling LLM with #arrayLen( ctx.messages )# messages" );
        return AiMiddlewareResult.continue();
    },
    afterLLMCall : function( ctx ) {
        println( "LLM responded" );
        return AiMiddlewareResult.continue();
    },
    beforeToolCall : function( ctx ) {
        println( "Tool: #ctx.toolName#" );
        return AiMiddlewareResult.continue();
    },
    afterToolCall : function( ctx ) {
        println( "Tool done" );
        return AiMiddlewareResult.continue();
    },
    onError : function( ctx ) {
        println( "Error in #ctx.phase#: #ctx.error.message#" );
        return AiMiddlewareResult.continue();
    },
    wrapLLMCall : function( ctx, handler ) {
        println( "Wrapping LLM call" );
        return handler();
    },
    wrapToolCall : function( ctx, handler ) {
        println( "Wrapping tool call" );
        return handler();
    }
};

aiAgent().withMiddleware( fullCoverageMiddleware ).run( "Hello" );