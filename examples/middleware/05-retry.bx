/**
 * 05-retry.bx
 * RetryMiddleware — automatic retry with exponential backoff.
 */

// Retry both LLM calls and tool calls with default settings
// (3 retries, 1.5x backoff: waits 1.5s, 2.25s, 3.375s between attempts)
var agent = aiAgent(
    name       : "RetryAgent",
    middleware : [ new RetryMiddleware() ]
);

var result = agent.run( "Fetch the latest exchange rates" );
println( result );

// Fine-tuned: only retry specific exception types, more retries for tools
var tunedAgent = aiAgent()
    .withMiddleware( new RetryMiddleware(
        maxRetries    : 5,
        backoffFactor : 2.0,                                   // doubles each time: 2s, 4s, 8s, 16s, 32s
        retryOn       : [ "NetworkException", "TimeoutException", "ProviderError" ],
        retryLLM      : true,
        retryTools    : true
    ) )
    .withMiddleware( new LoggingMiddleware() );   // logging after retry so retried calls are visible

result = tunedAgent.run( "Call the flaky external API and summarise the result" );
println( result );

// Only retry tool calls, not LLM calls (useful when LLM errors should surface immediately)
var toolOnlyAgent = aiAgent()
    .withMiddleware( new RetryMiddleware( retryLLM: false, retryTools: true, maxRetries: 2 ) );

result = toolOnlyAgent.run( "Process the data file" );
println( result );