<cfscript>
    // Test middleware engine
    request = new models.AiBaseRequest();
    
    // Add logging middleware (struct-of-closures)
    request.addMiddleware({
        beforeToolCall = (ctx) => {
            writeOutput("Tool: #ctx.toolName#<br/>");
            return new models.middleware.AiMiddlewareResult().setType("cancel");
        }
    });
    
    // Fire hook - should hit first middleware and cancel
    result = request.fireMiddleware( "beforeToolCall", {toolName:"testTool"} );
    writeOutput("Result: #result.getType()# ✅");
</cfscript>
