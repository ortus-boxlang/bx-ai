 * MiniMax AI Service Provider
 * https://platform.minimax.io/docs/api-reference/api-overview
 */
class extends="BaseService"{

	/**
	 * Static defaults
	 */
	static {
		DEFAULT_CHAT_PARAMS = {
			// https://platform.minimax.io/docs/api-reference/chat-completion
			"model" : "MiniMax-M2.5-highspeed"
		}
		DEFAULT_EMBED_PARAMS = {
			"model" : "embo-01"
		}
	}

	/**
	 * Constructor
	 * https://platform.minimax.io/docs/api-reference/api-overview
	 */
	function init(){
		variables.chatURL = "https://api.minimax.io/v1/chat/completions"
		variables.embeddingsURL = "https://api.minimax.io/v1/embeddings"
		variables.name = "MiniMax"
	}

	/**
	 * Invoke a request to the provider
	 *
	 * @chatRequest The AI request to send to the provider
	 *
	 * @return The response from the provider according to the return format in the AI request
	 */
	@override
	function invoke( required AiChatRequest chatRequest ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )
		return super.invoke( arguments.chatRequest )
	}

	/**
	 * Invoke a request to the provider in streaming mode
	 *
	 * @chatRequest The Chat request to send to the provider
	 * @callback A callback function to be called with each chunk of the stream: function( chunk )
	 *
	 * @return void
	 */
	@override
	function invokeStream( required AiChatRequest chatRequest, required function callback ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )
		return super.invokeStream( arguments.chatRequest, arguments.callback )
	}

	/**
	 * Seed the default embedding model before delegating to base.
	 * Mirrors the pattern used in invoke() for chat defaults.
	 */
	@override
	public function embeddings( required AiEmbeddingRequest embeddingRequest ){
		arguments.embeddingRequest.mergeServiceParams( static.DEFAULT_EMBED_PARAMS )
		return super.embeddings( arguments.embeddingRequest )
	}

	/**
	 * Remap MiniMax's base_resp error convention to the standard { error: "..." } shape
	 * so BaseService's centralized error handling, logging, and onAIError announcement fire correctly.
	 *
	 * MiniMax response shape: { base_resp: { status_code: 0|N, status_msg: "..." }, choices: [...] }
	 * @see https://platform.minimax.io/docs/api-reference/text-chat#response-base-resp
	 */
	private struct function postChatResponse( required AiChatRequest chatRequest, required struct dataPacket, required struct result ){
		if( result.keyExists( "base_resp" ) && result.base_resp.status_code != 0 ){
			return { "error": result.base_resp.status_msg ?: "Unknown MiniMax error (status_code: #result.base_resp.status_code#)" };
		}
		return arguments.result;
	}

	/**
	 * Reshape the embedding request packet to MiniMax's format:
	 * - Renames `input` → `texts` array (MiniMax requires an array, not a scalar)
	 * - Injects the required `type` field (db = indexing, query = search)
	 * @see https://platform.minimax.io/docs/api-reference/embeddings
	 */
	private struct function preEmbeddingRequest( required AiEmbeddingRequest embeddingRequest, required struct dataPacket ){
		var input = arguments.embeddingRequest.getInput();
		return {
			"model": arguments.dataPacket.model ?: arguments.embeddingRequest.getModel(),
			"type" : "db",
			"texts": isArray( input ) ? input : [ input ]
		};
	}

	/**
	 * Normalize MiniMax's embedding response into the standard OpenAI format so
	 * BaseService's returnFormat switch works without further overrides.
	 *
	 * MiniMax returns: { vectors: [ { index, type, embedding } ], total_tokens, base_resp }
	 * Standard format: { data: [ { embedding, index, object } ], model, object, usage }
	 *
	 * base_resp errors are remapped to { error: "..." } so BaseService's error handler fires.
	 * @see https://platform.minimax.io/docs/api-reference/embeddings
	 */
	private struct function postEmbeddingResponse( required AiEmbeddingRequest embeddingRequest, required struct dataPacket, required struct result ){
		// Remap base_resp error to the standard error shape
		if( result.keyExists( "base_resp" ) && result.base_resp.status_code != 0 ){
			return { "error": result.base_resp.status_msg ?: "Unknown MiniMax embedding error (status_code: #result.base_resp.status_code#)" };
		}

		// Normalize vectors → standard data array
		return {
			"data"  : result.vectors.map( (vector) => {
				return {
					"embedding": vector.embedding,
					"index"    : vector.index,
					"object"   : "embedding"
				}
			} ),
			"model" : arguments.embeddingRequest.getModel(),
			"object": "list",
			"usage" : {
				"prompt_tokens": result.total_tokens ?: 0,
				"total_tokens" : result.total_tokens ?: 0
			}
		};
	}

}
