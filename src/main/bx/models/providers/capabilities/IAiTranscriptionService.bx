 * Capability interface for AI providers that support speech-to-text transcription
 * and audio translation. Providers implementing this interface can convert audio
 * files into text.
 */
import bxModules.bxai.models.providers.IAiService;

interface extends="IAiService" {

	/**
	 * Transcribe audio into text in the original language.
	 *
	 * @transcriptionRequest The transcription request containing the audio source and parameters
	 *
	 * @return AiTranscriptionResponse with the transcribed text and optional metadata
	 */
	function transcribe( required AiTranscriptionRequest transcriptionRequest )

	/**
	 * Translate audio into English text regardless of the source language.
	 *
	 * @transcriptionRequest The transcription request containing the audio source and parameters
	 *
	 * @return AiTranscriptionResponse with the translated English text
	 */
	function translate( required AiTranscriptionRequest transcriptionRequest )

}
