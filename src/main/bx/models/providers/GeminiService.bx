import bxModules.bxai.models.providers.capabilities.IAiChatService;
import bxModules.bxai.models.providers.capabilities.IAiEmbeddingsService;

class extends="BaseService" implements="IAiChatService, IAiEmbeddingsService" {

	/**
	 * Static defaults
	 */
	static {
		DEFAULT_CHAT_PARAMS = {
			// https://ai.google.dev/gemini-api/docs/quickstart
			// according to the docs, this is the default model
			"model" : "gemini-2.5-flash"
		};
		DEFAULT_EMBED_PARAMS = {
			"model" : "gemini-embedding-001"
		};
	}

	/**
	 * Constructor
	 */
	function init(){
		variables.chatURL = "https://generativelanguage.googleapis.com/v1beta/models/%MODEL%:generateContent"
		variables.embeddingsURL = "https://generativelanguage.googleapis.com/v1beta/models/%MODEL%:embedContent"
		variables.name = "Gemini"
	}

	/**
	 * Invoke a request to the provider
	 *
	 * @chatRequest The AI request to send to the provider
	 *
	 * @return The response from the provider according to the return format in the AI request
	 */
	function invoke( required AiChatRequest chatRequest ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )
		return super.invoke( arguments.chatRequest )
	}

	/**
	 * Invoke a request to the provider in streaming mode
	 *
	 * @chatRequest The Chat request to send to the provider
	 * @callback A callback function to be called with each chunk of the stream: function( chunk )
	 *
	 * @return void
	 */
	function invokeStream( required AiChatRequest chatRequest, required function callback ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )
		return super.invokeStream( arguments.chatRequest, arguments.callback )
	}

	/**
	 * Seed defaults, resolve the per-request URL (Gemini embeds model name + API key in the URL),
	 * disable the Bearer auth header, then delegates to base.
	 * @see https://ai.google.dev/api/embeddings
	 */
	@override
	public function embeddings( required AiEmbeddingRequest embeddingRequest ){
		arguments.embeddingRequest
			.mergeServiceParams( static.DEFAULT_EMBED_PARAMS )
			.setApiKeyIfEmpty( getAPIKey() )

		// Bake model + key into the URL for this request (Gemini uses query-param auth)
		variables.embeddingsURL = getEmbeddingsURL()
			.replace( '%MODEL%', arguments.embeddingRequest.getModel() )
			& '?key=#arguments.embeddingRequest.getApiKey()#';

		// No Authorization header — key is already in the URL
		arguments.embeddingRequest.setSendAuthHeader( false );

		return super.embeddings( arguments.embeddingRequest );
	}

	/**
	 * Reshape the embedding packet to Gemini's format:
	 * { content: { parts: [{ text: "..." }] } }
	 * @see https://ai.google.dev/api/embeddings
	 */
	@override
	private struct function preRequest(
		required AiBaseRequest aiRequest,
		required struct dataPacket,
		required string operation
	) {
		if ( arguments.operation != "embeddings" ) {
			return arguments.dataPacket
		}
		var input = arguments.aiRequest.getInput()
		return {
			"content": {
				"parts": [ {
					"text": isArray( input ) ? input.toList( " " ) : input
				} ]
			}
		}
	}

	/**
	 * Normalize Gemini's embedding response to the standard OpenAI format.
	 * Gemini returns: { embedding: { values: [...] } }
	 * Standard format: { data: [{ embedding, index, object }], model }
	 * @see https://ai.google.dev/api/embeddings
	 */
	@override
	private any function postResponse(
		required AiBaseRequest aiRequest,
		required struct dataPacket,
		required any result,
		required string operation
	) {
		if ( arguments.operation != "embeddings" ) {
			return arguments.result
		}
		if ( !arguments.result.keyExists( "embedding" ) ) {
			return { "error": "Invalid Gemini embedding response — 'embedding' key missing. Response: #arguments.result.toString()#" }
		}
		return {
			"data" : [ {
				"embedding": arguments.result.embedding.values,
				"index"    : 0,
				"object"   : "embedding"
			} ],
			"model": arguments.aiRequest.getModel()
		}
	}

	/**
	 * Gemini chat request
	 */
	@override
	public function chat( required AiChatRequest chatRequest, numeric interactionCount = 0 ){
		// We need to pre-process the messages to conform to the Gemini API
		var dataPacket = {
			"contents": arguments.chatRequest
				.getMessages()
				.map( message -> {
					return {
						"role" : message.role == "system" ? "model" : "user",
						"parts": [ {
							"text": message.content
						} ]
					}
				} )
			}.append( arguments.chatRequest.getParams() )

		// Tooling support
		if( dataPacket.keyExists( "tools" ) ){
			dataPacket.tools = dataPacket.tools.map( .getSchema )
		}

		// Update URL according to the model
		variables.chatURL = getChatUrl().replace( '%MODEL%', chatRequest.getModel() ) & '?key=#chatRequest.getApiKey()#';
		// No auth header
		arguments.chatRequest.setSendAuthHeader( false );

		// Send it
		var result = sendChatRequest( chatRequest, dataPacket )

		// If an error is returned, throw it
		if( result.keyExists( "error" ) ){
			throw(
				type   : "ProviderError",
				message: result.error.toString()
			);
		}

		// No Tool calls yet.

		// Determine return formats
		var content = result.candidates.first().content.parts.first().text;
		switch( chatRequest.getReturnFormat() ){
			case "all":
				return result.candidates;
			case "raw":
				return result;
			case "json":
				return jsonDeserialize( extractFromCodeBlock( content, "json" ) );
			case "xml":
				return xmlParse( extractFromCodeBlock( content, "xml" ) );
			case "structuredOutput":
				return populateStructuredOutput( content, chatRequest );
			case "single": default:
				return content;
		}
	}

	/**
	 * Gemini streaming chat request - overridden to use Gemini-specific streaming format
	 * Gemini uses streamGenerateContent endpoint with ?alt=sse parameter
	 * @see https://ai.google.dev/gemini-api/docs/text-generation#rest_5
	 *
	 * @chatRequest The AiChatRequest object to send to the provider
	 * @callback A callback function to be called with each chunk of the stream
	 */
	@override
	public function chatStream( required AiChatRequest chatRequest, required function callback, numeric interactionCount = 0 ){
		var userCallback = arguments.callback;
		var requestedModel = arguments.chatRequest.getModel();

		// We need to pre-process the messages to conform to the Gemini API
		var dataPacket = {
			"contents": arguments.chatRequest
				.getMessages()
				.map( message -> {
					return {
						"role" : message.role == "system" ? "model" : "user",
						"parts": [ {
							"text": message.content
						} ]
					}
				} )
			}.append( arguments.chatRequest.getParams() )

		// Tooling support
		if( dataPacket.keyExists( "tools" ) ){
			dataPacket.tools = dataPacket.tools.map( .getSchema )
		}

		// Update URL for Gemini streaming: use streamGenerateContent endpoint with alt=sse
		var streamingURL = getChatUrl()
			.replace( '%MODEL%', chatRequest.getModel() )
			.replace( 'generateContent', 'streamGenerateContent' )
			& '?key=#chatRequest.getApiKey()#&alt=sse';

		// Set the streaming URL
		variables.chatURL = streamingURL;

		// No auth header for Gemini
		arguments.chatRequest.setSendAuthHeader( false );
		var normalizedCallback = ( chunk ) => {
			var content = chunk.candidates?.first()?.content?.parts?.first()?.text ?: "";
			var finishReason = chunk.candidates?.first()?.finishReason ?: "";

			userCallback({
				"provider": "Gemini",
				"model": requestedModel,
				"object": "chat.completion.chunk",
				"choices": [
					{
						"index": 0,
						"delta": {
							"role": "assistant",
							"content": content
						},
						"finish_reason": finishReason
					}
				],
				"raw": chunk
			});
		};

		// Send it with streaming
		sendStreamRequest( chatRequest, dataPacket, normalizedCallback )
	}

}
