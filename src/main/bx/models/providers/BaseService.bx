 * Base Service for AI Providers
 * This service provides a base implementation for AI providers
 * It is based on the Open AI standard, overridable by the provider
 *
 * All AI Providers must extend this service and implement the following methods:
 * - configure()
 * - invoke()
 * - invokeStream()
 *
 * All providers have the following properties:
 * - apiKey                                   : The API key to use with the provider
 * - chatURL                                  : The chat URL of the provider API
 * - params                                   : The default params request properties
 */
import bxModules.bxai.models.util.SchemaBuilder;

abstract class implements="IAiService" {

	/**
	 * The name of the LLM service provider
	 */
	property name="name" default="";

	/**
	 * The API key to use with the provider
	 */
	property name="apiKey" default="";

	/**
	 * The chat URL of the provider API
	 */
	property name="chatURL" default="";

	/**
	 * The embeddings URL of the provider API
	 */
	property name="embeddingsURL" default="";

	/**
	 * The default params to send to the provider on ANY request (chat, embeddings, etc.)
	 */
	property name="params" type="struct" default={};

	/**
	 * The default headers to send to the provider on ANY request (chat, embeddings, etc.)
	 */
	property name="headers" type="struct" default={};

	/**
	 * Maximum number of tool call interactions allowed to prevent infinite loops.
	 * Deprecated — use MaxToolCallsMiddleware instead.
	 * Kept as a safety fallback when no middleware is configured.
	 */
	property name="maxInteractions" type="numeric" default=10;

	/**
	 * Configuration options for a service provider.
	 */
	property name="options" type="struct" default={};

	/**
	 * Constants
	 */
	static {
		final MODULE_SETTINGS = getModuleInfo( "bxai" ).settings
	}

	// =========================================================================
	// Helper Methods
	// =========================================================================

	IAiService function defaults( required params ){
		variables.params.append( arguments.params, true );
		return this;
	}

	BaseService function addHeader( required string name, required string value ){
		variables.headers[ arguments.name ] = arguments.value;
		return this;
	}

	// =========================================================================
	// Interface Methods
	// =========================================================================

	IAiService function configure( required any options ){
		if( isSimpleValue( arguments.options ) ){
			variables.apiKey = arguments.options;
			return this;
		}

		if( !isStruct( arguments.options ) ){
			throw(
				type    : "InvalidConfiguration",
				message : "The configure() method expects either a simple API key string or a struct of options."
			);
		}

		variables.options = arguments.options;

		if( arguments.options.keyExists( "apiKey" ) ){
			variables.apiKey = arguments.options.apiKey;
		}

		if( static.MODULE_SETTINGS.keyExists( "defaultParams" ) ){
			variables.params.append( static.MODULE_SETTINGS.defaultParams, false );
		}

		if( static.MODULE_SETTINGS.keyExists( "providers" ) && static.MODULE_SETTINGS.providers.keyExists( variables.name ) ){
			var providerSettings = static.MODULE_SETTINGS.providers[ variables.name ];
			if( providerSettings.keyExists( "params" ) ){
				variables.params.append( providerSettings.params, true );
			}
			if( providerSettings.keyExists( "options" ) ){
				variables.options.append( providerSettings.options, true );
			}
		}

		return this;
	}

	function invoke( required AiChatRequest chatRequest ){
		chatRequest
			.setModelIfEmpty( variables.params.model ?: "" )
			.setApiKeyIfEmpty( getAPIKey() )
			.mergeServiceParams( variables.params )
			.mergeServiceHeaders( variables.headers );
		return chat( argumentCollection=arguments );
	}

	function invokeStream( required AiChatRequest chatRequest, required function callback ){
		chatRequest
			.setModelIfEmpty( variables.params.model ?: "" )
			.setApiKeyIfEmpty( getAPIKey() )
			.mergeServiceParams( variables.params )
			.mergeServiceHeaders( variables.headers )
			.setStream( true );
		return chatStream( argumentCollection=arguments );
	}

	// =========================================================================
	// chat() — synchronous with full middleware pipeline
	// =========================================================================

	/**
	 * Send messages to the provider synchronously.
	 * Fires beforeLLMCall, wrapLLMCall, afterLLMCall, and full tool loop hooks.
	 *
	 * @chatRequest      The AiChatRequest object
	 * @interactionCount Current tool call recursion depth (internal use)
	 *
	 * @throws ProviderError if the provider returns an error
	 * @throws MaxInteractionsExceeded if the tool loop exceeds the allowed limit
	 *
	 * @return The response from the provider, or an AiMiddlewareResult if suspended/cancelled
	 */
	function chat( required AiChatRequest chatRequest, numeric interactionCount=0 ){

		// Capture into local var — arguments scope is not available inside nested closures
		var thisChatRequest = arguments.chatRequest;

		// -----------------------------------------------------------------------
		// 1. beforeLLMCall
		// -----------------------------------------------------------------------
		var llmContext = {
			"model"      : thisChatRequest.getModel(),
			"chatRequest": thisChatRequest,
			"messages"   : thisChatRequest.getMessages()
		};

		var beforeResult = thisChatRequest.fireMiddleware( "beforeLLMCall", llmContext );
		if( beforeResult.isTerminal() ) return beforeResult;

		// -----------------------------------------------------------------------
		// 2. wrapLLMCall — wraps the full HTTP pipeline
		// -----------------------------------------------------------------------
		var result = thisChatRequest.fireWrapMiddleware(
			"wrapLLMCall",
			llmContext,
			function(){
				var dataPacket = {
					"model"   : thisChatRequest.getModel(),
					"messages": thisChatRequest.getMessages()
				}.append( thisChatRequest.getParams() );

				// Tooling support
				if( dataPacket.keyExists( "tools" ) ){
					dataPacket.tools = dataPacket.tools.map( .getSchema );
				}

				// Structured output support
				if( thisChatRequest.isStructuredOutput() ){
					var cleanSchema = SchemaBuilder::cleanSchema( thisChatRequest.getStructuredOutput() );
					dataPacket.response_format = {
						"type"       : "json_schema",
						"json_schema": {
							"name"  : "response",
							"strict": true,
							"schema": cleanSchema
						}
					};
				}

				dataPacket = preChatRequest( thisChatRequest, dataPacket );
				var rawResult = sendChatRequest( thisChatRequest, dataPacket );
				return postChatResponse( thisChatRequest, dataPacket, rawResult );
			}
		);

		// -----------------------------------------------------------------------
		// 3. afterLLMCall (reverse order)
		// -----------------------------------------------------------------------
		llmContext.response = result;
		thisChatRequest.fireMiddleware( "afterLLMCall", llmContext, true );

		// -----------------------------------------------------------------------
		// Error handling
		// -----------------------------------------------------------------------
		if( result.keyExists( "error" ) ){
			writeLog( text: result.error.toString(), type: "error", log: "ai" );
			BoxAnnounce( "onAIError", {
				error        : result.error,
				errorMessage : result.error.toString(),
				provider     : this,
				operation    : "chat",
				aiRequest    : thisChatRequest,
				canRetry     : true
			});
			throw( type: "ProviderError", message: result.error.toString() );
		}

		// -----------------------------------------------------------------------
		// Token usage announcement
		// -----------------------------------------------------------------------
		if( result.keyExists( "usage" ) ){
			BoxAnnounce( "onAITokenCount", {
				provider         : this,
				operation        : "chat",
				model            : thisChatRequest.getModel(),
				promptTokens     : result.usage.keyExists( "prompt_tokens" )     ? result.usage.prompt_tokens     : 0,
				completionTokens : result.usage.keyExists( "completion_tokens" ) ? result.usage.completion_tokens : 0,
				totalTokens      : result.usage.keyExists( "total_tokens" )      ? result.usage.total_tokens      : 0,
				aiRequest        : thisChatRequest,
				usage            : result.usage,
				timestamp        : now()
			});
		}

		// -----------------------------------------------------------------------
		// If no tool calls, return the result
		// -----------------------------------------------------------------------
		var hasToolCalls = result.keyExists( "choices" ) &&
			result.choices.len() &&
			result.choices[ 1 ].keyExists( "message" ) &&
			result.choices[ 1 ].message.keyExists( "tool_calls" ) &&
			isArray( result.choices[ 1 ].message.tool_calls ) &&
			result.choices[ 1 ].message.tool_calls.len();

		if( !hasToolCalls ){
			// Handle structured output if requested
			if( thisChatRequest.isStructuredOutput() ){
				var content = result.choices[ 1 ].message.content ?: "";
				return populateStructuredOutput( content, thisChatRequest );
			}

			// returnFormat handling
			switch( thisChatRequest.getReturnFormat() ){
				case "single":
					return result.choices[ 1 ].message.content ?: "";
				case "message":
					return result.choices[ 1 ].message;
				case "raw": default:
					return result;
			}
		}

		// -----------------------------------------------------------------------
		// Max interactions check
		// -----------------------------------------------------------------------
		var maxAllowed = thisChatRequest.getMaxInteractions() > 0
			? thisChatRequest.getMaxInteractions()
			: variables.maxInteractions;

		if( arguments.interactionCount >= maxAllowed ){
			writeLog(
				text : "Max tool call interactions (#maxAllowed#) exceeded",
				type : "error",
				log  : "ai"
			);
			throw(
				type    : "MaxInteractionsExceeded",
				message : "Tool calls exceeded maximum allowed interactions (#maxAllowed#). This may indicate an infinite loop."
			);
		}

		// -----------------------------------------------------------------------
		// Tool loop with full middleware hooks
		// -----------------------------------------------------------------------
		var newMessages = thisChatRequest.getMessages().map( function( message ){ return message; } );

		for( var choice in result.choices ){
			// Append assistant message with tool_calls into history
			newMessages.append( choice.message );

			if( !choice.message.keyExists( "tool_calls" ) || !isArray( choice.message.tool_calls ) ){
				continue;
			}

			for( var toolCall in choice.message.tool_calls ){
				var toolCtx = {
					"tool"      : thisChatRequest.getTool( toolCall.function.name ).getOrDefault(),
					"toolName"  : toolCall.function.name,
					"toolArgs"  : jsonDeserialize( toolCall.function.arguments ?: "{}" ),
					"toolCallId": toolCall.id
				};

				// beforeToolCall
				var beforeToolResult = thisChatRequest.fireMiddleware( "beforeToolCall", toolCtx );

				if( beforeToolResult.isTerminal() ){
					switch( beforeToolResult.getType() ){
						case "suspend":
							// Pass AiMiddlewareResult up the chain untouched — AiAgent.run() catches it
							return beforeToolResult;

						case "reject":
							// Inject rejection message and continue the loop
							newMessages.append({
								"role"        : "tool",
								"tool_call_id": toolCall.id,
								"content"     : "Rejected by human: #beforeToolResult.getReason()#"
							});
							continue;

						case "cancel":
							return AiMiddlewareResult.cancel( "Tool execution cancelled by middleware" );
					}
				}

				// If edit, use modified args
				if( beforeToolResult.isEdit() ){
					toolCtx.toolArgs = beforeToolResult.getData();
				}

				// wrapToolCall — wraps the actual tool invocation
				var toolOutput = thisChatRequest.fireWrapMiddleware(
					"wrapToolCall",
					toolCtx,
					function(){
						var toolAttempt = thisChatRequest.getTool( toolCall.function.name );
						if( toolAttempt.isPresent() ){
							return toolAttempt.get().invoke( toolCtx.toolArgs );
						}
						writeLog(
							text : "Unable to find tool named: #toolCall.function.name#",
							type : "warning",
							log  : "ai"
						);
						return "Tool ['#toolCall.function.name#'] not found in chat request";
					}
				);

				// afterToolCall (reverse order)
				toolCtx.result = toolOutput;
				thisChatRequest.fireMiddleware( "afterToolCall", toolCtx, true );

				// Append tool result to messages
				newMessages.append({
					"role"        : "tool",
					"tool_call_id": toolCall.id,
					"content"     : toolOutput
				});
			}
		}

		// Continue conversation with updated messages
		thisChatRequest.setMessages( newMessages );
		return chat( thisChatRequest, arguments.interactionCount + 1 );
	}

	// =========================================================================
	// chatStream() — streaming with full middleware pipeline
	// =========================================================================

	/**
	 * Send messages to the provider in streaming mode.
	 * Fires beforeLLMCall, afterLLMCall, and full tool loop hooks.
	 * On suspension: emits AiMiddlewareResult suspend chunk as final stream event.
	 *
	 * @chatRequest      The AiChatRequest object
	 * @callback         Callback receiving each streamed chunk: function( chunk )
	 * @interactionCount Current tool call recursion depth (internal use)
	 */
	public function chatStream(
		required AiChatRequest chatRequest,
		required function callback,
		numeric interactionCount=0
	){
		// Capture into local vars — arguments scope is not available inside nested closures
		var thisChatRequest = arguments.chatRequest;
		var thisCallback    = arguments.callback;

		// -----------------------------------------------------------------------
		// 1. beforeLLMCall
		// -----------------------------------------------------------------------
		var llmContext = {
			"model"      : thisChatRequest.getModel(),
			"chatRequest": thisChatRequest,
			"messages"   : thisChatRequest.getMessages()
		};

		var beforeResult = thisChatRequest.fireMiddleware( "beforeLLMCall", llmContext );
		if( beforeResult.isTerminal() ){
			thisCallback( beforeResult );
			return;
		}

		// -----------------------------------------------------------------------
		// 2. Build and send the stream request
		// -----------------------------------------------------------------------
		var dataPacket = {
			"model"   : thisChatRequest.getModel(),
			"messages": thisChatRequest.getMessages(),
			"stream"  : true
		}.append( thisChatRequest.getParams() );

		if( dataPacket.keyExists( "tools" ) ){
			dataPacket.tools = dataPacket.tools.map( .getSchema );
		}

		dataPacket = preStreamRequest( thisChatRequest, dataPacket );
		var streamState = sendStreamRequest( thisChatRequest, dataPacket, thisCallback );
		streamState = postStreamResponse( thisChatRequest, dataPacket, streamState );

		// -----------------------------------------------------------------------
		// 3. afterLLMCall (reverse order) — fires after stream completes
		// -----------------------------------------------------------------------
		llmContext.response = streamState;
		thisChatRequest.fireMiddleware( "afterLLMCall", llmContext, true );

		// -----------------------------------------------------------------------
		// If no tool calls, streaming is done
		// -----------------------------------------------------------------------
		if( !streamState.toolCalls.len() ){
			return;
		}

		// -----------------------------------------------------------------------
		// Max interactions check
		// -----------------------------------------------------------------------
		var maxAllowed = thisChatRequest.getMaxInteractions() > 0
			? thisChatRequest.getMaxInteractions()
			: variables.maxInteractions;

		if( arguments.interactionCount >= maxAllowed ){
			writeLog(
				text : "Max tool call interactions (#maxAllowed#) exceeded during streaming",
				type : "error",
				log  : "ai"
			);
			throw(
				type    : "MaxInteractionsExceeded",
				message : "Tool calls exceeded maximum allowed interactions (#maxAllowed#) during streaming."
			);
		}

		// -----------------------------------------------------------------------
		// Tool loop with middleware hooks (streaming)
		// -----------------------------------------------------------------------
		var newMessages = thisChatRequest.getMessages().map( function( message ){ return message; } );

		// Append assistant message with accumulated tool_calls
		var assistantMessage = {
			"role"      : "assistant",
			"content"   : streamState.content,
			"tool_calls": streamState.toolCalls
		};
		newMessages.append( assistantMessage );

		var suspended = false;

		for( var toolCall in streamState.toolCalls ){
			if( suspended ) break;

			var toolCtx = {
				"tool"      : thisChatRequest.getTool( toolCall.function.name ?: "" ).getOrDefault(),
				"toolName"  : toolCall.function.name ?: "",
				"toolArgs"  : jsonDeserialize( toolCall.function.arguments ?: "{}" ),
				"toolCallId": toolCall.id ?: ""
			};

			// beforeToolCall
			var beforeToolResult = thisChatRequest.fireMiddleware( "beforeToolCall", toolCtx );

			if( beforeToolResult.isTerminal() ){
				switch( beforeToolResult.getType() ){
					case "suspend":
						// Emit suspend as the final stream chunk and stop
						thisCallback( beforeToolResult );
						suspended = true;
						continue;

					case "reject":
						newMessages.append({
							"role"        : "tool",
							"tool_call_id": toolCall.id ?: "",
							"content"     : "Rejected by human: #beforeToolResult.getReason()#"
						});
						continue;

					case "cancel":
						thisCallback( AiMiddlewareResult.cancel( "Tool execution cancelled by middleware" ) );
						suspended = true;
						continue;
				}
			}

			// If edit, use modified args
			if( beforeToolResult.isEdit() ){
				toolCtx.toolArgs = beforeToolResult.getData();
			}

			// wrapToolCall
			var toolOutput = thisChatRequest.fireWrapMiddleware(
				"wrapToolCall",
				toolCtx,
				function(){
					var toolAttempt = thisChatRequest.getTool( toolCall.function.name ?: "" );
					if( toolAttempt.isPresent() ){
						return toolAttempt.get().invoke( toolCtx.toolArgs );
					}
					writeLog(
						text : "Unable to find tool named during streaming: #toolCall.function.name ?: 'unknown'#",
						type : "warning",
						log  : "ai"
					);
					return "Tool ['#toolCall.function.name ?: 'unknown'#'] not found in chat request";
				}
			);

			// afterToolCall (reverse order)
			toolCtx.result = toolOutput;
			thisChatRequest.fireMiddleware( "afterToolCall", toolCtx, true );

			newMessages.append({
				"role"        : "tool",
				"tool_call_id": toolCall.id ?: "",
				"content"     : toolOutput
			});
		}

		// If suspended, do not continue streaming
		if( suspended ) return;

		// Continue streaming after tool execution
		thisChatRequest.setMessages( newMessages );
		chatStream( thisChatRequest, thisCallback, arguments.interactionCount + 1 );
	}

	// =========================================================================
	// Embeddings (unchanged)
	// =========================================================================

	public function embeddings( required AiEmbeddingRequest embeddingRequest ){
		arguments.embeddingRequest
			.setApiKeyIfEmpty( getAPIKey() )
			.mergeServiceParams( variables.params )
			.mergeServiceHeaders( variables.headers );

		var dataPacket = {
			"input": arguments.embeddingRequest.getInput(),
			"model": arguments.embeddingRequest.getModel()
		}.append( arguments.embeddingRequest.getParams() );

		dataPacket = preEmbeddingRequest( arguments.embeddingRequest, dataPacket );
		var result = sendEmbeddingRequest( embeddingRequest, dataPacket );
		result = postEmbeddingResponse( arguments.embeddingRequest, dataPacket, result );

		if( result.keyExists( "error" ) ){
			writeLog( text: result.error.toString(), type: "error", log: "ai" );
			BoxAnnounce( "onAIError", {
				error            : result.error,
				errorMessage     : result.error.toString(),
				provider         : this,
				operation        : "embeddings",
				embeddingRequest : arguments.embeddingRequest,
				canRetry         : true
			});
			throw( type: "ProviderError", message: result.error.toString() );
		}

		if( !result.keyExists( "data" ) ){
			writeLog( text: "Invalid embedding response: #result.toString()#", type: "error", log: "ai" );
			BoxAnnounce( "onAIError", {
				error            : "Invalid embedding response",
				errorMessage     : "Invalid embedding response from provider. Response: #result.toString()#",
				provider         : this,
				operation        : "embeddings",
				embeddingRequest : arguments.embeddingRequest,
				canRetry         : false
			});
			throw(
				type    : "ProviderError",
				message : "Invalid embedding response from provider. Response: #result.toString()#"
			);
		}

		switch( embeddingRequest.getReturnFormat() ){
			case "embeddings":
				return result.data.map( function( item ){ return item.embedding; } );
			case "raw":
				return result;
			case "first": default:
				return result.data[ 1 ].embedding;
		}
	}

	// =========================================================================
	// Pre/Post Hooks (no-ops — override in concrete providers)
	// =========================================================================

	private struct function preChatRequest( required AiChatRequest chatRequest, required struct dataPacket ){
		return arguments.dataPacket;
	}

	private struct function postChatResponse( required AiChatRequest chatRequest, required struct dataPacket, required struct result ){
		return arguments.result;
	}

	private struct function preStreamRequest( required AiChatRequest chatRequest, required struct dataPacket ){
		return arguments.dataPacket;
	}

	private struct function postStreamResponse( required AiChatRequest chatRequest, required struct dataPacket, required struct streamState ){
		return arguments.streamState;
	}

	private struct function preEmbeddingRequest( required AiEmbeddingRequest embeddingRequest, required struct dataPacket ){
		return arguments.dataPacket;
	}

	private struct function postEmbeddingResponse( required AiEmbeddingRequest embeddingRequest, required struct dataPacket, required struct result ){
		return arguments.result;
	}

	// =========================================================================
	// HTTP Methods (unchanged)
	// =========================================================================

	private function sendChatRequest( required AiChatRequest chatRequest, required struct dataPacket ){
		BoxAnnounce( "onAIChatRequest", {
			"dataPacket" : arguments.dataPacket,
			"chatRequest": arguments.chatRequest,
			"provider"   : this
		});

		if( arguments.chatRequest.getLogRequest() ){
			writeLog( text: buildRequestLog( arguments.chatRequest, arguments.dataPacket ), type: "info", log: "ai" );
		}
		if( arguments.chatRequest.getLogRequestToConsole() ){
			println( buildRequestLog( arguments.chatRequest, arguments.dataPacket ) );
		}

		bx:http
			url     = getChatURL()
			method  = "post"
			result  = "chatResult"
			charset = "utf-8"
			timeout = arguments.chatRequest.getTimeout()
		{
			bx:httpParam type="header" name="content-type" value="application/json";
			if( arguments.chatRequest.getSendAuthHeader() ){
				bx:httpParam type="header" name="Authorization" value="Bearer #arguments.chatRequest.getApiKey()#";
			}
			for( var thisHeader in arguments.chatRequest.getHeaders() ){
				bx:httpParam type="header" name="#thisHeader#" value="#arguments.chatRequest.getHeaders()[ thisHeader ]#";
			}
			bx:httpParam type="body" value=jsonSerialize( arguments.dataPacket );
		}

		if( chatResult.statusCode == "429" || chatResult.statusCode == 429 ){
			var errorData = {};
			try {
				errorData = jsonDeserialize( chatResult.filecontent );
			} catch( any e ){
				errorData = { message: chatResult.filecontent };
			}
			BoxAnnounce( "onAIRateLimitHit", {
				provider   : this,
				operation  : "chat",
				statusCode : chatResult.statusCode,
				errorData  : errorData,
				chatRequest: arguments.chatRequest,
				retryAfter : chatResult.responseheader.keyExists( "retry-after" ) ? chatResult.responseheader[ "retry-after" ] : ""
			});
		}

		if( arguments.chatRequest.getLogResponse() ){
			writeLog( text: buildResponseLog( arguments.chatRequest, chatResult ), type: "info", log: "ai" );
		}
		if( arguments.chatRequest.getLogResponseToConsole() ){
			println( buildResponseLog( arguments.chatRequest, chatResult ) );
		}

		try {
			var iData = {
				"chatRequest": arguments.chatRequest,
				"response"   : jsonDeserialize( chatResult.filecontent ),
				"rawResponse": chatResult,
				"provider"   : this
			};
		} catch( any e ){
			BoxAnnounce( "onAIError", {
				error        : e,
				errorMessage : "Error deserializing response: #chatResult.filecontent#",
				provider     : this,
				operation    : "sendChatRequest",
				aiRequest    : arguments.chatRequest,
				canRetry     : true
			});
			throw(
				type    : "JsonDeserializationError",
				message : "Error deserializing response from provider: #e.message & e.detail#",
				detail  : "Response: #chatResult.filecontent#"
			);
		}

		BoxAnnounce( "onAIChatResponse", iData );
		return iData.response;
	}

	private struct function sendStreamRequest(
		required AiChatRequest chatRequest,
		required struct dataPacket,
		required function callback
	){
		var userCallback    = arguments.callback;
		var thisChatRequest = arguments.chatRequest;
		var streamState     = {
			"content"     : "",
			"finishReason": "",
			"toolCalls"   : []
		};

		BoxAnnounce( "onAIChatRequest", {
			"dataPacket" : arguments.dataPacket,
			"chatRequest": arguments.chatRequest,
			"provider"   : this
		});

		if( arguments.chatRequest.getLogRequest() ){
			writeLog( text: buildRequestLog( arguments.chatRequest, arguments.dataPacket ), type: "info", log: "ai" );
		}
		if( arguments.chatRequest.getLogRequestToConsole() ){
			println( buildRequestLog( arguments.chatRequest, arguments.dataPacket ) );
		}

		var httpRequest = http( getChatURL() )
			.method( "POST" )
			.charset( "utf-8" )
			.timeout( arguments.chatRequest.getTimeout() )
			.header( "content-type", "application/json" )
			.sse( true );

		if( arguments.chatRequest.getSendAuthHeader() ){
			httpRequest.header( "Authorization", "Bearer #arguments.chatRequest.getApiKey()#" );
		}

		for( var thisHeader in arguments.chatRequest.getHeaders() ){
			httpRequest.header( thisHeader, arguments.chatRequest.getHeaders()[ thisHeader ] );
		}

		httpRequest
			.body( jsonSerialize( arguments.dataPacket ) )
			.onChunk( function( chunk, lastEventId, httpResult, httpClient, response ){
				if( chunk?.data?.trim()?.isEmpty() ) return;
				if( chunk.data == "[DONE]" ) return;
				try {
					var parsedChunk = jsonDeserialize( chunk.data );
					updateStreamState( streamState, parsedChunk );
					userCallback( parsedChunk );
				} catch( any e ){
					writeLog( text: "Error parsing stream chunk: [#e.message#] - Data: [#chunk.data#]", type: "error", log: "ai" );
				}
			})
			.onError( function( error, httpResult ){
				var errorMessage = "HTTP Error: [#error.message#]";
				writeLog( text: "Stream Request Error: [#errorMessage#]", type: "error", log: "ai" );
				BoxAnnounce( "onAIError", {
					error        : error,
					errorMessage : errorMessage,
					provider     : this,
					operation    : "stream",
					aiRequest    : thisChatRequest,
					canRetry     : true
				});
				throw( type: "ProviderError", message: errorMessage );
			})
			.onComplete( function( httpResult ){
				if( thisChatRequest.getLogResponse() ){
					writeLog( text: "Stream completed successfully", type: "info", log: "ai" );
				}
				BoxAnnounce( "onAIChatResponse", {
					"chatRequest"    : thisChatRequest,
					"provider"       : this,
					"streamComplete" : true
				});
			})
			.send();

		return streamState;
	}

	private void function updateStreamState( required struct streamState, required struct parsedChunk ){
		var firstChoice = arguments.parsedChunk.choices?.first();
		if( isNull( firstChoice ) ) return;

		var content = firstChoice.delta?.content ?: "";
		if( !isNull( content ) && isSimpleValue( content ) ){
			arguments.streamState.content &= toString( content );
		}

		var finishReason = firstChoice.finish_reason ?: "";
		if( !isNull( finishReason ) && isSimpleValue( finishReason ) && toString( finishReason ).len() ){
			arguments.streamState.finishReason = toString( finishReason );
		}

		var toolCallDeltas = firstChoice.delta?.tool_calls ?: [];
		if( isArray( toolCallDeltas ) && toolCallDeltas.len() ){
			mergeToolCallDeltas( arguments.streamState.toolCalls, toolCallDeltas );
		}
	}

	private void function mergeToolCallDeltas( required array toolCalls, required array toolCallDeltas ){
		var accumulatedToolCalls = arguments.toolCalls;
		var incomingDeltas       = arguments.toolCallDeltas;

		incomingDeltas.each( function( delta ){
			var zeroBasedIndex = delta.keyExists( "index" ) ? val( delta.index ) : accumulatedToolCalls.len();
			var arrayIndex     = zeroBasedIndex + 1;

			while( accumulatedToolCalls.len() < arrayIndex ){
				accumulatedToolCalls.append({
					"id"      : "",
					"type"    : "function",
					"function": { "name": "", "arguments": "" }
				});
			}

			var current = accumulatedToolCalls[ arrayIndex ];

			if( delta.keyExists( "id" ) && !isNull( delta.id ) && toString( delta.id ).len() ){
				current.id = toString( delta.id );
			}
			if( delta.keyExists( "type" ) && !isNull( delta.type ) && toString( delta.type ).len() ){
				current.type = toString( delta.type );
			}
			if( delta.keyExists( "function" ) && isStruct( delta.function ) ){
				if( delta.function.keyExists( "name" ) && !isNull( delta.function.name ) && toString( delta.function.name ).len() ){
					current.function.name = toString( delta.function.name );
				}
				if( delta.function.keyExists( "arguments" ) && !isNull( delta.function.arguments ) ){
					current.function.arguments &= toString( delta.function.arguments );
				}
			}

			accumulatedToolCalls[ arrayIndex ] = current;
		});
	}

	private function sendEmbeddingRequest( required AiEmbeddingRequest embeddingRequest, required struct dataPacket ){
		BoxAnnounce( "onAIEmbedRequest", {
			"dataPacket"      : arguments.dataPacket,
			"embeddingRequest": arguments.embeddingRequest,
			"provider"        : this
		});

		if( arguments.embeddingRequest.getLogRequest() ){
			writeLog( text: buildEmbeddingRequestLog( arguments.embeddingRequest, arguments.dataPacket ), type: "info", log: "ai" );
		}
		if( arguments.embeddingRequest.getLogRequestToConsole() ){
			println( buildEmbeddingRequestLog( arguments.embeddingRequest, arguments.dataPacket ) );
		}

		bx:http
			url     = getEmbeddingsURL()
			method  = "post"
			result  = "embeddingResult"
			charset = "utf-8"
			timeout = arguments.embeddingRequest.getTimeout()
		{
			bx:httpParam type="header" name="content-type" value="application/json";
			if( arguments.embeddingRequest.getSendAuthHeader() ){
				bx:httpParam type="header" name="Authorization" value="Bearer #arguments.embeddingRequest.getApiKey()#";
			}
			for( var thisHeader in arguments.embeddingRequest.getHeaders() ){
				bx:httpParam type="header" name="#thisHeader#" value="#arguments.embeddingRequest.getHeaders()[ thisHeader ]#";
			}
			bx:httpParam type="body" value=jsonSerialize( arguments.dataPacket );
		}

		if( arguments.embeddingRequest.getLogResponse() ){
			writeLog( text: buildEmbeddingResponseLog( arguments.embeddingRequest, embeddingResult ), type: "info", log: "ai" );
		}
		if( arguments.embeddingRequest.getLogRequestToConsole() ){
			println( buildEmbeddingResponseLog( arguments.embeddingRequest, embeddingResult ) );
		}

		try {
			var iData = {
				"embeddingRequest": arguments.embeddingRequest,
				"response"        : jsonDeserialize( embeddingResult.filecontent ),
				"rawResponse"     : embeddingResult,
				"provider"        : this
			};
		} catch( any e ){
			BoxAnnounce( "onAIError", {
				error        : e,
				errorMessage : "Error deserializing response: #embeddingResult.filecontent#",
				provider     : this,
				operation    : "sendEmbeddingRequest",
				aiRequest    : arguments.embeddingRequest,
				canRetry     : true
			});
			throw(
				type    : "JsonDeserializationError",
				message : "Error deserializing response from provider: #e.message & e.detail#",
				detail  : "Response: #embeddingResult.filecontent#"
			);
		}

		BoxAnnounce( "onAIEmbedResponse", iData );
		return iData.response;
	}

	// =========================================================================
	// Logging Helpers (unchanged)
	// =========================================================================

	private string function buildRequestLog( required AiChatRequest chatRequest, required struct dataPacket ){
		var logLines = [];
		logLines.append( "========================================" );
		logLines.append( "** AI Request (#now()#)**" );
		logLines.append( "Provider: #this.name# / Model: #arguments.chatRequest.getModel()#" );
		logLines.append( "Endpoint: #getChatURL()#" );
		logLines.append( "Timeout: #arguments.chatRequest.getTimeout()#s" );
		logLines.append( "Message Count: #arguments.chatRequest.getMessages().len()#" );
		if( arguments.dataPacket.keyExists( "tools" ) && arguments.dataPacket.tools.len() ){
			logLines.append( "Tools: #arguments.dataPacket.tools.len()#" );
		}
		if( arguments.chatRequest.isStructuredOutput() ){
			logLines.append( "Structured Output: YES" );
		}
		if( !isNull( arguments.chatRequest.getTenantId() ) && arguments.chatRequest.getTenantId().len() ){
			logLines.append( "Tenant ID: #arguments.chatRequest.getTenantId()#" );
		}
		if( !arguments.chatRequest.getHeaders().isEmpty() ){
			logLines.append( "Custom Headers: #arguments.chatRequest.getHeaders().keyArray().toList( ', ' )#" );
		}
		logLines.append( "Request Body:" );
		logLines.append( jsonSerialize( data: arguments.dataPacket, pretty: true ) );
		logLines.append( "========================================" );
		return logLines.toList( chr( 10 ) );
	}

	private string function buildResponseLog( required AiChatRequest chatRequest, required struct chatResult ){
		var logLines = [];
		logLines.append( "========================================" );
		logLines.append( "** AI Response (#now()#)**" );
		logLines.append( "Provider: #this.name# / Model: #arguments.chatRequest.getModel()#" );
		logLines.append( "Status: #arguments.chatResult.statusCode#" );
		logLines.append( "Execution Time: #arguments.chatResult?.executionTime#ms" );
		if( arguments.chatResult.keyExists( "responseheader" ) && !arguments.chatResult.responseheader.isEmpty() ){
			logLines.append( "Response Headers: #arguments.chatResult.responseheader.keyArray().toList( ', ' )#" );
		}
		try {
			var parsedResponse = jsonDeserialize( arguments.chatResult.filecontent );
			if( parsedResponse.keyExists( "usage" ) ){
				var usage = parsedResponse.usage;
				logLines.append( "Token Usage: Prompt=#usage.keyExists( 'prompt_tokens' ) ? usage.prompt_tokens : 0# | Completion=#usage.keyExists( 'completion_tokens' ) ? usage.completion_tokens : 0# | Total=#usage.keyExists( 'total_tokens' ) ? usage.total_tokens : 0#" );
			}
			logLines.append( "Deserialized Response:" );
			logLines.append( jsonSerialize( data: parsedResponse, pretty: true ) );
		} catch( any e ){
			logLines.append( "Raw Response (JSON parsing failed):" );
			logLines.append( arguments.chatResult.filecontent );
		}
		logLines.append( "========================================" );
		return logLines.toList( chr( 10 ) );
	}

	private string function buildEmbeddingRequestLog( required AiEmbeddingRequest embeddingRequest, required struct dataPacket ){
		var logLines = [];
		logLines.append( "========================================" );
		logLines.append( "** AI Embedding Request (#now()#)**" );
		logLines.append( "Provider: #this.name# / Model: #arguments.embeddingRequest.getModel()#" );
		logLines.append( "Endpoint: #getEmbeddingsURL()#" );
		logLines.append( "Timeout: #arguments.embeddingRequest.getTimeout()#s" );
		var input = arguments.dataPacket.keyExists( "input" ) ? arguments.dataPacket.input : "";
		if( isArray( input ) ){
			logLines.append( "Input Count: #input.len()# items" );
			if( input.len() > 0 ){
				var preview = isSimpleValue( input[ 1 ] ) ? input[ 1 ] : input[ 1 ].toString();
				if( preview.len() > 100 ) preview = preview.left( 100 ) & "...";
				logLines.append( "First Item Preview: #preview#" );
			}
		} else if( isSimpleValue( input ) ){
			var preview = input.len() > 100 ? input.left( 100 ) & "..." : input;
			logLines.append( "Input: #preview#" );
		}
		if( arguments.dataPacket.keyExists( "dimensions" ) ){
			logLines.append( "Dimensions: #arguments.dataPacket.dimensions#" );
		}
		if( !isNull( arguments.embeddingRequest.getTenantId() ) && arguments.embeddingRequest.getTenantId().len() ){
			logLines.append( "Tenant ID: #arguments.embeddingRequest.getTenantId()#" );
		}
		if( !arguments.embeddingRequest.getHeaders().isEmpty() ){
			logLines.append( "Custom Headers: #arguments.embeddingRequest.getHeaders().keyArray().toList( ', ' )#" );
		}
		logLines.append( "Request Body:" );
		logLines.append( jsonSerialize( arguments.dataPacket, true ) );
		logLines.append( "========================================" );
		return logLines.toList( chr( 10 ) );
	}

	private string function buildEmbeddingResponseLog( required AiEmbeddingRequest embeddingRequest, required struct embeddingResult ){
		var logLines = [];
		logLines.append( "========================================" );
		logLines.append( "** AI Embedding Response (#now()#)**" );
		logLines.append( "Provider: #this.name# / Model: #arguments.embeddingRequest.getModel()#" );
		logLines.append( "Status: #arguments.embeddingResult.statusCode#" );
		if( arguments.embeddingResult.keyExists( "executionTime" ) ){
			logLines.append( "Execution Time: #arguments.embeddingResult.executionTime#ms" );
		}
		if( arguments.embeddingResult.keyExists( "responseheader" ) && !arguments.embeddingResult.responseheader.isEmpty() ){
			logLines.append( "Response Headers: #arguments.embeddingResult.responseheader.keyArray().toList( ', ' )#" );
		}
		try {
			var parsedResponse = jsonDeserialize( arguments.embeddingResult.filecontent );
			if( parsedResponse.keyExists( "data" ) && isArray( parsedResponse.data ) ){
				logLines.append( "Embeddings Count: #parsedResponse.data.len()#" );
				if( parsedResponse.data.len() > 0 && parsedResponse.data[ 1 ].keyExists( "embedding" ) && isArray( parsedResponse.data[ 1 ].embedding ) ){
					logLines.append( "Vector Dimensions: #parsedResponse.data[ 1 ].embedding.len()#" );
				}
			}
			if( parsedResponse.keyExists( "usage" ) ){
				var usage = parsedResponse.usage;
				logLines.append( "Token Usage: Prompt=#usage.keyExists( 'prompt_tokens' ) ? usage.prompt_tokens : 0# | Total=#usage.keyExists( 'total_tokens' ) ? usage.total_tokens : 0#" );
			}
			logLines.append( "Deserialized Response:" );
			logLines.append( jsonSerialize( parsedResponse, true ) );
		} catch( any e ){
			logLines.append( "Raw Response (JSON parsing failed):" );
			logLines.append( arguments.embeddingResult.filecontent );
		}
		logLines.append( "========================================" );
		return logLines.toList( chr( 10 ) );
	}

	// =========================================================================
	// Structured Output Helper (unchanged)
	// =========================================================================

	private string function extractFromCodeBlock( required string content, string language="" ){
		var trimmed = arguments.content.trim();
		if( arguments.language.len() && trimmed.startsWith( "```#arguments.language#" ) ){
			var startPos = trimmed.find( chr( 10 ) );
			if( startPos > 0 ){
				var endPos = trimmed.find( "```", startPos );
				if( endPos > 0 ){
					return trimmed.substring( startPos, endPos - 1 ).trim();
				}
			}
		}
		if( trimmed.startsWith( "```" ) ){
			var lines = trimmed.split( chr( 10 ) );
			if( lines.len() > 2 ){
				lines.deleteAt( 1 );
				lines.deleteAt( lines.len() );
				return lines.toList( chr( 10 ) ).trim();
			}
		}
		return arguments.content;
	}

	private any function populateStructuredOutput( required string content, required AiChatRequest chatRequest ){
		var jsonContent      = extractFromCodeBlock( arguments.content, "json" );
		var outputDefinition = arguments.chatRequest.getStructuredOutputDefinition();

		if( arguments.chatRequest.getLogResponseToConsole() ){
			println( "Populating structured output..." );
			println( jsonContent );
			println( "Definition: #arguments.chatRequest.getStructuredOutput().toString()#" );
		}

		if( isObject( outputDefinition ) ){
			return SchemaBuilder::populateClass( outputDefinition, jsonContent );
		}

		if( isArray( outputDefinition ) ){
			var data       = jsonDeserialize( jsonContent );
			var itemsArray = data.keyExists( "items" ) ? data.items : data;
			return SchemaBuilder::populateArray( outputDefinition[ 1 ], jsonSerialize( itemsArray ) );
		}

		if( isStruct( outputDefinition ) ){
			if( outputDefinition.keyExists( "_originalSchemas" ) && !outputDefinition._originalSchemas.isEmpty() ){
				var result = {};
				var data   = jsonDeserialize( jsonContent );
				for( var schemaInfo in outputDefinition._originalSchemas ){
					var name   = schemaInfo.name;
					var schema = schemaInfo.schema;
					if( data.keyExists( name ) ){
						var propertyData = jsonSerialize( data[ name ] );
						if( isObject( schema ) ){
							result[ name ] = SchemaBuilder::populateClass( schema, propertyData );
						} else if( isStruct( schema ) ){
							result[ name ] = SchemaBuilder::populateStruct( propertyData );
						} else {
							result[ name ] = data[ name ];
						}
					}
				}
				return result;
			}
			return SchemaBuilder::populateStruct( jsonContent );
		}

		return jsonDeserialize( jsonContent );
	}

}