import bxModules.bxai.models.util.SchemaBuilder;
import bxModules.bxai.models.providers.capabilities.IAiChatService;
import bxModules.bxai.models.providers.capabilities.IAiEmbeddingsService;

class extends="OpenAiService" implements="IAiChatService, IAiEmbeddingsService" {

	/**
	 * Static defaults
	 */
	static {
		DEFAULT_CHAT_PARAMS = {
			// Popular local models - users can override with any Ollama model
			"model" : "qwen2.5:0.5b-instruct",
		}
		DEFAULT_EMBED_PARAMS = {
			"model" : "nomic-embed-text"
		}
		DEFAULT_CHAT_ENDPOINT = "api/chat"
		DEFAULT_EMBED_ENDPOINT = "api/embed"
	}

	/**
	 * Constructor
	 */
	function init(){
		// Default to local Ollama instance
		variables.chatURL = "http://localhost:11434/#static.DEFAULT_CHAT_ENDPOINT#"
		variables.embeddingsURL = "http://localhost:11434/#static.DEFAULT_EMBED_ENDPOINT#"
		variables.name = "Ollama"
		// Ollama typically doesn't require auth headers for local instances
		// But supports basic auth for remote/secured instances
	}

	/**
	 * Configure the service with the API key
	 *
	 * @apiKey - The API key to use with the provider
	 *
	 * @throws InvalidConfiguration if the options are not valid
	 *
	 * @return The configured service instance
	 */
	IAiService function configure( required any options ){
		super.configure( arguments.options )

		// Check if we have an options.baseUrl for all the endpoints
		if( variables.options.keyExists( "baseUrl" ) ){
			var baseUrl = variables.options.baseUrl
			// If it doesn't end with a slash, add it
			if( !baseUrl.endsWith( "/" ) ){
				baseUrl &= "/"
			}
			// Set the endpoints
			variables.chatURL = baseUrl & static.DEFAULT_CHAT_ENDPOINT
			variables.embeddingsURL = baseUrl & static.DEFAULT_EMBED_ENDPOINT
		}

		return this
	}

	// -------------------------------------------------------------------------------------------
	// --- Local Pre/Post Request/Response Handling Overrides ---
	// -------------------------------------------------------------------------------------------

	@override
	private struct function preRequest(
		required AiBaseRequest aiRequest,
		required struct dataPacket,
		required string operation
	) {
		// -------------------------------------------------------------------------------------------
		// --- Authentication Handling ---
		// -------------------------------------------------------------------------------------------
		// Ollama typically doesn't use auth headers for local instances
		// But may use basic auth for remote instances
		if( !arguments.aiRequest.getApiKey().isEmpty() ){
			arguments.aiRequest.addHeader( "Authorization", "Basic #toBase64( arguments.aiRequest.getApiKey() )#" )
		} else {
			arguments.aiRequest.setSendAuthHeader( false )
		}


		// -------------------------------------------------------------------------------------------
		// --- Actions for Both Chat and Stream Operations ---
		// -------------------------------------------------------------------------------------------
		if( [ "stream", "chat" ].findNoCase( arguments.operation ) ){

			// -------------------------------------------------------------------------------------------
			// --- Structured Output Handling for Chat/Stream ---
			// -------------------------------------------------------------------------------------------

			// Ollama accepts a JSON schema directly in the "format" field
			// https://github.com/ollama/ollama/blob/main/docs/api.md#structured-outputs
			if( arguments.aiRequest.isStructuredOutput() ){
				var cleanSchema = SchemaBuilder::cleanSchema( arguments.aiRequest.getStructuredOutput() )
				dataPacket[ "format" ] = cleanSchema
				// Remove any existing open ai response_format to avoid confusion
				dataPacket.delete( "response_format" )
			}

			// -------------------------------------------------------------------------------------------
			// --- Denormalize tool_call arguments in message history (chat + stream) ---
			// -------------------------------------------------------------------------------------------
			if( dataPacket.keyExists( "messages" ) ){
				dataPacket.messages = dataPacket.messages.map( ( message ) => {
					if( message.keyExists( "tool_calls" ) && isArray( message.tool_calls ) ){
						message.tool_calls = message.tool_calls.map( ( toolCall ) => {
							var args = toolCall.function?.arguments ?: {}
							if( isSimpleValue( args ) && args.len() ){
								toolCall.function[ "arguments" ] = jsonDeserialize( args )
							}
							return toolCall
						} )
					}
					return message;
			} )
			}
		}

		// -------------------------------------------------------------------------------------------
		// --- Operation Specific  ---
		// -------------------------------------------------------------------------------------------

		switch( arguments.operation ){
			case "stream" : {
				// Ollama uses the same endpoint for streaming and non-streaming requests, controlled by the "stream" parameter in the request body
				dataPacket[ "stream" ] = true
				break;
			}

			case "chat": {
				// For non-streaming chat, explicitly set stream to false to get the correct response
				dataPacket[ "stream" ] = false
				break;
			}

		}

		//println( "Pre-request data packet for operation [#arguments.operation#]: #dataPacket.toJSON( pretty:true )#" );

		return dataPacket
	}

	/**
	 * Normalize Ollama API responses to the standard OpenAI format so the parent
	 * OpenAIService can handle tool calling, return formats, and middleware without
	 * any Ollama-specific branching.
	 *
	 * Chat: Ollama's { message, done, prompt_eval_count, eval_count }
	 *       → OpenAI's { choices:[{ message, finish_reason }], model, usage }
	 *
	 * Embeddings: Ollama's { embeddings:[[...]] }
	 *             → OpenAI's { data:[{ embedding, index, object }], model, object }
	 *
	 * @see https://github.com/ollama/ollama/blob/main/docs/api.md
	 */
	@override
	private any function postResponse(
		required AiBaseRequest aiRequest,
		required struct dataPacket,
		required any result,
		required string operation
	) {
		//println( "Post-response raw result for operation [#arguments.operation#]: #arguments.result.toString()#" );

		// -------------------------------------------------------------------------------------------
		// --- Error Pass-through For all Operations ---
		// -------------------------------------------------------------------------------------------
		// If the result already carries an error key, return it unchanged so BaseService's
		// centralized error handler can fire the correct exception.
		if( isStruct( arguments.result ) && arguments.result.keyExists( "error" ) ){
			return arguments.result
		}

		// -------------------------------------------------------------------------------------------
		// --- Chat Response Normalization ---
		// -------------------------------------------------------------------------------------------
		// Ollama returns: { message: { role, content, tool_calls }, model, done, prompt_eval_count, eval_count }
		// OpenAI format:  { choices: [{ message, finish_reason }], model, usage: { ... } }
		if( arguments.operation == "chat" ){
			var ollamaResult = arguments.result
			var message      = ollamaResult.message ?: {}

			// Normalize tool_calls from Ollama format to OpenAI format
			// Ollama:  [{ function: { name, arguments: struct } }]
			// OpenAI:  [{ id, type:"function", function: { name, arguments: jsonString } }]
			if( message.keyExists( "tool_calls" ) && message.tool_calls.len() ){
				message.tool_calls = message.tool_calls.map( ( toolCall, i ) => {
					var normalizedArgs = toolCall.function?.arguments ?: {}
					return {
						"id"      : toolCall.id ?: "call_ollama_#i#_#lCase( createUUID() )#",
						"type"    : "function",
						"function": {
							"name"     : toolCall.function?.name ?: "",
							"arguments": isSimpleValue( normalizedArgs ) ? normalizedArgs : jsonSerialize( normalizedArgs )
						}
					}
				} )
			}

			// Determine finish reason: "tool_calls" if tools were invoked, "stop" otherwise
			var hasToolCalls = message.keyExists( "tool_calls" ) && isArray( message.tool_calls ) && message.tool_calls.len()
			var finishReason = hasToolCalls ? "tool_calls" : ( ollamaResult.done ? "stop" : "" )

			var normalized = {
				"choices": [{
					"message"      : message,
					"finish_reason": finishReason
				}],
				"model": ollamaResult.model ?: arguments.aiRequest.getModel()
			}

			// Map Ollama token counts to OpenAI usage format
			if( ollamaResult.keyExists( "prompt_eval_count" ) ){
				var promptTokens     = ollamaResult.prompt_eval_count ?: 0
				var completionTokens = ollamaResult.eval_count ?: 0
				normalized[ "usage" ] = {
					"prompt_tokens"    : promptTokens,
					"completion_tokens": completionTokens,
					"total_tokens"     : promptTokens + completionTokens
				}
			}

			//println( "Normalized Ollama Chat Response: " & normalized.toString() )

			return normalized
		}

		// -------------------------------------------------------------------------------------------
		// --- Embedding Response Normalization ---
		// -------------------------------------------------------------------------------------------
		// Ollama returns: { embeddings: [[...], ...] }
		// Standard format: { data: [{ embedding, index, object }] }
		//
		// Missing `embeddings` key is remapped to { error: "..." } so BaseService's
		// centralized error handler fires correctly.
		// @see https://github.com/ollama/ollama/blob/main/docs/api.md#generate-embeddings
		if( arguments.operation == "embeddings" ){
			if ( !arguments.result.keyExists( "embeddings" ) ) {
				return { "error": "Invalid Ollama embedding response — 'embeddings' key missing. Response: #arguments.result.toString()#" }
			}
			return {
				"data"  : arguments.result.embeddings.map( ( embedding, index ) => {
					return { "embedding": embedding, "index": index - 1, "object": "embedding" }
				} ),
				"model" : arguments.aiRequest.getModel(),
				"object": "list"
			}
		}

		return arguments.result
	}

	// -------------------------------------------------------------------------------------------
	// --- Provider-Specific Overrides for Chat and Embeddings ---
	// -------------------------------------------------------------------------------------------

	/**
	 * Ollama chat request - customized for Ollama's API format
	 * @see https://github.com/ollama/ollama/blob/main/docs/api.md
	 *
	 * @chatRequest The AiChatRequest object to send to the provider
	 * @interactionCount The number of interactions (for tool calling recursion tracking)
	 *
	 * @throws ProviderError if the provider returns an error from the request
	 * @throws MaxInteractionsExceeded if tool calls exceed the maximum allowed interactions
	 */
	@override
	public function chat( required AiChatRequest chatRequest, numeric interactionCount = 0 ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )
		// SuperSize me!
		return super.chat( arguments.chatRequest, arguments.interactionCount )
	}

	/**
	 * Ollama streaming chat request - delegates to parent after seeding defaults.
	 * The actual NDJSON transport is handled by the sendStreamRequest() override below.
	 *
	 * @chatRequest The AiChatRequest object to send to the provider
	 * @callback A callback function to be called with each chunk of the stream
	 * @interactionCount The number of interactions (for tool calling recursion tracking)
	 */
	@override
	public function chatStream( required AiChatRequest chatRequest, required function callback, numeric interactionCount = 0 ){
		// Seed the chat request with defaults
		arguments.chatRequest.mergeServiceParams( static.DEFAULT_CHAT_PARAMS )

		// Build the packet according to Ollama's API format with streaming
		var dataPacket = {
			"model": arguments.chatRequest.getModel(),
			"messages": arguments.chatRequest.getMessages(),
			"stream": true
		}.append( arguments.chatRequest.getParams() )

		// -------------------------------------------------------------------------------------------
		// --- Tooling Detection ---
		// -------------------------------------------------------------------------------------------
		if( dataPacket.keyExists( "tools" ) ){
			dataPacket.tools = dataPacket.tools.map( .getSchema )
		}

		// -------------------------------------------------------------------------------------------
		// --- Fire local callback for pre mods ---
		// -------------------------------------------------------------------------------------------
		dataPacket = preRequest( arguments.chatRequest, dataPacket, "stream" )

		// -------------------------------------------------------------------------------------------
		// --- Fire beforeLLMCall middleware ---
		// -------------------------------------------------------------------------------------------
		var streamLlmCtx   = { chatRequest: arguments.chatRequest, dataPacket: dataPacket };
		var streamLlmBefore = arguments.chatRequest.fireMiddleware( "beforeLLMCall", streamLlmCtx );
		if ( streamLlmBefore.isTerminal() ) {
			// Emit a single sentinel chunk so callers know the stream was stopped
			arguments.callback( { type: "middleware_stop", result: streamLlmBefore } )
			return
		}

		// -------------------------------------------------------------------------------------------
		// --- Global Announcement for Stream Start ---
		// -------------------------------------------------------------------------------------------
		BoxAnnounce(
			"onAIChatRequest",
			{
				"dataPacket" : dataPacket,
				"chatRequest": arguments.chatRequest,
				"provider"   : this
			}
		);

		// Log the request if enabled
		if( arguments.chatRequest.getLogRequestToConsole() ){
			println( "AI Request (Stream)" )
			println( dataPacket )
		}

		// Buffer for accumulating partial lines
		var buffer = "";
		// Capture callback in local variable for closure
		var userCallback = arguments.callback;
		var thisChatRequest = arguments.chatRequest;
		var requestedModel = arguments.chatRequest.getModel();
		var emitNormalizedChunk = ( parsedChunk ) => {
			var content = parsedChunk.message?.content ?: "";
			var finishReason = parsedChunk.done ? "stop" : "";

			userCallback( {
				"provider": "Ollama",
				"model": parsedChunk.model ?: requestedModel,
				"object": "chat.completion.chunk",
				"choices": [
					{
						"index": 0,
						"delta": {
							"role": "assistant",
							"content": content
						},
						"finish_reason": finishReason
					}
				],
				"raw": parsedChunk
			} )
		}

		// Build HTTP request with fluent API
		// Note: Ollama uses newline-delimited JSON, NOT SSE format
		var httpRequest = http( getChatURL() )
			.method( "POST" )
			.charset( "utf-8" )
			.timeout( thisChatRequest.getTimeout() )
			.header( "content-type", "application/json" );

		// Auth Header ONLY if the provider requires it
		if( thisChatRequest.getSendAuthHeader() ){
			httpRequest.header( "Authorization", "Bearer #thisChatRequest.getApiKey()#" );
		}

		// Add custom headers
		for( var thisHeader in thisChatRequest.getHeaders() ){
			httpRequest.header( thisHeader, thisChatRequest.getHeaders()[ thisHeader ] );
		}

		// Set request body and callbacks
		httpRequest
			.body( jsonSerialize( dataPacket ) )
			.onChunk( ( chunkNumber, content, totalBytes, httpResult, httpClient, response ) => {
				// For regular streaming (not SSE), onChunk receives:
				// chunkNumber, content (string), totalBytes, httpResult, httpClient, response
				// Ollama sends newline-delimited JSON: {"message":{...}}\n{"message":{...}}\n

				// Append chunk to buffer
				buffer &= content;

				// Process complete lines
				var lines = buffer.split( char(10) );

				// Keep the last potentially incomplete line in the buffer
				buffer = lines[ lines.len() ];

				// Process complete lines (all but the last)
				for( var i = 1; i <= lines.len() - 1; i++ ){
					var line = lines[ i ].trim();

					// Skip empty lines
					if( line.isEmpty() ){
						continue;
					}

					println( "Received chunk: #line#" )

					// Each line is a complete JSON object
					try {
						var parsedChunk = jsonDeserialize( line );
						emitNormalizedChunk( parsedChunk );
					} catch( any e ){
						writeLog(
							text: "Error parsing Ollama stream chunk: #e.message# - Data: #line#",
							type: "error",
							log : "ai"
						)
					}
				}
			} )
			.onError( ( error, httpResult ) => {
				var errorMessage = "HTTP Error: #error.message#";

				writeLog(
					text: "Stream Request Error: #errorMessage#",
					type: "error",
					log : "ai"
				)

				throw(
					type   : "ProviderError",
					message: errorMessage
				);
			} )
			.onComplete( ( httpResult ) => {
				// Process any remaining data in buffer
				if( !buffer.isEmpty() ){
					try {
						var parsedChunk = jsonDeserialize( buffer.trim() );
						emitNormalizedChunk( parsedChunk );
					} catch( any e ){
						// Ignore parsing errors for final buffer
					}
				}

				// -------------------------------------------------------------------------------------------
				// --- Fire afterLLMCall middleware, in reverse order ---
				// -------------------------------------------------------------------------------------------
				thisChatRequest.fireMiddleware(
					hook   : "afterLLMCall",
					context: { chatRequest: thisChatRequest, streamState: httpResult },
					reverse: true
				)

				BoxAnnounce(
					"onAIChatResponse",
					{
						"chatRequest" : thisChatRequest,
						"provider"    : this,
						"streamComplete" : true
					}
				);
			} )
			.send()

		// -------------------------------------------------------------------------------------------
		// --- Fire local callback for post mods ---
		// -------------------------------------------------------------------------------------------
		streamState = postResponse( arguments.chatRequest, dataPacket, buffer, "stream" )

		// -------------------------------------------------------------------------------------------
		// --- Fire afterLLMCall middleware, in reverse order ---
		// -------------------------------------------------------------------------------------------
		arguments.chatRequest.fireMiddleware(
			hook   : "afterLLMCall",
			context: { chatRequest: arguments.chatRequest, streamState: buffer },
			reverse: true
		)
	}


	@override
	public function embeddings( required AiEmbeddingRequest embeddingRequest ){
		arguments.embeddingRequest.mergeServiceParams( static.DEFAULT_EMBED_PARAMS )
		return super.embeddings( arguments.embeddingRequest )
	}

}