 * Docker Model Runner Service
 *
 * This service provides integration with Docker Model Runner (DMR), which exposes
 * multiple API formats for running local AI models with GPU acceleration.
 *
 * Supported APIs:
 * - OpenAI API: /engines/v1/chat/completions, /engines/v1/embeddings (this service)
 * - Anthropic API: /engines/v1/messages (use ClaudeService with baseURL override)
 * - Ollama API: /api/chat, /api/embed (use OllamaService with baseUrl override)
 * - Image Generation: /engines/v1/images/generations (not yet supported)
 * - Native DMR API: /models (model management, supported via helper methods)
 *
 * URL Patterns (all equivalent for OpenAI API):
 * - http://model-runner.docker.internal/engines/v1 (from containers)
 * - http://localhost:12434/engines/v1 (from host)
 * - http://localhost:12434/engines/llama.cpp/v1 (engine-specific)
 *
 * Note: DMR ignores the Authorization header - no API key required.
 *
 * IMPORTANT: This service forces HTTP/1.1 for all HTTP calls. Docker Model Runner's
 * reverse proxy drops the POST body when Java's HttpClient attempts an HTTP/2
 * upgrade (h2c) over plain HTTP. The proxy accepts the upgrade but loses the body
 * during protocol translation to the vLLM backend. Forcing HTTP/1.1 avoids the
 * h2c negotiation entirely. The llama.cpp backend is unaffected but HTTP/1.1 works
 * for both.
 *
 * @see https://docs.docker.com/ai/model-runner/
 * @see https://docs.docker.com/ai/model-runner/api-reference/
 */
class extends = "OpenAICompatibleService"{
	/**
	 * Static defaults
	 *
	 * Docker Model Runner supports multiple URL patterns:
	 * - /v1/* - Direct API access
	 * - /engines/v1/* - OpenAI-compatible endpoint (recommended for third-party tools)
	 * - /engines/{engine}/v1/* - Engine-specific endpoint (e.g., /engines/llama.cpp/v1)
	 */
	static {
		// Default endpoint for Docker Model Runner (accessible from Docker containers)
		// Using /engines/v1 for better OpenAI compatibility
		DEFAULT_BASE_URL = "http://model-runner.docker.internal/engines/v1";
		// Alternative for host machine access
		HOST_BASE_URL    = "http://localhost:12434/engines/v1";
		// Native DMR API base (for model management)
		DMR_API_BASE     = "http://localhost:12434";

		DEFAULT_CHAT_PARAMS = {};
		DEFAULT_EMBED_PARAMS = {};
	}

	/**
	 * Constructor
	 */
	function init(){
		// Call parent constructor first
		super.init();

		// Override with Docker Model Runner specific defaults
		variables.baseURL       = static.DEFAULT_BASE_URL;
		variables.chatURL       = variables.baseURL & "/chat/completions";
		variables.embeddingsURL = variables.baseURL & "/embeddings";
		variables.name          = "DockerModelRunner";

		defaults( static.DEFAULT_CHAT_PARAMS );
	}

	/**
	 * Configure the service with options
	 *
	 * @config Can be a String (API key, or empty string for no auth) or a Struct of
	 *         configuration options (see OpenAICompatibleService.configure) plus:
	 *         - useHostURL: Boolean to use localhost URL instead of Docker internal
	 *
	 * @return The service instance for chaining
	 */
		@override
	IAiService function configure( required any config ){
		// Handle Docker-specific useHostURL option before calling parent
		if (
			isStruct( arguments.config ) && arguments.config.keyExists( "useHostURL" ) && arguments.config.useHostURL
		) {
			arguments.config.baseURL = static.HOST_BASE_URL;
		}

		// Delegate to parent for standard configuration
		return super.configure( arguments.config );
	}

	/**
	 * Override chat to handle Docker Model Runner specifics
	 * Adds automatic retry for model loading (503) errors.
	 *
	 * @chatRequest      The AiChatRequest object to send to the provider
	 * @interactionCount Current tool call interaction count (used internally)
	 * @retryCount       Current retry attempt for model loading (used internally)
	 *
	 * @return The response from the provider according to the return format
	 */
		@override
	public function chat(
		required AiChatRequest chatRequest,
		numeric interactionCount = 0,
		numeric retryCount       = 0
	){
		// Use the parent implementation with retry for model loading
		try {
			return super.chat( chatRequest = arguments.chatRequest, interactionCount = arguments.interactionCount );
		} catch ( ProviderError e ) {
			// Check if this is a "model loading" error (503)
			if ( e.message.findNoCase( "Loading model" ) > 0 || e.message.findNoCase( "503" ) > 0 ) {
				// Retry up to 10 times with longer delays for model loading
				// Large models can take 30-60+ seconds to load
				var maxRetries = 10;
				if ( arguments.retryCount < maxRetries ) {
					// Use 5 second intervals for consistent, longer waits during model load
					var waitTime = 5000; // 5 seconds between retries
					writeLog(
						text: "Docker Model Runner: Model loading, retrying in #waitTime / 1000#s (attempt #arguments.retryCount + 1#/#maxRetries#)",
						type: "info",
						log : "ai"
					);
					sleep( waitTime );
					return chat(
						arguments.chatRequest,
						arguments.interactionCount,
						arguments.retryCount + 1
					);
				}
			}
			// Re-throw if not a loading error or max retries exceeded
			rethrow;
		}
	}

	/**
	 * Override chatStream to handle Docker Model Runner specifics
	 * Adds automatic retry for model loading (503) errors.
	 *
	 * @chatRequest The AiChatRequest object to send to the provider
	 * @callback    A callback function to be called with each chunk of the stream
	 * @retryCount  Current retry attempt for model loading (used internally)
	 */
		@override
	public function chatStream(
		required AiChatRequest chatRequest,
		required function callback,
		numeric retryCount = 0
	){
		// Use the parent implementation with retry for model loading
		try {
			return super.chatStream( chatRequest = arguments.chatRequest, callback = arguments.callback );
		} catch ( ProviderError e ) {
			// Check if this is a "model loading" error (503)
			if ( e.message.findNoCase( "Loading model" ) > 0 || e.message.findNoCase( "503" ) > 0 ) {
				// Retry up to 10 times with longer delays for model loading
				// Large models can take 30-60+ seconds to load
				var maxRetries = 10;
				if ( arguments.retryCount < maxRetries ) {
					// Use 5 second intervals for consistent, longer waits during model load
					var waitTime = 5000; // 5 seconds between retries
					writeLog(
						text: "Docker Model Runner: Model loading for stream, retrying in #waitTime / 1000#s (attempt #arguments.retryCount + 1#/#maxRetries#)",
						type: "info",
						log : "ai"
					);
					sleep( waitTime );
					return chatStream(
						arguments.chatRequest,
						arguments.callback,
						arguments.retryCount + 1
					);
				}
			}
			// Re-throw if not a loading error or max retries exceeded
			rethrow;
		}
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * HTTP Overrides (HTTP/1.1 forced)
	 *
	 * Docker Model Runner's reverse proxy drops the POST body when Java's HttpClient
	 * attempts an HTTP/2 upgrade (h2c) over plain HTTP. The proxy accepts the upgrade
	 * but loses the body during protocol translation to the vLLM backend.
	 * Forcing HTTP/1.1 avoids the h2c negotiation entirely.
	 * The llama.cpp backend is unaffected but HTTP/1.1 works for both.
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Override sendChatRequest to force HTTP/1.1 for Docker Model Runner.
	 *
	 * @chatRequest The AiChatRequest object
	 * @dataPacket  The data packet struct to serialize and send
	 *
	 * @return The deserialized response struct
	 */
	@override
	private function sendChatRequest( required AiChatRequest chatRequest, required struct dataPacket ){
		// SYNC NOTE: This method mirrors BaseService.sendChatRequest() with httpVersion="HTTP/1.1" added.
		// If BaseService.sendChatRequest() changes, update this method to match.

		// Announce the request
		BoxAnnounce(
			"onAIChatRequest",
			{
				"dataPacket" : arguments.dataPacket,
				"chatRequest": arguments.chatRequest,
				"provider"   : this
			}
		);

		// Log the request
		if( arguments.chatRequest.getLogRequest() ){
			writeLog(
				text: buildRequestLog( arguments.chatRequest, arguments.dataPacket ),
				type: "info",
				log : "ai"
			)
		}
		if( arguments.chatRequest.getLogRequestToConsole() ){
			println( buildRequestLog( arguments.chatRequest, arguments.dataPacket ) )
		}

		// Force HTTP/1.1 to avoid h2c body-dropping issue with DMR's vLLM proxy
		bx: http
			url         = getChatURL()
			method      = "post"
			result      = "chatResult"
			charset     = "utf-8"
			timeout     = arguments.chatRequest.getTimeout()
			httpVersion = "HTTP/1.1"
		{
			bx:httpParam type="header" name="content-type" value="application/json";

			if( arguments.chatRequest.getSendAuthHeader() ){
				bx:httpParam type="header" name="Authorization" value="Bearer #arguments.chatRequest.getApiKey()#";
			}

			for( var thisHeader in arguments.chatRequest.getHeaders() ){
				bx:httpParam
					type="header"
					name="#thisHeader#"
					value="#arguments.chatRequest.getHeaders()[ thisHeader ]#";
			}

			bx:httpParam type="body" value=jsonSerialize( arguments.dataPacket );
		}

		// Rate limit detection
		if( chatResult.statusCode == "429" || chatResult.statusCode == 429 ){
			var errorData = {};
			try {
				errorData = jsonDeserialize( chatResult.filecontent );
			} catch( any e ){
				errorData = { message: chatResult.filecontent };
			}
			BoxAnnounce( "onAIRateLimitHit", {
				provider    : this,
				operation   : "chat",
				statusCode  : chatResult.statusCode,
				errorData   : errorData,
				chatRequest : arguments.chatRequest,
				retryAfter  : chatResult.responseheader.keyExists( "retry-after" ) ? chatResult.responseheader[ "retry-after" ] : ""
			} );
		}

		// Response logging
		if( arguments.chatRequest.getLogResponse() ){
			writeLog(
				text: buildResponseLog( arguments.chatRequest, chatResult ),
				type: "info",
				log : "ai"
			)
		}
		if( arguments.chatRequest.getLogResponseToConsole() ){
			println( buildResponseLog( arguments.chatRequest, chatResult ) )
		}

		// Deserialize response
		try {
			var iData = {
				"chatRequest" : arguments.chatRequest,
				"response"    : jsonDeserialize( chatResult.filecontent ),
				"rawResponse" : chatResult,
				"provider"    : this
			}
		} catch( any e ){
			BoxAnnounce( "onAIError", {
				error        : e,
				errorMessage : "Error deserializing response: #chatResult.filecontent#",
				provider     : this,
				operation    : "sendChatRequest",
				aiRequest    : arguments.chatRequest,
				canRetry     : true
			} );
			throw(
				type    : "JsonDeserializationError",
				message : "Error deserializing response from provider: #e.message & e.detail#",
				detail  : "Response: #chatResult.filecontent#"
			);
		}

		BoxAnnounce( "onAIChatResponse", iData );
		return iData.response;
	}

	/**
	 * Override sendStreamRequest to force HTTP/1.1 for Docker Model Runner.
	 *
	 * Also handles vLLM backends that ignore stream=true and return a plain
	 * JSON response. When SSE mode yields zero chunks, falls back to a
	 * non-streaming request and synthesizes a streaming chunk for the callback.
	 *
	 * @chatRequest The AiChatRequest object
	 * @dataPacket  The data packet struct to serialize and send
	 * @callback    Function called with each parsed SSE chunk
	 *
	 * @return Stream state struct with accumulated content and finish reason
	 */
	@override
	private struct function sendStreamRequest(
		required AiChatRequest chatRequest,
		required struct dataPacket,
		required function callback
	){
		// SYNC NOTE: This method mirrors BaseService.sendStreamRequest() with .http1() added
		// and vLLM non-streaming fallback appended. If BaseService.sendStreamRequest() changes,
		// update this method to match.

		var userCallback = arguments.callback;
		var thisChatRequest = arguments.chatRequest;
		var streamState = {
			"content"      : "",
			"finishReason" : "",
			"toolCalls"    : []
		};

		// Announce the request
		BoxAnnounce(
			"onAIChatRequest",
			{
				"dataPacket" : arguments.dataPacket,
				"chatRequest": arguments.chatRequest,
				"provider"   : this
			}
		);

		// Log the request
		if( arguments.chatRequest.getLogRequest() ){
			writeLog(
				text: buildRequestLog( arguments.chatRequest, arguments.dataPacket ),
				type: "info",
				log : "ai"
			)
		}
		if( arguments.chatRequest.getLogRequestToConsole() ){
			println( buildRequestLog( arguments.chatRequest, arguments.dataPacket ) )
		}

		// Force HTTP/1.1 to avoid h2c body-dropping issue with DMR's vLLM proxy
		var httpRequest = http( getChatURL() )
			.method( "POST" )
			.charset( "utf-8" )
			.timeout( arguments.chatRequest.getTimeout() )
			.header( "content-type", "application/json" )
			.http1()
			.sse( true );

		if( arguments.chatRequest.getSendAuthHeader() ){
			httpRequest.header( "Authorization", "Bearer #arguments.chatRequest.getApiKey()#" );
		}

		for( var thisHeader in arguments.chatRequest.getHeaders() ){
			httpRequest.header( thisHeader, arguments.chatRequest.getHeaders()[ thisHeader ] );
		}

		httpRequest
			.body( jsonSerialize( arguments.dataPacket ) )
			.onChunk( ( chunk, lastEventId, httpResult, httpClient, response ) => {
				if( chunk?.data?.trim()?.isEmpty() ){
					return;
				}
				if( chunk.data == "[DONE]" ){
					return;
				}
				// Parse JSON separately from callback so callback errors propagate to caller
				var parsedChunk = javacast( "null", "" );
				try {
					parsedChunk = jsonDeserialize( chunk.data );
				} catch( any e ){
					writeLog(
						text: "Error parsing stream chunk: [#e.message#] - Data: [#chunk.data#]",
						type: "error",
						log : "ai"
					);
					return;
				}
				updateStreamState( streamState, parsedChunk );
				userCallback( parsedChunk );
			} )
			.onError( ( error, httpResult ) => {
				var errorMessage = "HTTP Error: [#error.message#]";
				writeLog(
					text: "Stream Request Error: [#errorMessage#]",
					type: "error",
					log : "ai"
				)
				BoxAnnounce( "onAIError", {
					error        : error,
					errorMessage : errorMessage,
					provider     : this,
					operation    : "stream",
					aiRequest    : thisChatRequest,
					canRetry     : true
				} );
				throw(
					type    : "ProviderError",
					message : errorMessage
				);
			} )
			.onComplete( ( httpResult ) => {
				if( thisChatRequest.getLogResponse() ){
					writeLog(
						text: "Stream completed successfully",
						type: "info",
						log : "ai"
					)
				}
				BoxAnnounce(
					"onAIChatResponse",
					{
						"chatRequest"    : thisChatRequest,
						"provider"       : this,
						"streamComplete" : true
					}
				);
			} )
			.send();

		// vLLM fallback: if no SSE data was processed at all (no content, no tool calls,
		// no finish reason), the backend likely returned a plain JSON response ignoring
		// stream=true. Re-send as non-streaming and convert to a synthetic streaming chunk.
		if( !len( streamState.content ) && streamState.toolCalls.isEmpty() && !len( streamState.finishReason ) ){
			streamState = sendNonStreamingFallback( arguments.chatRequest, arguments.dataPacket, userCallback );
		}

		return streamState;
	}

	/**
	 * Fallback for vLLM backends that ignore stream=true.
	 * Sends a non-streaming request and converts the response to a synthetic
	 * streaming chunk, invoking the callback as if it were a single-chunk stream.
	 *
	 * @chatRequest The AiChatRequest object
	 * @dataPacket  The data packet (stream=true will be removed)
	 * @callback    The user callback to invoke with the synthetic chunk
	 *
	 * @return Stream state struct
	 */
	private struct function sendNonStreamingFallback(
		required AiChatRequest chatRequest,
		required struct dataPacket,
		required function callback
	){
		var streamState = {
			"content"      : "",
			"finishReason" : "",
			"toolCalls"    : []
		};

		// Remove stream flag for the fallback request
		var fallbackPacket = duplicate( arguments.dataPacket );
		fallbackPacket.delete( "stream" );

		// Use the non-streaming sendChatRequest (which also forces HTTP/1.1)
		var fullResponse = sendChatRequest( arguments.chatRequest, fallbackPacket );

		// Convert the non-streaming response to a synthetic streaming chunk
		if( fullResponse.keyExists( "choices" ) && isArray( fullResponse.choices ) && fullResponse.choices.len() > 0 ){
			var choice = fullResponse.choices[ 1 ];
			var syntheticDelta = {};

			if( choice.keyExists( "message" ) && choice.message.keyExists( "content" ) && len( choice.message.content ) ){
				syntheticDelta[ "content" ] = choice.message.content;
			}
			if( choice.keyExists( "message" ) && choice.message.keyExists( "tool_calls" ) && isArray( choice.message.tool_calls ) ){
				syntheticDelta[ "tool_calls" ] = choice.message.tool_calls;
			}

			if( !syntheticDelta.isEmpty() ){
				var syntheticChunk = {
					"id"      : fullResponse.id ?: "fallback",
					"object"  : "chat.completion.chunk",
					"choices" : [ {
						"index"         : 0,
						"delta"         : syntheticDelta,
						"finish_reason" : choice.finish_reason ?: "stop"
					} ]
				};
				updateStreamState( streamState, syntheticChunk );
				arguments.callback( syntheticChunk );

				writeLog(
					text: "Docker Model Runner: vLLM returned non-streaming response, converted to single chunk",
					type: "warning",
					log : "ai"
				);
			}
		} else {
			writeLog(
				text: "Docker Model Runner: Non-streaming fallback returned no usable choices",
				type: "warning",
				log : "ai"
			);
		}

		return streamState;
	}

	/**
	 * Get the base URL for the native DMR API (/models, /models/pull, etc.).
	 * This differs from variables.baseURL which points to the OpenAI-compatible
	 * /engines/v1 path used for chat completions and embeddings.
	 *
	 * @return The DMR API base URL (e.g., "http://localhost:12434")
	 */
	private string function getDmrApiBase(){
		return variables.options.keyExists( "useHostURL" ) && variables.options.useHostURL
			? static.HOST_BASE_URL.replace( "/engines/v1", "" )
			: static.DMR_API_BASE;
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Native DMR API Methods (Model Management)
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * List available models from Docker Model Runner
	 * Uses the native DMR /models endpoint
	 *
	 * @return Array of model info structs or empty array on error
	 */
	@override
	public array function listModels() {
		try {
			var apiBase = getDmrApiBase();

			bx:http
				url         = apiBase & "/models"
				method      = "get"
				result      = "modelsResult"
				charset     = "utf-8"
				timeout     = 10
				httpVersion = "HTTP/1.1"
			{}

			if ( ( modelsResult.statusCode == 200 || modelsResult.statusCode == "200 OK" ) && modelsResult.keyExists( "filecontent" ) && len( modelsResult.filecontent ) ) {
				var response = jsonDeserialize( modelsResult.filecontent );
				// DMR returns array of model objects directly or wrapped in data
				if ( isArray( response ) ) {
					return response;
				} else if ( response.keyExists( "data" ) && isArray( response.data ) ) {
					return response.data;
				}
			}
			return [];
		} catch ( any e ) {
			writeLog(
				text : "Error listing models from Docker Model Runner: #e.message#",
				type : "error",
				log  : "ai"
			);
			return [];
		}
	}

	/**
	 * Pull/download a model to Docker Model Runner
	 * Uses the native DMR /models/pull endpoint
	 *
	 * @model The model identifier to pull (e.g., "ai/llama3.2:1B-Q8_0")
	 * @return Struct with success status and message
	 */
	public struct function pullModel( required string model ) {
		try {
			var apiBase = getDmrApiBase();

			bx:http
				url         = apiBase & "/models/pull"
				method      = "post"
				result      = "pullResult"
				charset     = "utf-8"
				timeout     = 300  // 5 minutes for model download
				httpVersion = "HTTP/1.1"
			{
				bx:httpParam type="header" name="content-type" value="application/json";
				bx:httpParam type="body" value=jsonSerialize({ "model": arguments.model });
			}

			if ( ( pullResult.statusCode == 200 || pullResult.statusCode == "200 OK" ) && pullResult.keyExists( "filecontent" ) ) {
				return {
					"success": true,
					"model": arguments.model,
					"message": "Model pulled successfully"
				};
			}

			return {
				"success": false,
				"model": arguments.model,
				"message": pullResult.filecontent ?: "Failed to pull model",
				"statusCode": pullResult.statusCode
			};
		} catch ( any e ) {
			writeLog(
				text : "Error pulling model '#arguments.model#' from Docker Model Runner: #e.message#",
				type : "error",
				log  : "ai"
			);
			return {
				"success": false,
				"model": arguments.model,
				"message": e.message
			};
		}
	}

	/**
	 * Get detailed information about a specific model
	 *
	 * @model The model identifier
	 * @return Struct with model details or empty struct on error
	 */
	public struct function getModelInfo( required string model ) {
		try {
			var apiBase = getDmrApiBase();

			bx:http
				url         = apiBase & "/models/" & urlEncode( arguments.model )
				method      = "get"
				result      = "modelResult"
				charset     = "utf-8"
				timeout     = 10
				httpVersion = "HTTP/1.1"
			{}

			if ( ( modelResult.statusCode == 200 || modelResult.statusCode == "200 OK" ) && modelResult.keyExists( "filecontent" ) && len( modelResult.filecontent ) ) {
				return jsonDeserialize( modelResult.filecontent );
			}
			return {};
		} catch ( any e ) {
			writeLog(
				text : "Error getting model info from Docker Model Runner: #e.message#",
				type : "error",
				log  : "ai"
			);
			return {};
		}
	}

	/**
	 * Check if Docker Model Runner is available and responding
	 *
	 * @return Boolean indicating if DMR is reachable
	 */
	@override
	public boolean function isAvailable() {
		try {
			var apiBase = getDmrApiBase();

			bx:http
				url         = apiBase & "/models"
				method      = "get"
				result      = "checkResult"
				charset     = "utf-8"
				timeout     = 5
				httpVersion = "HTTP/1.1"
			{}

			return checkResult.statusCode == 200 || checkResult.statusCode == "200 OK";
		} catch ( any e ) {
			writeLog(
				text : "Docker Model Runner availability check failed: #e.message#",
				type : "warning",
				log  : "ai"
			);
			return false;
		}
	}
}
