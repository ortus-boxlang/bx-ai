 * ----------------------------------------------------------------------------------
 * File-based AI conversation storage
 * Stores conversation history in a JSON file for persistence across restarts
 * Perfect for simple persistent storage without external dependencies
 */
class extends="BaseMemory" {

	/**
	 * The directory path where memory files are stored
	 */
	property name="directoryPath" type="string";

	static{
		final DEFAULT_DIRECTORY_PATH = getTempDirectory() & "/bx-ai-memories"
	}

	/**
	 * Constructor
	 *
	 * @key The unique key for this memory instance
	 * @userId The user identifier for multi-tenant isolation
	 * @conversationId The conversation identifier for multiple conversations
	 * @directoryPath Path to the directory for storing memory files (optional)
	 */
	function init(
		required string key,
		string userId = "",
		string conversationId = "",
		string directoryPath = static.DEFAULT_DIRECTORY_PATH
	) {
		super.init(
			key: arguments.key,
			userId: arguments.userId,
			conversationId: arguments.conversationId
		);
		variables.directoryPath = arguments.directoryPath;
		return this;
	}

	/**
	 * Configure the memory instance
	 * Supports directoryPath in config and loads data from file if it exists
	 *
	 * @config Configuration struct with options (directoryPath, etc.)
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function configure( required struct config ) {
		if ( arguments.config.keyExists( "directoryPath" ) ) {
			variables.directoryPath = arguments.config.directoryPath;
		}

		// Ensure directory exists
		if ( !directoryExists( variables.directoryPath ) ) {
			directoryCreate( variables.directoryPath, true, true );
		}

		super.configure( arguments.config );

		return this;
	}

	/**
	 * Get or set the directory path
	 *
	 * @directoryPath Optional directory path to set
	 *
	 * @return String (getter) or IAiMemory (setter)
	 */
	public any function directoryPath( string directoryPath ) {
		if ( !isNull( arguments.directoryPath ) ) {
			variables.directoryPath = arguments.directoryPath;
			return this;
		}
		return variables.directoryPath;
	}

	/**
	 * Get all messages - reads directly from the per-call file
	 *
	 * @userId   Optional per-call user identifier (overrides instance default)
	 * @conversationId Optional per-call conversation identifier (overrides instance default)
	 *
	 * @return Array of message structs
	 */
	public array function getAll( string userId = "", string conversationId = "" ) {
		var filePath = getFilePath( resolveUserId( userId ), resolveConversationId( conversationId ) );
		return loadMessagesFromFile( filePath );
	}

	/**
	 * Add a message to memory and persist to file
	 *
	 * @message The message to add
	 * @userId   Optional per-call user identifier (overrides instance default)
	 * @conversationId Optional per-call conversation identifier (overrides instance default)
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function add( required any message, string userId = "", string conversationId = "" ) {
		var filePath = getFilePath( resolveUserId( userId ), resolveConversationId( conversationId ) );
		var messages = loadMessagesFromFile( filePath );
		messages.append( processMessage( arguments.message ), true );
		saveMessagesToFile( filePath, messages );
		this.trim( userId, conversationId );
		return this;
	}

	/**
	 * Clear all messages from memory and file
	 *
	 * @userId   Optional per-call user identifier (overrides instance default)
	 * @conversationId Optional per-call conversation identifier (overrides instance default)
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function clear( string userId = "", string conversationId = "" ) {
		var filePath = getFilePath( resolveUserId( userId ), resolveConversationId( conversationId ) );
		if ( len( filePath ) && fileExists( filePath ) ) {
			fileDelete( filePath );
		}
		return this;
	}

	/**
	 * Remove the system message and persist to file
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function removeSystemMessage() {
		var instancePath = getFilePath( variables.userId, variables.conversationId );
		var messages = loadMessagesFromFile( instancePath ).filter( m => m.role != "system" );
		saveMessagesToFile( instancePath, messages );
		return this;
	}

	/**
	 * Get or set metadata - persists to file when setting
	 *
	 * @metadata Optional struct to merge with existing metadata
	 *
	 * @return Struct (getter) or IAiMemory (setter)
	 */
	public any function metadata( struct metadata ) {
		if ( !isNull( arguments.metadata ) ) {
			variables.metadata.append( arguments.metadata, true );
			// Re-save the file to persist updated metadata
			var instancePath = getFilePath( variables.userId, variables.conversationId );
			saveMessagesToFile( instancePath, loadMessagesFromFile( instancePath ) );
			return this;
		}
		return variables.metadata;
	}

	/**
	 * Get a summary of this memory instance
	 * Overrides base to add directoryPath field
	 *
	 * @return Struct with memory information
	 */
	public struct function getSummary() {
		var summary = super.getSummary();
		var filePath = getFilePath( variables.userId, variables.conversationId );
		summary.directoryPath = variables.directoryPath;
		summary.filePath = filePath;
		summary.fileExists = len( filePath ) && fileExists( filePath );
		return summary;
	}

	/**
	 * Export messages to a serializable format
	 * Overrides base to add directoryPath field
	 *
	 * @return Struct containing all memory data
	 */
	public struct function export() {
		var exported = super.export();
		exported.directoryPath = variables.directoryPath;
		return exported;
	}

	/**
	 * Import messages from a previously exported format
	 * Overrides base to handle directoryPath and persist to file
	 *
	 * @data The exported memory data
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function import( required struct data ) {
		// Import base fields
		super.import( arguments.data );

		// Handle directoryPath specific to FileMemory
		if ( arguments.data.keyExists( "directoryPath" ) ) {
			variables.directoryPath = arguments.data.directoryPath;
		}

		// Persist imported data to file using current instance identity
		var instancePath = getFilePath( variables.userId, variables.conversationId );
		saveMessagesToFile( instancePath, variables.messages );

		return this;
	}

	/**
	 * Trim messages to keep only the last N (excluding system message)
	 *
	 * @userId   Optional per-call user identifier (overrides instance default)
	 * @conversationId Optional per-call conversation identifier (overrides instance default)
	 *
	 * @return IAiMemory for chaining
	 */
	public IAiMemory function trim( string userId = "", string conversationId = "" ) {
		if ( variables.maxMessages == 0 ) return this;

		var filePath = getFilePath( resolveUserId( userId ), resolveConversationId( conversationId ) );
		var messages = loadMessagesFromFile( filePath );

		var systemMessages = messages.filter( m => m.role == "system" );
		var nonSystem = messages.filter( m => m.role != "system" );

		if ( nonSystem.len() <= variables.maxMessages ) {
			return this;
		}

		var start = nonSystem.len() - variables.maxMessages + 1;
		var keep = nonSystem.slice( start, variables.maxMessages );

		if ( !systemMessages.isEmpty() ) {
			keep.prepend( systemMessages.first() );
		}

		saveMessagesToFile( filePath, keep );
		return this;
	}

	/**
	 * --------------------------------------------------------------------------
	 * Private Helpers
	 * --------------------------------------------------------------------------
	 */

	/**
	 * Get the full file path based on directoryPath, key, userId, and conversationId.
	 * Pure function — does NOT read from identity variables scope.
	 *
	 * @userId The resolved user identifier
	 * @conversationId The resolved conversation identifier
	 *
	 * @return String full path to the memory file
	 */
	private string function getFilePath( string userId = "", string conversationId = "" ) {
		// Build filename parts: memory-{key}[-userId][-conversationId].json
		var parts = [ "memory", variables.key.slugify() ];

		// Add userId if present
		if ( len( arguments.userId ) ) {
			parts.append( arguments.userId.slugify() );
		}

		// Add conversationId if present
		if ( len( arguments.conversationId ) ) {
			parts.append( arguments.conversationId.slugify() );
		}

		var filename = parts.toList( "-" ) & ".json";
		// Combine directory and filename
		return variables.directoryPath & "/" & filename;
	}

	/**
	 * Load messages array from a JSON file.
	 * Returns an empty array if the file does not exist or is unreadable.
	 *
	 * @filePath Full path to the memory JSON file
	 *
	 * @return Array of message structs
	 */
	private array function loadMessagesFromFile( required string filePath ) {
		if ( !fileExists( arguments.filePath ) ) {
			return [];
		}

		try {
			var fileContent = fileRead( arguments.filePath );

			if ( !len( trim( fileContent ) ) ) {
				fileDelete( arguments.filePath );
				return [];
			}

			var data = jsonDeserialize( fileContent );
			if ( isStruct( data ) && data.keyExists( "messages" ) && isArray( data.messages ) ) {
				return data.messages;
			}
		} catch( any e ) {
			// Corrupted file — return empty
		}

		return [];
	}

	/**
	 * Persist a messages array to a JSON file.
	 *
	 * @filePath Full path to the memory JSON file
	 * @messages The messages array to persist
	 */
	private void function saveMessagesToFile( required string filePath, required array messages ) {
		try {
			// Ensure directory exists
			if ( len( variables.directoryPath ) && !directoryExists( variables.directoryPath ) ) {
				directoryCreate( variables.directoryPath, true, true );
			}

			fileWrite(
				arguments.filePath,
				jsonSerialize( {
					type     : variables.name,
					key      : variables.key,
					metadata : variables.metadata,
					messages : arguments.messages
				} )
			);
		} catch( any e ) {
			throw(
				type: "FileMemoryError",
				message: "Failed to save memory to file: #arguments.filePath#",
				detail: e.message
			);
		}
	}

	// ==================== Checkpoint Methods ====================

	/**
	 * Build the file path for a checkpoint file.
	 */
	private string function buildCheckpointFilePath( required string threadId ) {
		var checkpointDir = variables.directoryPath & "/checkpoints";
		if ( !directoryExists( checkpointDir ) ) {
			directoryCreate( checkpointDir, true, true );
		}
		// Sanitise the threadId to only allow alphanumerics, dashes, and underscores
		var safeId = arguments.threadId.reReplace( "[^a-zA-Z0-9_\-]", "_", "all" );
		return checkpointDir & "/" & safeId & ".json";
	}

	/**
	 * Persist checkpoint state as a JSON file.
	 *
	 * @threadId Unique agent thread identifier
	 * @state    Serialisable struct to store
	 * @ttl      TTL in minutes (stored as expiresAt; 0 = no expiry)
	 *
	 * @return this for chaining
	 */
	public IAiMemory function saveState( required string threadId, required struct state, numeric ttl = 0 ) {
		var filePath = buildCheckpointFilePath( arguments.threadId );
		var payload  = {
			threadId  : arguments.threadId,
			savedAt   : now(),
			expiresAt : arguments.ttl > 0 ? dateAdd( "n", arguments.ttl, now() ) : "",
			state     : arguments.state
		};
		fileWrite( filePath, jsonSerialize( payload ) );
		return this;
	}

	/**
	 * Retrieve checkpoint state from its JSON file.
	 *
	 * @threadId Unique agent thread identifier
	 *
	 * @return Saved state struct, or empty struct if not found or expired
	 */
	public struct function loadState( required string threadId ) {
		var filePath = buildCheckpointFilePath( arguments.threadId );
		if ( !fileExists( filePath ) ) {
			return {};
		}
		try {
			var payload = jsonDeserialize( fileRead( filePath ) );
			// Honour expiry
			if ( len( payload.expiresAt ) && now() > payload.expiresAt ) {
				fileDelete( filePath );
				return {};
			}
			return payload.state ?: {};
		} catch ( any e ) {
			return {};
		}
	}

	/**
	 * Delete checkpoint file.
	 *
	 * @threadId Unique agent thread identifier
	 *
	 * @return this for chaining
	 */
	public IAiMemory function clearState( required string threadId ) {
		var filePath = buildCheckpointFilePath( arguments.threadId );
		if ( fileExists( filePath ) ) {
			fileDelete( filePath );
		}
		return this;
	}

}
