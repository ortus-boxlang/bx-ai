 * A tool implementation backed by a closure or lambda.
 * Extends BaseTool for lifecycle, event firing, and result serialization.
 *
 * Use aiTool( name, description, callable ) to create instances.
 *
 * You can also use the fluent describe syntax:
 *   aiTool( "myFn", "Does something", myCallable )
 *     .describeMyArg( "What this argument does" )
 */
class extends="BaseTool" {

	/**
	 * The callable (closure/lambda/function reference) this tool delegates to.
	 */
	property name="callable";

	/**
	 * Maps BoxLang parameter types to JSON Schema types for OpenAI function-calling schemas.
	 * Modeled on SchemaBuilder.TYPE_MAP but kept local to avoid import coupling.
	 */
	static {
		BOXLANG_TO_JSON_TYPE = {
			"string"   : "string",
			"numeric"  : "number",
			"integer"  : "number",
			"float"    : "number",
			"double"   : "number",
			"boolean"  : "boolean",
			"array"    : "array",
			"struct"   : "object",
			"any"      : "string",
			"date"     : "string",
			"datetime" : "string"
		};
	}

	/**
	 * Construct a new ClosureTool with the given name, description, and callable.
	 *
	 * @name The tool name
	 * @description The tool description for AI understanding
	 * @callable The function the tool will invoke when called by the AI
	 */
	ClosureTool function init( required string name, string description = "", any callable = null ) {
		variables.name = arguments.name

		if( variables.name.isEmpty() ) {
			throw(
				type    : "InvalidToolName",
				message : "Tool name cannot be empty. Provide a valid name when creating a ClosureTool."
			)
		}

		variables.description = arguments.description
		if ( !isNull( arguments.callable ) ) {
			this.call( arguments.callable )
		}
		return this
	}

	/**
	 * Set the callable function this tool will invoke.
	 *
	 * @callable A closure, lambda, or function reference
	 */
	ClosureTool function call( required any callable ) {
		variables.callable = arguments.callable
		return this
	}

	/**
	 * Invoke the callable with the provided args.
	 * Injects _chatRequest into args so closures can optionally access conversation context.
	 *
	 * @args The arguments to pass to the callable
	 * @chatRequest The originating chat request
	 *
	 * @throws MissingCallable if no callable has been set
	 */
	public any function doInvoke( required struct args, AiChatRequest chatRequest ) {
		if ( isNull( variables?.callable ) ) {
			throw(
				type    : "MissingCallable",
				message : "No callable has been set on this ClosureTool. Use call() before invoking."
			)
		}
		// Coerce structured values to JSON strings only for string-typed params. Now that the
		// generated schema correctly declares array/object/boolean/number types, the AI will send
		// native JSON types for those. This coercion is a defensive fallback for cases where a
		// BoxLang param is declared "string" but the AI (or MCP client) still sends a complex
		// object/array (e.g. JSON-encoded fields like source_context or key_decisions). Without
		// this, BoxLang's typed-arg binding would throw "Can't cast Struct<Ordered> to a string" before the callable runs.
		var incomingArgs = arguments.args
		variables.callable.$bx.meta.parameters.each( param => {
			if ( ( param.type ?: "" ) == "string" && incomingArgs.keyExists( param.name ) ) {
				var value = incomingArgs[ param.name ]
				if ( !isNull( value ) && !isSimpleValue( value ) ) {
					incomingArgs[ param.name ] = jsonSerialize( value )
				}
			}
		} )
		// Inject _chatRequest into args for closures that want conversation context
		arguments.args._chatRequest = arguments.chatRequest
		return variables.callable( argumentCollection = arguments.args )
	}

	/**
	 * Generate an OpenAI-compatible function schema from the callable's parameter metadata.
	 */
	struct function generateSchema() {
		var argSchema = getArgumentsSchema()
		return {
			"type"     : "function",
			"function" : {
				"name"        : variables.name,
				"description" : variables.description,
				"parameters"  : {
					"type"                 : "object",
					"properties"           : argSchema.properties,
					"required"             : argSchema.required,
					"additionalProperties" : false
				}
			}
		}
	}

	/**
	 * Introspect the callable's parameter metadata to build the arguments schema.
	 * The _chatRequest parameter is injected at runtime by doInvoke() and does not
	 * appear in the callable's declared parameters, so no filtering is needed.
	 *
	 * @throws MissingCallable if no callable has been set
	 *
	 * @return Struct with properties:{} and required:[] keys
	 */
	public struct function getArgumentsSchema() {
		if ( isNull( variables?.callable ) ) {
			throw(
				type    : "MissingCallable",
				message : "No callable has been set. Use call() before calling getArgumentsSchema()."
			)
		}
		var results = { "properties" : {}, "required" : [] }
		variables.callable.$bx.meta.parameters.each( param => {
			if ( param.required ) {
				results.required.append( param.name )
			}
			// Map BoxLang type to JSON Schema type; default to "string" for unknown/untyped params
			var jsonType = static.BOXLANG_TO_JSON_TYPE[ ( param.type ?: "any" ).lcase() ] ?: "string"
			var property = {
				"type"        : jsonType,
				"description" : variables.argDescriptions[ param.name ] ?: param.name
			}
			// For array-typed params, include an open items schema (no element type info available)
			if ( jsonType == "array" ) {
				property[ "items" ] = {}
			}
			results.properties[ param.name ] = property
		} )
		return results
	}

}
