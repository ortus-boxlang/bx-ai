 * Tavily Search web provider.
 *
 * Uses the official Tavily API (https://api.tavily.com/search).
 * Tavily is built specifically for AI agents — returns clean, relevant results
 * optimized for LLM consumption.
 *
 * Requires a TAVILY_API_KEY (set via env var, module settings, or constructor config).
 * Free tier: 1,000 queries/month.
 */
class extends="BaseSearch" {

	/**
	 * The Tavily API key.
	 */
	property name="apiKey" type="string" default="";

	/**
	 * Search depth: "basic" or "advanced" (default: "basic")
	 */
	property name="searchDepth" type="string" default="basic";

	/**
	 * Configure the Tavily search provider.
	 *
	 * @config Struct with tavilyApiKey, searchDepth, maxResults, timeout, etc.
	 *
	 * @return This instance for fluent chaining
	 */
	function configure( required struct config ) {
		super.configure( arguments.config )
		variables.apiKey = resolveApiKey( "TAVILY_API_KEY", "tavilyApiKey" )
		if ( structKeyExists( arguments.config, "searchDepth" ) ) {
			variables.searchDepth = arguments.config.searchDepth
		}
		return this
	}

	/**
	 * Search using the Tavily API.
	 *
	 * @query   The search query string
	 * @options Optional struct with maxResults, timeout, searchDepth, etc.
	 * @return  Array of result structs: [{title, url, snippet}]
	 */
	function search( required string query, struct options = {} ) {
		// Merge options
		if ( !isNull( arguments.options ) ) {
			configure( arguments.options )
		}

		// Check for API key
		if ( variables.apiKey.isEmpty() ) {
			return [{
				title: "Tavily Search Error",
				url: "",
				snippet: "Tavily Search requires an API key. Set the TAVILY_API_KEY environment variable, add tavilyApiKey to module settings, or pass it in the config struct."
			}]
		}

		var searchUrl = "https://api.tavily.com/search"

		var requestBody = {
			query: query,
			api_key: variables.apiKey,
			max_results: variables.maxResults,
			search_depth: variables.searchDepth,
			include_answer: false
		}

		var response = executeRequest(
			url: searchUrl,
			method: "POST",
			headers: {
				"Content-Type": "application/json; charset=utf-8"
			},
			body: requestBody
		)

		var statusCode = val( listFirst( response.statusCode, " " ) )
		if ( statusCode >= 400 ) {
			return [{
				title: "Tavily Search Error",
				url: searchUrl,
				snippet: "HTTP #statusCode# error from Tavily API. Response: #response.fileContent#"
			}]
		}

		// Parse JSON response
		try {
			var data = jsonDeserialize( response.fileContent )
		} catch ( any e ) {
			return [{
				title: "Tavily Search Error",
				url: searchUrl,
				snippet: "Failed to parse Tavily response: #e.message#"
			}]
		}

		// Tavily returns results in the "results" array
		if ( !structKeyExists( data, "results" ) || !isArray( data.results ) ) {
			return [{
				title: "No Results",
				url: "",
				snippet: "Tavily returned no results for: #query#"
			}]
		}

		// Format results
		return formatResults( data.results )
	}

}
