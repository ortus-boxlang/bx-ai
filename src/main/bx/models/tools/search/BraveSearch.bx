 * Brave Search web provider.
 *
 * Uses the official Brave Search API (https://api.search.brave.com/res/v1/web/search).
 * Requires a BRAVE_API_KEY (set via env var, module settings, or constructor config).
 *
 * Free tier: 2,000 queries/month.
 */
class extends="BaseSearch" {

	/**
	 * The Brave API key.
	 */
	property name="apiKey" type="string" default="";

	/**
	 * Configure the Brave search provider.
	 *
	 * @config Struct with braveApiKey, maxResults, timeout, etc.
	 * @return This instance for fluent chaining
	 */
	function configure( required struct config ) {
		super.configure( arguments.config )
		variables.apiKey = resolveApiKey( "BRAVE_API_KEY", "braveApiKey" )
		return this
	}

	/**
	 * Search using the Brave Search API.
	 *
	 * @query   The search query string
	 * @options Optional struct with maxResults, timeout, etc.
	 *
	 * @return  Array of result structs: [{title, url, snippet}]
	 */
	function doSearch( required string query, struct options = {} ) {
		// Merge options
		if ( !isNull( arguments.options ) ) {
			configure( arguments.options )
		}

		// Check for API key
		if ( variables.apiKey.isEmpty() ) {
			return [{
				title: "Brave Search Error",
				url: "",
				snippet: "Brave Search requires an API key. Set the BRAVE_API_KEY environment variable, add braveApiKey to module settings, or pass it in the config struct."
			}]
		}

		var encodedQuery = encodeSearchQuery( query )
		var searchUrl = "https://api.search.brave.com/res/v1/web/search?q=#encodedQuery#&count=#variables.maxResults#"

		var response = executeRequest(
			url: searchUrl,
			headers: {
				"Accept": "application/json",
				"Accept-Encoding": "gzip",
				"X-Subscription-Token": variables.apiKey
			}
		)

		var statusCode = val( listFirst( response.statusCode, " " ) )
		if ( statusCode >= 400 ) {
			return [{
				title: "Brave Search Error",
				url: searchUrl,
				snippet: "HTTP #statusCode# error from Brave Search API. Response: #response.fileContent#"
			}]
		}

		// Parse JSON response
		try {
			var data = jsonDeserialize( response.fileContent );
		} catch ( any e ) {
			return [{
				title: "Brave Search Error",
				url: searchUrl,
				snippet: "Failed to parse Brave Search response: #e.message#"
			}]
		}

		// Brave returns results in data.web.results array
		if ( !structKeyExists( data, "web" ) || !structKeyExists( data.web, "results" ) ) {
			return [{
				title: "No Results",
				url: "",
				snippet: "Brave Search returned no results for: #query#"
			}]
		}

		// Format results
		return formatResults( data.web.results )
	}

}
