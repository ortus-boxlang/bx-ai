 * governing permissions and limitations under the License.
 * ----------------------------------------------------------------------------------
 * Request object for speech-to-text transcription and audio translation operations.
 * The audio source can be a local file path, a URL, or binary/base64 data.
 *
 * Can be used directly (constructed by aiTranscribe()/aiTranslate()) or as a fluent builder
 * when either BIF is called with no audio:
 *
 * ```bx
 * text = aiTranscribe()
 *     .file( "/path/to/audio.mp3" )
 *     .language( "es" )
 *     .transcribe()
 *
 * text = AiTranscriptionRequest
 *     .of( "/path/to/audio.mp3" )
 *     .withWordTimestamps()
 *     .transcribe()
 *
 * // Same builder, different terminator
 * english = AiTranscriptionRequest
 *     .of( "/path/to/spanish.mp3" )
 *     .translate()
 * ```
 */
class extends="AiBaseRequest" {

	/**
	 * Path to a local audio file on disk
	 */
	property name="audioFile" default="";

	/**
	 * URL of a remote audio file (http/https)
	 */
	property name="audioURL" default="";

	/**
	 * Raw binary or base64-encoded audio data
	 */
	property name="audioData" default="";

	/**
	 * Input audio format hint: mp3, wav, flac, ogg, m4a, webm, etc.
	 */
	property name="inputFormat" default="";

	/**
	 * BCP-47 language code of the source audio (e.g. "en", "es", "fr").
	 * Leave empty for auto-detection.
	 */
	property name="language" default="";

	/**
	 * Desired response format from the provider: json, text, verbose_json, srt, vtt
	 */
	property name="responseFormat" default="json";

	/**
	 * Timestamp granularities to include: segment, word (provider support varies)
	 */
	property name="timestamps" type="array" default=[];

	/**
	 * Whether to enable speaker diarization (provider support varies)
	 */
	property name="diarize" type="boolean" default=false;

	/**
	 * Constructor
	 *
	 * @audio          The audio source: file path (string), URL (string), or binary data
	 * @params         Provider API parameters (language, response_format, timestamp_granularities, etc.)
	 * @options        High-level options (provider, apiKey, returnFormat, logging, etc.)
	 * @methodDefaults Default values merged into options before processing
	 */
	function init(
		any audio = "",
		struct params = {},
		struct options = {},
		struct methodDefaults = {}
	){
		super.init()

		arguments.options = prepareOptions( arguments.options, arguments.methodDefaults )

		variables.params                = arguments.params
		variables.provider              = options.provider ?: ""
		variables.apiKey                = options.apiKey ?: ""
		variables.logRequest            = options.logRequest ?: false
		variables.logRequestToConsole   = options.logRequestToConsole ?: false
		variables.logResponse           = options.logResponse ?: false
		variables.logResponseToConsole  = options.logResponseToConsole ?: false
		variables.returnFormat          = options.returnFormat ?: "text"
		variables.model                 = params.model ?: ""
		variables.timeout               = options.timeout ?: 60
		variables.baseURL               = options.baseURL ?: ""
		variables.providerOptions       = options.providerOptions ?: {}
		variables.language              = params.language ?: options.language ?: ""
		variables.responseFormat        = params.response_format ?: options.responseFormat ?: "json"
		variables.timestamps            = params.timestamp_granularities ?: options.timestamps ?: []
		variables.diarize               = params.diarize ?: options.diarize ?: false
		variables.inputFormat           = params.inputFormat ?: options.inputFormat ?: ""

		// OpenAI and compatible providers require response_format=verbose_json when timestamps are requested.
		// Auto-upgrade the response format to avoid API errors.
		if ( variables.timestamps.len() > 0 && variables.responseFormat != "verbose_json" ) {
			variables.responseFormat = "verbose_json"
		}

		// Detect and assign the audio source type
		if ( isSimpleValue( arguments.audio ) && arguments.audio.len() > 0 ) {
			if ( arguments.audio.left( 4 ) == "http" ) {
				variables.audioURL  = arguments.audio
				variables.audioFile = ""
				variables.audioData = ""
			} else {
				variables.audioFile = arguments.audio
				variables.audioURL  = ""
				variables.audioData = ""
				// Verify that the file exists, else throw an exception
				if ( !fileExists( variables.audioFile ) ) {
					throw(
						type    : "InvalidArgument",
						message : "Audio file not found at path: #variables.audioFile#"
					)
				}
			}
		} else if ( isBinary( arguments.audio ) ) {
			variables.audioData = arguments.audio
			variables.audioFile = ""
			variables.audioURL  = ""
		} else {
			variables.audioFile = ""
			variables.audioURL  = ""
			variables.audioData = ""
		}

		return this
	}

	/**
	 * Check whether this request has a valid audio source
	 */
	boolean function hasAudio(){
		return ( variables.audioFile.len() > 0 || variables.audioURL.len() > 0 || ( !isSimpleValue( variables.audioData ) || variables.audioData.len() > 0 ) )
	}

	// ==========================================================================
	// Static Factory
	// ==========================================================================

	/**
	 * Create a new transcription request builder seeded with an audio source.
	 * Audio can be a file path (string), URL (string starting with "http"), or binary data.
	 *
	 * @audio The audio source: file path, URL, or binary data
	 */
	static AiTranscriptionRequest function of( any audio = "" ){
		return new AiTranscriptionRequest( audio = arguments.audio )
	}

	// ==========================================================================
	// Audio Source Builder Methods
	// ==========================================================================

	/**
	 * Set the audio source to a local file path.
	 * Throws immediately if the file does not exist (consistent with init() behavior).
	 *
	 * @path Absolute or relative path to the audio file
	 */
	AiTranscriptionRequest function file( required string path ){
		if ( !fileExists( arguments.path ) ) {
			throw( type: "InvalidArgument", message: "Audio file not found at path: #arguments.path#" )
		}
		variables.audioFile = arguments.path
		variables.audioURL  = ""
		variables.audioData = ""
		return this
	}

	/**
	 * Set the audio source to a remote URL (http/https).
	 *
	 * @url The URL of the remote audio file
	 */
	AiTranscriptionRequest function url( required string url ){
		variables.audioURL  = arguments.url
		variables.audioFile = ""
		variables.audioData = ""
		return this
	}

	/**
	 * Set the audio source to raw binary data.
	 *
	 * @binary The binary audio data
	 */
	AiTranscriptionRequest function data( required any binary ){
		variables.audioData = arguments.binary
		variables.audioFile = ""
		variables.audioURL  = ""
		return this
	}

	// ==========================================================================
	// Fluent Builder API
	// ==========================================================================

	/**
	 * Set the AI model to use (e.g. "whisper-1", "whisper-large-v3").
	 *
	 * @model The model name
	 */
	AiTranscriptionRequest function model( required string model ){
		variables.model = arguments.model
		return this
	}

	/**
	 * Set the provider (e.g. "openai", "groq", "mistral").
	 *
	 * @provider The provider name
	 */
	AiTranscriptionRequest function provider( required string provider ){
		variables.provider = arguments.provider
		return this
	}

	/**
	 * Set the API key for the provider.
	 *
	 * @apiKey The API key
	 */
	AiTranscriptionRequest function apiKey( required string apiKey ){
		variables.apiKey = arguments.apiKey
		return this
	}

	/**
	 * Set the BCP-47 language code of the source audio (e.g. "en", "es", "fr").
	 * Leave empty for auto-detection.
	 *
	 * @language The language code
	 */
	AiTranscriptionRequest function language( required string language ){
		variables.language = arguments.language
		return this
	}

	/**
	 * Set the input audio format hint (e.g. "mp3", "wav", "flac").
	 *
	 * @format The audio format
	 */
	AiTranscriptionRequest function inputFormat( required string format ){
		variables.inputFormat = arguments.format
		return this
	}

	/**
	 * Set the request timeout in seconds.
	 *
	 * @seconds Timeout in seconds
	 */
	AiTranscriptionRequest function timeout( required numeric seconds ){
		variables.timeout = arguments.seconds
		return this
	}

	/**
	 * Request word-level timestamps in the response.
	 * Automatically sets responseFormat to "verbose_json" as required by OpenAI and compatible providers.
	 */
	AiTranscriptionRequest function withWordTimestamps(){
		variables.timestamps     = [ "word" ]
		variables.responseFormat = "verbose_json"
		return this
	}

	/**
	 * Request segment-level timestamps in the response.
	 * Automatically sets responseFormat to "verbose_json" as required by OpenAI and compatible providers.
	 */
	AiTranscriptionRequest function withSegmentTimestamps(){
		variables.timestamps     = [ "segment" ]
		variables.responseFormat = "verbose_json"
		return this
	}

	/**
	 * Request both word- and segment-level timestamps in the response.
	 * Automatically sets responseFormat to "verbose_json" as required by OpenAI and compatible providers.
	 */
	AiTranscriptionRequest function withTimestamps(){
		variables.timestamps     = [ "word", "segment" ]
		variables.responseFormat = "verbose_json"
		return this
	}

	/**
	 * Enable speaker diarization (identify who is speaking when).
	 *
	 * @value Enable or disable diarization (default true)
	 */
	AiTranscriptionRequest function diarize( boolean value = true ){
		variables.diarize = arguments.value
		return this
	}

	/**
	 * Return response format: json (default).
	 */
	AiTranscriptionRequest function asJSON(){
		variables.responseFormat = "json"
		return this
	}

	/**
	 * Return format as plain text string (sets returnFormat = "text").
	 */
	AiTranscriptionRequest function asText(){
		variables.returnFormat = "text"
		return this
	}

	/**
	 * Return response format: verbose_json (includes segments and words).
	 */
	AiTranscriptionRequest function asVerboseJSON(){
		variables.responseFormat = "verbose_json"
		return this
	}

	/**
	 * Return response format: SRT subtitle format.
	 */
	AiTranscriptionRequest function asSRT(){
		variables.responseFormat = "srt"
		return this
	}

	/**
	 * Return response format: WebVTT subtitle format.
	 */
	AiTranscriptionRequest function asVTT(){
		variables.responseFormat = "vtt"
		return this
	}

	/**
	 * Merge additional provider API parameters into the request params.
	 *
	 * @params Struct of provider API parameters to merge
	 */
	AiTranscriptionRequest function withParams( required struct params ){
		variables.params.append( arguments.params, true )

		// If timestamp_granularities passed via params, sync to variables.timestamps
		if ( arguments.params.keyExists( "timestamp_granularities" ) ) {
			variables.timestamps = arguments.params.timestamp_granularities
		}

		// OpenAI requires response_format=verbose_json when timestamps are requested
		if ( variables.timestamps.len() > 0 && variables.responseFormat != "verbose_json" ) {
			variables.responseFormat = "verbose_json"
		}

		return this
	}

	/**
	 * Apply a struct of high-level options in bulk.
	 * Recognizes: provider, apiKey, model, language, inputFormat, responseFormat,
	 * returnFormat, timestamps, diarize, timeout, logRequest, logResponse.
	 *
	 * @options Struct of options to apply
	 */
	AiTranscriptionRequest function withOptions( required struct options ){
		if ( arguments.options.keyExists( "provider" ) )             variables.provider             = arguments.options.provider
		if ( arguments.options.keyExists( "apiKey" ) )               variables.apiKey               = arguments.options.apiKey
		if ( arguments.options.keyExists( "model" ) )                variables.model                = arguments.options.model
		if ( arguments.options.keyExists( "language" ) )             variables.language             = arguments.options.language
		if ( arguments.options.keyExists( "inputFormat" ) )          variables.inputFormat          = arguments.options.inputFormat
		if ( arguments.options.keyExists( "responseFormat" ) )       variables.responseFormat       = arguments.options.responseFormat
		if ( arguments.options.keyExists( "returnFormat" ) )         variables.returnFormat         = arguments.options.returnFormat
		if ( arguments.options.keyExists( "timestamps" ) )           variables.timestamps           = arguments.options.timestamps
		if ( arguments.options.keyExists( "diarize" ) )              variables.diarize              = arguments.options.diarize
		if ( arguments.options.keyExists( "timeout" ) )              variables.timeout              = arguments.options.timeout
		if ( arguments.options.keyExists( "logRequest" ) )           variables.logRequest           = arguments.options.logRequest
		if ( arguments.options.keyExists( "logRequestToConsole" ) )  variables.logRequestToConsole  = arguments.options.logRequestToConsole
		if ( arguments.options.keyExists( "logResponse" ) )          variables.logResponse          = arguments.options.logResponse
		if ( arguments.options.keyExists( "logResponseToConsole" ) ) variables.logResponseToConsole = arguments.options.logResponseToConsole

		// OpenAI requires response_format=verbose_json when timestamps are requested
		if ( variables.timestamps.len() > 0 && variables.responseFormat != "verbose_json" ) {
			variables.responseFormat = "verbose_json"
		}

		return this
	}

	/**
	 * Enable request and/or response logging.
	 *
	 * @request  Log the request (default true)
	 * @response Log the response (default true)
	 * @console  Also print to console (default false)
	 */
	AiTranscriptionRequest function withLogging( boolean request = true, boolean response = true, boolean console = false ){
		variables.logRequest           = arguments.request
		variables.logResponse          = arguments.response
		variables.logRequestToConsole  = arguments.console && arguments.request
		variables.logResponseToConsole = arguments.console && arguments.response
		return this
	}

	// ==========================================================================
	// Terminators
	// ==========================================================================

	/**
	 * Terminator — execute transcription with all options configured in the builder chain.
	 * Calls aiTranscribe() with the current state of this request.
	 *
	 * @return String (returnFormat "text") or AiTranscriptionResponse
	 */
	function transcribe(){
		return aiTranscribe( _buildAudioSource(), _buildParams(), _buildOptions() )
	}

	/**
	 * Terminator — execute audio translation to English with all options in the builder chain.
	 * Calls aiTranslate() with the current state of this request.
	 *
	 * @return String (returnFormat "text") or AiTranscriptionResponse
	 */
	function translate(){
		return aiTranslate( _buildAudioSource(), _buildParams(), _buildOptions() )
	}

	// ==========================================================================
	// Private Helpers
	// ==========================================================================

	/**
	 * Return the best available audio source for passing to aiTranscribe()/aiTranslate().
	 */
	private any function _buildAudioSource(){
		if ( variables.audioFile.len() > 0 ) return variables.audioFile
		if ( variables.audioURL.len() > 0 )  return variables.audioURL
		return variables.audioData
	}

	/**
	 * Build the params struct, merging model in (aiTranscribe reads model from params).
	 */
	private struct function _buildParams(){
		var p = variables.params.copy()
		if ( len( variables.model ) && !p.keyExists( "model" ) ) {
			p.model = variables.model
		}
		return p
	}

	/**
	 * Build the options struct from current builder state.
	 */
	private struct function _buildOptions(){
		return {
			provider             : variables.provider,
			apiKey               : variables.apiKey,
			returnFormat         : variables.returnFormat,
			language             : variables.language,
			inputFormat          : variables.inputFormat,
			responseFormat       : variables.responseFormat,
			timestamps           : variables.timestamps,
			diarize              : variables.diarize,
			timeout              : variables.timeout,
			logRequest           : variables.logRequest,
			logRequestToConsole  : variables.logRequestToConsole,
			logResponse          : variables.logResponse,
			logResponseToConsole : variables.logResponseToConsole
		}
	}

}
