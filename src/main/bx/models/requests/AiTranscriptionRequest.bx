 * Request object for speech-to-text transcription and audio translation operations.
 * The audio source can be a local file path, a URL, or binary/base64 data.
 */
class extends="AiBaseRequest" {

	/**
	 * Path to a local audio file on disk
	 */
	property name="audioFile" default="";

	/**
	 * URL of a remote audio file (http/https)
	 */
	property name="audioURL" default="";

	/**
	 * Raw binary or base64-encoded audio data
	 */
	property name="audioData" default="";

	/**
	 * Input audio format hint: mp3, wav, flac, ogg, m4a, webm, etc.
	 */
	property name="inputFormat" default="";

	/**
	 * BCP-47 language code of the source audio (e.g. "en", "es", "fr").
	 * Leave empty for auto-detection.
	 */
	property name="language" default="";

	/**
	 * Desired response format from the provider: json, text, verbose_json, srt, vtt
	 */
	property name="responseFormat" default="json";

	/**
	 * Timestamp granularities to include: segment, word (provider support varies)
	 */
	property name="timestamps" type="array" default=[];

	/**
	 * Whether to enable speaker diarization (provider support varies)
	 */
	property name="diarize" type="boolean" default=false;

	/**
	 * Constructor
	 *
	 * @audio          The audio source: file path (string), URL (string), or binary data
	 * @params         Provider API parameters (language, response_format, timestamp_granularities, etc.)
	 * @options        High-level options (provider, apiKey, returnFormat, logging, etc.)
	 * @methodDefaults Default values merged into options before processing
	 */
	function init(
		any audio = "",
		struct params = {},
		struct options = {},
		struct methodDefaults = { returnFormat: "text" }
	){
		arguments.options = prepareOptions( arguments.options, arguments.methodDefaults );

		variables.params                = arguments.params;
		variables.provider              = options.provider ?: "";
		variables.apiKey                = options.apiKey ?: "";
		variables.logRequest            = options.logRequest ?: false;
		variables.logRequestToConsole   = options.logRequestToConsole ?: false;
		variables.logResponse           = options.logResponse ?: false;
		variables.logResponseToConsole  = options.logResponseToConsole ?: false;
		variables.returnFormat          = options.returnFormat ?: "text";
		variables.model                 = params.model ?: "";
		variables.timeout               = options.timeout ?: 60;
		variables.baseURL               = options.baseURL ?: "";
		variables.providerOptions       = options.providerOptions ?: {};
		variables.language              = params.language ?: options.language ?: "";
		variables.responseFormat        = params.response_format ?: options.responseFormat ?: "json";
		variables.timestamps            = params.timestamp_granularities ?: options.timestamps ?: [];
		variables.diarize               = params.diarize ?: options.diarize ?: false;
		variables.inputFormat           = params.inputFormat ?: options.inputFormat ?: "";

		// Detect and assign the audio source type
		if ( isSimpleValue( arguments.audio ) && arguments.audio.len() > 0 ) {
			if ( arguments.audio.left( 4 ) == "http" ) {
				variables.audioURL  = arguments.audio;
				variables.audioFile = "";
				variables.audioData = "";
			} else {
				variables.audioFile = arguments.audio;
				variables.audioURL  = "";
				variables.audioData = "";
				// Verify that the file exists, else throw an exception
				if ( !fileExists( variables.audioFile ) ) {
					throw(
						type    : "InvalidArgument",
						message : "Audio file not found at path: #variables.audioFile#"
					)
				}
			}
		} else if ( isBinary( arguments.audio ) ) {
			variables.audioData = arguments.audio;
			variables.audioFile = "";
			variables.audioURL  = "";
		} else {
			variables.audioFile = "";
			variables.audioURL  = "";
			variables.audioData = "";
		}

		return this;
	}

	/**
	 * Check whether this request has a valid audio source
	 */
	boolean function hasAudio(){
		return ( variables.audioFile.len() > 0 || variables.audioURL.len() > 0 || ( !isSimpleValue( variables.audioData ) || variables.audioData.len() > 0 ) );
	}

}
