 * Base class for AI request models that provides common properties and methods
 */
import bxModules.bxai.models.middleware.AiMiddlewareResult;
import bxModules.bxai.models.middleware.StructMiddlewareAdapter;

abstract class{

	/**
	 * The params struct to pass to the provider in the request
	 */
	property name="params" type="struct" default={};

	/**
	 * The provider to use for the request
	 */
	property name="provider" default="";

	/**
	 * The API key to use for the provider
	 */
	property name="apiKey" default="";

	/**
	 * Log request
	 */
	property name="logRequest" type="boolean" default=false;

	/**
	 * Log request to console
	 * This is usually used for debugging purposes
	 */
	property name="logRequestToConsole" type="boolean" default=false;

	/**
	 * Log response
	 */
	property name="logResponse" type="boolean" default=false;

	/**
	 * Log response to console
	 * This is usually used for debugging purposes
	 */
	property name="logResponseToConsole" type="boolean" default=false;

	/**
	 * The return format of the response
	 */
	property name="returnFormat" default="raw";

	/**
	 * The model to use for the request
	 */
	property name="model" default="";

	/**
	 * The timeout for the request
	 */
	property name="timeout" type="numeric" default="#static.DEFAULT_HTTP_TIMEOUT#";

	/**
	 * Base URL for the provider API (optional override for the service's default)
	 * Used by OpenAI-compatible services for custom endpoints
	 */
	property name="baseURL" type="string" default="";

	/**
	 * Send an auth header or not with the API Key
	 * This is usually determined by the provider
	 */
	property name="sendAuthHeader" type="boolean" default=true;

	/**
	 * A collection of headers to send with the request
	 */
	property name="headers" type="struct" default={};

	/**
	 * Maximum number of tool call interactions allowed
	 * If not set, will use the service default (10)
	 */
	property name="maxInteractions" type="numeric" default=0;

	/**
	 * Tenant identifier for multi-tenant usage tracking
	 * Used to attribute AI usage to specific tenants for billing purposes
	 */
	property name="tenantId" type="string" default="";

	/**
	 * Additional metadata for usage tracking (cost center, project, etc.)
	 * This data will be included in onAITokenCount events for custom billing logic
	 */
	property name="usageMetadata" type="struct" default={};

	/**
	 * Provider-specific options that don't fit the common interface
	 * Each provider can define and read its own keys from this struct
	 * Examples: inferenceProfileArn (Bedrock), customHeaders (OpenAI-compatible)
	 */
	property name="providerOptions" type="struct" default={};

	/**
	 * Resume context injected by AiAgent.resume() or resumeStream().
	 * Carries the human decision ("approve", "reject", "edit") and any edited data
	 * from a prior HumanInTheLoop suspension, so the middleware can honour it on the
	 * next tool call instead of suspending again.
	 */
	property name="resumeContext" type="struct" default={};

	/**
	 * Middleware stack for this request.
	 * Added via addMiddleware() — can be IAiMiddleware instances or struct-of-closures (auto-wrapped).
	 */
	property name="middleware" type="array" default=[];

	/**
	 * Module settings - centralized access point
	 */
	static {
		final MODULE_SETTINGS = getModuleInfo( "bxai" ).settings
		final DEFAULT_HTTP_TIMEOUT = MODULE_SETTINGS.timeout ?: 45
	}

	/**
	 * Prepare options by merging module settings with method-specific defaults and user options
	 * Merge order (lowest to highest priority): module settings → method defaults → user options
	 *
	 * @options User-provided options struct
	 * @methodDefaults Optional method-specific defaults (e.g., aiChat uses returnFormat="single")
	 *
	 * @return Merged options struct with all defaults applied
	 */
	struct function prepareOptions( struct options = {}, struct methodDefaults = {} ) {
		return {}
			// Start with module settings (lowest priority)
			.append( static.MODULE_SETTINGS, true )
			// Apply method-specific defaults (middle priority)
			.append( arguments.methodDefaults, true )
			// Apply user options (highest priority)
			.append( arguments.options, true )
	}

	/**
	 * Add a header to the request
	 *
	 * @name The name of the header
	 * @value The value of the header
	 */
	function addHeader( required string name, required string value ){
		variables.headers[ arguments.name ] = arguments.value;
		return this;
	}

	/**
	 * Set the model if it's empty
	 *
	 * @model The model to use if the current model is empty
	 */
	function setModelIfEmpty( required string model ){
		if( isNull( arguments.model ) || arguments.model.isEmpty() ){
			return this;
		}

		if( variables.model.isEmpty() ){
			variables.model = arguments.model;
		}
		return this;
	}

	/**
	 * Get Model if set or looks up from params
	 *
	 * @return The model to use
	 */
	function getModel(){
		if( !variables.model.isEmpty() ){
			return variables.model;
		}
		if( variables.params.keyExists( "model" ) ){
			return variables.params.model;
		}
		return "";
	}

	/**
	 * Set the API key if it's empty
	 *
	 * @apiKey The API key to use if the current API key is empty
	 */
	function setApiKeyIfEmpty( required string apiKey ){
		if( variables.apiKey.isEmpty() ){
			variables.apiKey = arguments.apiKey;
		}
		return this;
	}

	/**
	 * Merge service params into the request params
	 *
	 * @serviceParams The service params to merge
	 * @override If true, override existing params with service params
	 *
	 * @return This request
	 */
	AiBaseRequest function mergeServiceParams( required struct serviceParams, boolean override = false ){
		// Filter out model as it's handled separately in some implementations
		//var paramsToMerge = arguments.serviceParams.filter( ( key, value ) => key != "model" );
		variables.params.append( arguments.serviceParams, arguments.override );
		return this;
	}

	/**
	 * Merge service headers into the request headers
	 *
	 * @serviceHeaders The service headers to merge
	 * @override If true, override existing headers with service headers
	 *
	 * @return This request
	 */
	AiBaseRequest function mergeServiceHeaders( required struct serviceHeaders, boolean override = false ){
		variables.headers.append( arguments.serviceHeaders, arguments.override );
		return this;
	}

	/**
	 * Get a provider option by key with an optional default value
	 *
	 * @key The option key to retrieve
	 * @defaultValue The default value if the key doesn't exist
	 *
	 * @return The option value or the default
	 */
	function getProviderOption( required string key, any defaultValue = "" ){
		return variables.providerOptions[ arguments.key ] ?: arguments.defaultValue;
	}

	// ==================== Middleware Support ====================

	/**
	 * Add a middleware to the request's stack.
	 * Structs are automatically wrapped in StructMiddlewareAdapter.
	 * Arrays are flattened — each element is added individually.
	 *
	 * @middleware IAiMiddleware instance, struct-of-closures, or array of either
	 *
	 * @return This request for chaining
	 */
	AiBaseRequest function addMiddleware( required any middleware ) {
		if ( isArray( arguments.middleware ) ) {
			arguments.middleware.each( mw => addMiddleware( mw ) );
			return this;
		}

		if ( isStruct( arguments.middleware ) && !isObject( arguments.middleware ) ) {
			// Wrap plain struct-of-closures in the adapter
			variables.middleware.append( new StructMiddlewareAdapter( arguments.middleware ) );
		} else {
			variables.middleware.append( arguments.middleware );
		}
		return this;
	}

	/**
	 * Fire a named sequential hook across the middleware stack.
	 *
	 * - Iterates forward (or in reverse when reverse=true for "after" hooks)
	 * - Stops and returns the first terminal result (cancel, reject, or suspend)
	 * - Returns AiMiddlewareResult.continue() if all middleware pass
	 * - Fires the onError hook if any middleware throws
	 *
	 * @hook    Hook method name (e.g. "beforeToolCall")
	 * @context Context struct for this hook
	 * @reverse If true, iterate in reverse order (for outbound "after" hooks)
	 *
	 * @return The first terminal AiMiddlewareResult, or continue()
	 */
	AiMiddlewareResult function fireMiddleware(
		required string hook,
		required struct context,
		boolean reverse = false
	) {
		if ( variables.middleware.isEmpty() ) {
			return AiMiddlewareResult.continue()
		}

		var stack = arguments.reverse ? variables.middleware.reverse() : variables.middleware

		for ( var mw in stack ) {
			try {
				var result = invoke( mw, arguments.hook, { context: arguments.context } )

				// Ensure we got a proper AiMiddlewareResult back
				if ( !isNull( result ) && result instanceof "AiMiddlewareResult" && result.isTerminal() ) {
					return result
				}
			} catch ( any e ) {
				writeLog(
					text: "Error in middleware " & arguments.hook & " handler: " & e.message & e.detail,
					type:"error",
					log: "ai"
				)
				// Fire onError hook, then rethrow
				try {
					invoke( mw, "onError", {
						context: {
							error  : e,
							phase  : arguments.hook,
							context: arguments.context
						}
					} )
				} catch ( any ignored ) {
					writeLog(
						text: "Error in middleware onError handler: " & ignored.message & ignored.detail,
						type:"error",
						log: "ai"
					)
				}
				rethrow
			}
		}

		return AiMiddlewareResult.continue()
	}

	/**
	 * Fire a wrap-style hook that surrounds the actual invocation.
	 *
	 * Builds a nested closure chain so each middleware wraps the next.
	 * The innermost layer is innerFunction.
	 *
	 * @hook    Wrap method name (e.g. "wrapLLMCall" or "wrapToolCall")
	 * @context Context struct for this hook
	 * @innerFunction The actual LLM/tool call to execute at the center
	 *
	 * @return The result of the outermost wrapper (which eventually calls innerFunction)
	 */
	any function fireWrapMiddleware(
		required string hook,
		required struct context,
		required function innerFunction
	) {
		if ( variables.middleware.isEmpty() ) {
			return arguments.innerFunction()
		}

		// Build the chain from innermost (last middleware) to outermost (first middleware).
		// Each layer is created via a private helper so its captured variables live in
		// their own function-call scope — avoiding the classic closure-in-loop bug where
		// all lambdas share the same (final) values of loop variables.
		var chain = arguments.innerFunction
		var i     = variables.middleware.len()
		while ( i >= 1 ) {
			chain = _buildWrapLayer( variables.middleware[ i ], arguments.hook, arguments.context, chain )
			i--
		}

		return chain()
	}

	/**
	 * Creates a single wrap-layer closure that captures its arguments in an isolated
	 * function scope, preventing shared-variable issues when chaining multiple layers.
	 */
	private function _buildWrapLayer(
		required any mw,
		required string hook,
		required struct context,
		required function next
	) {
		var _mw   = arguments.mw
		var _hook = arguments.hook
		var _ctx  = arguments.context
		var _next = arguments.next
		return () => invoke( _mw, _hook, [ _ctx, _next ] )
	}

}
