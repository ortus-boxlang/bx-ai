 * Request object for text-to-speech synthesis operations.
 * Contains the input text and all audio generation parameters.
 */
class extends="AiBaseRequest" {

	/**
	 * The text to convert to speech
	 */
	property name="text" default="";

	/**
	 * The voice to use for synthesis (provider-specific voice name or ID)
	 */
	property name="voice" default="";

	/**
	 * The output audio format: mp3, wav, flac, opus, pcm (provider support varies)
	 */
	property name="outputFormat" default="mp3";

	/**
	 * Speech speed multiplier (0.25 to 4.0 for OpenAI; providers vary)
	 */
	property name="speed" type="numeric" default=1.0;

	/**
	 * Constructor
	 *
	 * @text          The text to convert to speech
	 * @params         Provider API parameters (voice, speed, model, language, etc.)
	 * @options        High-level options (provider, apiKey, returnFormat, outputFile, logging, etc.)
	 * @methodDefaults Default values merged into options before processing
	 */
	function init(
		string text = "",
		struct params = {},
		struct options = {},
		struct methodDefaults = { returnFormat: "response" }
	){
		arguments.options = prepareOptions( arguments.options, arguments.methodDefaults );

		variables.text                 = arguments.text;
		variables.params                = arguments.params;
		variables.provider              = options.provider ?: "";
		variables.apiKey                = options.apiKey ?: "";
		variables.logRequest            = options.logRequest ?: false;
		variables.logRequestToConsole   = options.logRequestToConsole ?: false;
		variables.logResponse           = options.logResponse ?: false;
		variables.logResponseToConsole  = options.logResponseToConsole ?: false;
		variables.returnFormat          = options.returnFormat ?: "response";
		variables.model                 = params.model ?: "";
		variables.timeout               = options.timeout ?: 30;
		variables.baseURL               = options.baseURL ?: "";
		variables.providerOptions       = options.providerOptions ?: {};
		variables.voice                 = params.voice ?: options.voice ?: "";
		variables.outputFormat          = params.outputFormat ?: options.outputFormat ?: "mp3";
		variables.speed                 = params.speed ?: options.speed ?: 1.0;

		return this;
	}

}
