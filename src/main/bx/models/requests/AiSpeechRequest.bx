 * ----------------------------------------------------------------------------------
 * Request object for text-to-speech synthesis operations.
 * Contains the input text and all audio generation parameters.
 *
 * Can be used directly (constructed by aiSpeak()) or as a fluent builder when aiSpeak() is called
 * with no text:
 *
 * ```bx
 * response = aiSpeak()
 *     .text( "Hello from BoxLang!" )
 *     .provider( "openai" )
 *     .female()
 *     .asWav()
 *     .speak()
 *
 * response = AiSpeechRequest
 *     .of( "Hello from BoxLang!" )
 *     .male()
 *     .asFlac()
 *     .speak()
 * ```
 *
 * BoxLang auto-generates fluent setters for all properties (setText, setVoice, etc.)
 * The methods below add shorter, more expressive aliases for common builder operations.
 */
class extends="AiBaseRequest" {

	/**
	 * The text to convert to speech
	 */
	property name="text" default="";

	/**
	 * The voice to use for synthesis (provider-specific voice name or ID)
	 */
	property name="voice" default="";

	/**
	 * The output audio format: mp3, wav, flac, opus, pcm (provider support varies)
	 */
	property name="outputFormat" default="mp3";

	/**
	 * Speech speed multiplier (0.25 to 4.0 for OpenAI; providers vary)
	 */
	property name="speed" type="numeric" default=1.0;

	/**
	 * Natural-language style instructions for the voice (e.g. "Speak like a pirate").
	 * Only supported by models that accept an instructions field, such as OpenAI gpt-4o-mini-tts.
	 */
	property name="instructions" default="";

	/**
	 * If set, the generated audio is automatically saved to this file path.
	 * When set, .speak() returns the saved file path string instead of AiSpeechResponse.
	 */
	property name="outputFile" default="";

	/**
	 * Constructor
	 *
	 * @text          The text to convert to speech
	 * @params         Provider API parameters (voice, speed, model, language, etc.)
	 * @options        High-level options (provider, apiKey, returnFormat, outputFile, logging, etc.)
	 * @methodDefaults Default values merged into options before processing
	 */
	function init(
		string text = "",
		struct params = {},
		struct options = {},
		struct methodDefaults = { returnFormat: "response" }
	){
		super.init()

		// Prepare options with method defaults (e.g. returnFormat) before seeding variables, so defaults are applied even when using the fluent builder without passing options to the constructor
		arguments.options = prepareOptions( arguments.options, arguments.methodDefaults );

		// Seed audio-specific defaults directly — do NOT merge all moduleRecord.settings into options
		// because that would overwrite options.apiKey with the module global key, which breaks cross-provider key resolution inside aiService() (e.g. GROQ_API_KEY convention check)
		variables.text                 = arguments.text
		variables.params                = arguments.params
		variables.provider              = options.provider ?: ""
		variables.apiKey                = options.apiKey ?: ""
		variables.logRequest            = options.logRequest ?: false
		variables.logRequestToConsole   = options.logRequestToConsole ?: false
		variables.logResponse           = options.logResponse ?: false
		variables.logResponseToConsole  = options.logResponseToConsole ?: false
		variables.returnFormat          = options.returnFormat ?: "response"
		variables.model                 = params.model ?: ""
		variables.timeout               = options.timeout ?: 30
		variables.baseURL               = options.baseURL ?: ""
		variables.providerOptions       = options.providerOptions ?: {}
		variables.voice                 = params.voice ?: options.voice ?: ""
		variables.outputFormat          = params.outputFormat ?: options.outputFormat ?: "mp3"
		variables.speed                 = params.speed ?: options.speed ?: 1.0
		variables.instructions          = params.instructions ?: options.instructions ?: ""
		variables.outputFile            = options.outputFile ?: ""

		// Resolve genered voice if passed
		var effectiveVoice = arguments.params.voice ?: arguments.options.voice ?: "";
		if ( len( effectiveVoice ) && listFindNoCase( "male,female", effectiveVoice ) ) {
			resolveGenderedVoice( effectiveVoice )
		}

		return this;
	}

	// ==========================================================================
	// Static Factory
	// ==========================================================================

	/**
	 * Create a new speech request builder seeded with text.
	 *
	 * @text The text to convert to speech
	 */
	static AiSpeechRequest function of( required string text ){
		return new AiSpeechRequest( text = arguments.text )
	}

	// ==========================================================================
	// Fluent Builder API
	// ==========================================================================

	/**
	 * Set the text to synthesize.
	 *
	 * @text The text to convert to speech
	 */
	AiSpeechRequest function text( required string text ){
		variables.text = arguments.text
		return this
	}

	/**
	 * Set the AI model to use (e.g. "tts-1", "tts-1-hd", "gpt-4o-mini-tts").
	 *
	 * @model The model name
	 */
	AiSpeechRequest function model( required string model ){
		variables.model = arguments.model
		return this
	}

	/**
	 * Set the provider (e.g. "openai", "gemini", "groq").
	 *
	 * @provider The provider name
	 */
	AiSpeechRequest function provider( required string provider ){
		variables.provider = arguments.provider
		return this
	}

	/**
	 * Set the API key for the provider.
	 *
	 * @apiKey The API key
	 */
	AiSpeechRequest function apiKey( required string apiKey ){
		variables.apiKey = arguments.apiKey
		return this
	}

	/**
	 * Set the voice to use for synthesis.
	 * Provider-specific voice names (e.g. "alloy", "nova") or the gender shortcuts
	 * .male() / .female() which are resolved by the BIF's gender-map logic.
	 *
	 * @voice The voice name or ID
	 */
	AiSpeechRequest function voice( required string voice ){
		variables.voice = arguments.voice
		return this
	}

	/**
	 * Check if a voice has been set on this request (either directly or via the .male() / .female() shortcuts).
	 * Useful for conditionally applying voice-related options or logic in aiSpeak() before the request is executed.
	 */
	boolean function hasVoice(){
		return !variables.voice.isEmpty()
	}

	/**
	 * Set the speech speed multiplier.
	 *
	 * @speed Speed multiplier (0.25 to 4.0 for OpenAI)
	 */
	AiSpeechRequest function speed( required numeric speed ){
		variables.speed = arguments.speed
		return this
	}

	/**
	 * Set natural-language style instructions for the voice.
	 *
	 * @instructions Style or mood instructions
	 */
	AiSpeechRequest function instructions( required string instructions ){
		variables.instructions = arguments.instructions
		return this
	}

	/**
	 * Set the file path where the generated audio will be automatically saved.
	 * When set, .speak() returns the saved file path string instead of AiSpeechResponse.
	 *
	 * @filePath Absolute or relative path for the output file
	 */
	AiSpeechRequest function outputFile( required string filePath ){
		variables.outputFile = arguments.filePath
		return this
	}

	/**
	 * Set the output audio format ("mp3", "wav", "flac", "opus", "pcm").
	 *
	 * @format The output format name
	 */
	AiSpeechRequest function outputFormat( required string format ){
		variables.outputFormat = arguments.format
		return this
	}

	/**
	 * Set the request timeout in seconds.
	 *
	 * @seconds Timeout in seconds
	 */
	AiSpeechRequest function timeout( required numeric seconds ){
		variables.timeout = arguments.seconds
		return this
	}

	/**
	 * Use a male voice (resolved via provider gender map in aiSpeak()).
	 */
	AiSpeechRequest function male(){
		variables.voice = "male"
		return this
	}

	/**
	 * Use a female voice (resolved via provider gender map in aiSpeak()).
	 */
	AiSpeechRequest function female(){
		variables.voice = "female"
		return this
	}

	/**
	 * Output format convenience method: mp3.
	 */
	AiSpeechRequest function asMP3(){
		variables.outputFormat = "mp3"
		return this
	}

	/**
	 * Output format convenience method: wav.
	 */
	AiSpeechRequest function asWav(){
		variables.outputFormat = "wav"
		return this
	}

	/**
	 * Output format convenience method: flac.
	 */
	AiSpeechRequest function asFlac(){
		variables.outputFormat = "flac"
		return this
	}

	/**
	 * Output format convenience method: opus.
	 */
	AiSpeechRequest function asOpus(){
		variables.outputFormat = "opus"
		return this
	}

	/**
	 * Output format convenience method: pcm.
	 */
	AiSpeechRequest function asPCM(){
		variables.outputFormat = "pcm"
		return this
	}

	/**
	 * Merge additional provider API parameters into the request params.
	 * Useful for provider-specific fields not covered by the standard properties.
	 *
	 * @params Struct of provider API parameters to merge
	 */
	AiSpeechRequest function withParams( required struct params ){
		variables.params.append( arguments.params, true )
		return this
	}

	/**
	 * Apply a struct of high-level options in bulk.
	 * Recognizes: provider, apiKey, model, voice, speed, instructions,
	 * outputFile, outputFormat, timeout, logRequest, logResponse.
	 *
	 * @options Struct of options to apply
	 */
	AiSpeechRequest function withOptions( required struct options ){
		if ( arguments.options.keyExists( "provider" ) )             variables.provider             = arguments.options.provider
		if ( arguments.options.keyExists( "apiKey" ) )               variables.apiKey               = arguments.options.apiKey
		if ( arguments.options.keyExists( "model" ) )                variables.model                = arguments.options.model
		if ( arguments.options.keyExists( "voice" ) )                variables.params.voice         = arguments.options.voice
		if ( arguments.options.keyExists( "speed" ) )                variables.speed                = arguments.options.speed
		if ( arguments.options.keyExists( "instructions" ) )         variables.instructions         = arguments.options.instructions
		if ( arguments.options.keyExists( "outputFormat" ) )         variables.outputFormat         = arguments.options.outputFormat
		if ( arguments.options.keyExists( "outputFile" ) )           variables.outputFile           = arguments.options.outputFile
		if ( arguments.options.keyExists( "timeout" ) )              variables.timeout              = arguments.options.timeout
		if ( arguments.options.keyExists( "logRequest" ) )           variables.logRequest           = arguments.options.logRequest
		if ( arguments.options.keyExists( "logRequestToConsole" ) )  variables.logRequestToConsole  = arguments.options.logRequestToConsole
		if ( arguments.options.keyExists( "logResponse" ) )          variables.logResponse          = arguments.options.logResponse
		if ( arguments.options.keyExists( "logResponseToConsole" ) ) variables.logResponseToConsole = arguments.options.logResponseToConsole
		return this
	}

	/**
	 * Enable request and/or response logging.
	 *
	 * @request  Log the request (default true)
	 * @response Log the response (default true)
	 * @console  Also print to console (default false)
	 */
	AiSpeechRequest function withLogging( boolean request = true, boolean response = true, boolean console = false ){
		variables.logRequest           = arguments.request
		variables.logResponse          = arguments.response
		variables.logRequestToConsole  = arguments.console && arguments.request
		variables.logResponseToConsole = arguments.console && arguments.response
		return this
	}

	// ==========================================================================
	// Terminator
	// ==========================================================================

	/**
	 * Terminator — execute speech synthesis with all options configured in the builder chain.
	 * Calls aiSpeak() with the current state of this request, which fires all events,
	 * validates the provider capability, and returns AiSpeechResponse (or a file path when
	 * outputFile is set).
	 *
	 * @return AiSpeechResponse, or the saved file path string when outputFile is set
	 */
	function speak(){
		// Resolve gendered voice if set but not yet resolved
		if ( len( variables.voice ) && listFindNoCase( "male,female", variables.voice ) ) {
			resolveGenderedVoice( variables.voice )
		}

		// Merge model into a copy of params (aiSpeak reads model from params, not options)
		var newParams = variables.params.copy()
		if ( len( variables.model ) && !newParams.keyExists( "model" ) ) {
			newParams.model = variables.model
		}

		if( hasVoice() ){
			newParams.voice = variables.voice
		}

		return aiSpeak(
			variables.text,
			newParams,
			{
				provider             : variables.provider,
				apiKey               : variables.apiKey,
				speed                : variables.speed,
				instructions         : variables.instructions,
				outputFormat         : variables.outputFormat,
				outputFile           : variables.outputFile,
				timeout              : variables.timeout,
				logRequest           : variables.logRequest,
				logRequestToConsole  : variables.logRequestToConsole,
				logResponse          : variables.logResponse,
				logResponseToConsole : variables.logResponseToConsole
			}
		)
	}

	/**
	 * Resolve gender keywords ("male"/"female") to provider-specific voice names, so providers always receive a concrete voice identifier, not a keyword.
	 *
	 * @gender The gender keyword to resolve ("male" or "female")
	 * @provider The provider for which to resolve the voice (optional; falls back to options.provider, then module default provider)
	 *
	 * @return The resolved voice name is set back on the request params.voice property
	 */
	private string function resolveGenderedVoice( string gender, string provider ){
		var audioSettings = super.getModuleSettings().audio
		var resolvedProviderForVoice = variables.provider.isEmpty() ? ( audioSettings.defaultProvider ?: super.getModuleSettings().provider ) : variables.provider
		var genderMap               = audioSettings.voiceGenderMap ?: {}
		var providerGenderMap       = genderMap[ resolvedProviderForVoice ] ?: {}
		var mappedVoice             = providerGenderMap[ arguments.gender.lcase() ] ?: ""
		if ( len( mappedVoice ) ) {
			variables.voice = mappedVoice
			return mappedVoice
		}
		return ""
	}

}
