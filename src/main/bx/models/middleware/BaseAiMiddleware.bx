 * ----------------------------------------------------------------------------------
 * Abstract no-op base class for AI middleware.
 * <br>
 * Extend this class and override only the hooks you need.
 * All unoverridden hooks return AiMiddlewareResult.continue() by default.
 * Wrap hooks delegate directly to the next handler by default.
 * <br>
 * This is the recommended base class for most middleware implementations, as it provides sensible defaults and reduces boilerplate.
 * If you want to implement IAiMiddleware directly, you must provide implementations for all hooks.
 * The StructMiddlewareAdapter class provides an alternative for users who prefer to pass a struct of closures instead of a full class.
 */
import bxModules.bxai.models.middleware.AiMiddlewareResult;

abstract class implements="IAiMiddleware" {

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function beforeAgentRun( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function afterAgentRun( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function beforeLLMCall( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function afterLLMCall( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function beforeToolCall( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function afterToolCall( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: continue
	 */
	AiMiddlewareResult function onError( required struct context ) {
		return AiMiddlewareResult.continue();
	}

	/**
	 * Default: just call the next handler and return
	 */
	any function wrapLLMCall( required struct context, required function handler ) {
		return arguments.handler();
	}

	/**
	 * Default: just call the next handler and return
	 */
	any function wrapToolCall( required struct context, required function handler ) {
		return arguments.handler();
	}

}
