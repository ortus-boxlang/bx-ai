 * ----------------------------------------------------------------------------------
 * Human-in-the-Loop (HITL) middleware.
 *
 * Intercepts tool calls that match the configured approval list and either:
 *   - mode "cli"  : Blocks execution and prompts the user on stdin/stdout
 *   - mode "web"  : Suspends the run, returning an AiMiddlewareResult.suspend() so the
 *                   caller can checkpoint and present the approval request asynchronously.
 *
 * CLI mode example:
 *   aiAgent( middleware: new HumanInTheLoopMiddleware( toolsRequiringApproval: [ "deleteRecord" ] ) )
 *
 * Web / async mode example:
 *   aiAgent(
 *       middleware  : new HumanInTheLoopMiddleware(
 *                         mode                 : "web",
 *                         toolsRequiringApproval: [ "placeOrder" ]
 *                    ),
 *       checkpointer: aiMemory( "cache" )
 *   )
 *
 * After suspension the caller receives an AiMiddlewareResult and can call:
 *   agent.resume( "approve", threadId )
 *   agent.resume( "reject", threadId )
 *   agent.resume( "edit", threadId, { correctedArgs: { ... } } )
 */
import bxModules.bxai.models.middleware.BaseAiMiddleware;
import bxModules.bxai.models.middleware.AiMiddlewareResult;

class extends="BaseAiMiddleware" {

	/**
	 * Tool names that require human approval (case-insensitive)
	 */
	property name="toolsRequiringApproval" type="array" default=[];

	/**
	 * Approval mode: "cli" (blocking stdin prompt) or "web" (suspend and return)
	 */
	property name="approvalMode" type="string" default="cli";

	/**
	 * Optional callback invoked on approval in web mode: function( context ) => "approve"|"reject"|"edit"
	 */
	property name="approvalCallback";

	/**
	 * Controls whether to show tool arguments in the CLI prompt
	 */
	property name="showArguments" type="boolean" default=true;

	/**
	 * Constructor
	 *
	 * @toolsRequiringApproval Array of tool names needing human sign-off
	 * @mode                   "cli" or "web", determines how the middleware requests approval. Default is "cli".
	 * @showArguments          Whether to print tool arguments in the CLI prompt
	 * @approvalCallback       Optional callback for custom approval logic
	 */
	function init(
		array    toolsRequiringApproval = [],
		string   mode                   = "cli",
		boolean  showArguments          = true,
		function approvalCallback
	) {
		variables.toolsRequiringApproval = arguments.toolsRequiringApproval
		variables.approvalMode           = arguments.mode
		variables.showArguments          = arguments.showArguments
		variables.approvalCallback 		 = arguments.approvalCallback

		return this
	}

	// ==================== Hooks ====================

	/**
	 * Intercept tool calls that require approval.
	 */
	AiMiddlewareResult function beforeToolCall( required struct context ) {
		var toolName = context.toolName ?: (context.tool?.getName() ?: "")

		// ── Resume path ──────────────────────────────────────────────────────────
		// If AiAgent.resume() was called, a resumeContext is stored on the request.
		// Honour the human decision here instead of suspending again.
		var resumeCtx = context.chatRequest.getResumeContext() ?: {}
		if ( !resumeCtx.isEmpty() && resumeCtx.keyExists( "resumeDecision" ) ) {

			// Only consume the context for the exact tool that was suspended
			var suspendedTool = resumeCtx.suspendData?.toolName ?: ""
			if ( suspendedTool.isEmpty() || suspendedTool == toolName ) {

				// Clear so subsequent tool calls in the same run go through normal HITL
				context.chatRequest.setResumeContext( {} )

				var decision = resumeCtx.resumeDecision

				if ( decision == "reject" ) {
					return AiMiddlewareResult.reject( "Rejected by human operator during resume." )
				}

				if ( decision == "edit" && !resumeCtx.editedData.isEmpty() ) {
					// Patch tool call arguments with the edited data.
					// BaseService reads toolCall.function.arguments AFTER beforeToolCall
					// returns, so in-place mutation is picked up automatically.
					var newArgs = resumeCtx.editedData.correctedArgs ?: resumeCtx.editedData
					if ( !isNull( context.toolCall ) && context.toolCall.keyExists( "function" ) ) {
						context.toolCall.function.arguments = jsonSerialize( newArgs )
					}
				}

				// "approve" (and "edit" after patching) → let the tool proceed
				return AiMiddlewareResult.continue()
			}
		}
		// ── End resume path ──────────────────────────────────────────────────────

		// Only intercept matching tools
		if ( variables.toolsRequiringApproval.findNoCase( toolName ) == 0 ) {
			return AiMiddlewareResult.continue()
		}

		// Gather pending tool info
		var pendingData = {
			toolName  : toolName,
			toolCall  : context.toolCall ?: {},
			arguments : context.toolCall?.function?.arguments ?: "{}"
		}

		if ( variables.approvalMode == "web" ) {
			// Async/web mode: suspend and let the caller checkpoint
			return AiMiddlewareResult.suspend( pendingData )
		}

		// CLI mode: block and prompt on stdin/stdout
		return cliApprove( toolName, pendingData )
	}

	// ==================== Private Helpers ====================

	private AiMiddlewareResult function cliApprove( required string toolName, required struct pendingData ) {
		println( "" )
		println( "╔══════════════════════════════════════════════════╗" )
		println( "║         HUMAN APPROVAL REQUIRED                  ║" )
		println( "╚══════════════════════════════════════════════════╝" )
		println( " Tool: #arguments.toolName#" )

		if ( variables.showArguments ) {
			println( " Args: #arguments.pendingData.arguments#" )
		}

		println( "" )
		println( " [A]pprove  [R]eject  [Q]uit" )
		print  ( " Decision: " )

		var input = cliRead().trim().lCase()

		println( "" )

		if ( input == "a" || input == "approve" ) {
			return AiMiddlewareResult.approve()
		}

		if ( input == "r" || input == "reject" ) {
			return AiMiddlewareResult.reject( "Rejected by human operator." )
		}

		// "q" or anything else = cancel the entire run
		return AiMiddlewareResult.cancel( "Human operator chose to quit." )
	}

}
