/**
 * LoggingMiddleware - Logs all agent lifecycle events
 */
component extends="models.middleware.BaseAiMiddleware" accessors="true" {

    // Name of the log file (creates {logName}.log)
    property name="logName" type="string" default="ai";

    /**
     * Log level for all messages
     * Options: debug | info | warn | error
     * Maps to writeLog types: debug→information, info→information, warn→warning, error→error
     */
    property name="logLevel" type="string" default="debug";

    /**
     * Whether to include tool arguments in logs (security-sensitive)
     */
    property name="logArgs" type="boolean" default=true;

    /**
     * Whether to include token usage in logs (if available)
     */
    property name="logTokens" type="boolean" default=false;

    /**
     * Initialize logging middleware with options
     */
    function init(
        string logName = "ai",
        string logLevel = "debug",
        boolean logArgs = true,
        boolean logTokens = false
    ) {
        variables.logName = arguments.logName;
        variables.logLevel = arguments.logLevel;
        variables.logArgs = arguments.logArgs;
        variables.logTokens = arguments.logTokens;

        // Log middleware initialization
        log( "LoggingMiddleware initialized: level=#arguments.logLevel#, args=#arguments.logArgs#", "init" );

        return this;
    }

    /**
     * PRIVATE: Normalized logging utility
     */
    private function log( required string message, string event = "" ) {
        var logType = mapLogLevel( variables.logLevel );
        var prefix = "[bx-ai]";
        
        if ( len( arguments.event ) ) {
            prefix &= "[#arguments.event#]";
        }

        writeLog(
            text="#prefix# #arguments.message#",
            type=logType,
            file=variables.logName
        );
    }

    /**
     * Map logLevel to writeLog type
     */
    private string function mapLogLevel( required string level ) {
        switch( arguments.level.lcase() ) {
            case "warn":  return "warning";
            case "error": return "error";
            default:      return "information";
        }
    }

    /**
     * Log before agent execution starts
     */
    function beforeAgentRun( required struct context ) {
        var detail = "Agent '#context.agent.agentName#' starting";

        // Add input preview (first 100 chars)
        if ( structKeyExists( context, "input" ) && len( toString( context.input ) ) > 0 ) {
            var inputPreview = left( toString( context.input ), 100 );
            if ( len( toString( context.input ) ) > 100 ) {
                inputPreview &= "...";
            }
            detail &= " | Input: #inputPreview#";
        }

        log( detail, "beforeAgentRun" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log after agent execution completes
     */
    function afterAgentRun( required struct context ) {
        var detail = "Agent '#context.agent.agentName#' completed";

        // Add response preview (first 100 chars)
        if ( structKeyExists( context, "response" ) ) {
            var responsePreview = left( toString( context.response ), 100 );
            if ( len( toString( context.response ) ) > 100 ) {
                responsePreview &= "...";
            }
            detail &= " | Response: #responsePreview#";
        }

        log( detail, "afterAgentRun" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log before LLM call
     */
    function beforeLLMCall( required struct context ) {
        var detail = "LLM call starting";

        // Add model name if available
        if ( structKeyExists( context, "model" ) && 
             isObject( context.model ) && 
             context.model.keyExists( "name" ) ) {
            detail &= " | Model: #context.model.name#";
        }

        // Add message count
        if ( structKeyExists( context, "messages" ) && isArray( context.messages ) ) {
            detail &= " | Messages: #arrayLen( context.messages )#";
        }

        // Add tools count
        if ( structKeyExists( context, "chatRequest" ) && 
             context.chatRequest.keyExists( "tools" ) ) {
            detail &= " | Tools: #arrayLen( context.chatRequest.tools )#";
        }

        log( detail, "beforeLLMCall" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log after LLM responds
     */
    function afterLLMCall( required struct context ) {
        var detail = "LLM call completed";

        // Add token usage if enabled and available
        if ( variables.logTokens && 
             structKeyExists( context, "response" ) && 
             isStruct( context.response ) ) {

            if ( structKeyExists( context.response, "usage" ) && isStruct( context.response.usage ) ) {
                var usage = context.response.usage;
                var promptTokens = usage.keyExists( "prompt_tokens" ) ? usage.prompt_tokens : 0;
                var completionTokens = usage.keyExists( "completion_tokens" ) ? usage.completion_tokens : 0;
                var totalTokens = usage.keyExists( "total_tokens" ) ? usage.total_tokens : promptTokens + completionTokens;
                
                detail &= " | Tokens: #promptTokens#in/#completionTokens#out/#totalTokens#total";
            }
        }

        // Add response preview
        if ( isStruct( context.response ) && context.response.keyExists( "content" ) ) {
            var contentPreview = left( toString( context.response.content ), 100 );
            if ( len( toString( context.response.content ) ) > 100 ) {
                contentPreview &= "...";
            }
            detail &= " | Response: #contentPreview#";
        }

        log( detail, "afterLLMCall" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log before tool execution
     */
    function beforeToolCall( required struct context ) {
        var detail = "🔧 Tool '#context.toolName#' starting";

        // Add tool call ID
        if ( structKeyExists( context, "toolCallId" ) && len( context.toolCallId ) ) {
            detail &= " | ID: #context.toolCallId#";
        }

        // Add arguments if enabled (security-sensitive)
        if ( variables.logArgs && structKeyExists( context, "toolArgs" ) && isStruct( context.toolArgs ) ) {
            var argsJson = serializeJSON( context.toolArgs );
            // Limit args to 200 chars to avoid huge logs
            if ( len( argsJson ) > 200 ) {
                argsJson = left( argsJson, 200 ) & "...";
            }
            detail &= " | Args: #argsJson#";
        }

        log( detail, "beforeToolCall" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log after tool execution
     */
    function afterToolCall( required struct context ) {
        var detail = "✅ Tool '#context.toolName#' completed";

        // Add result preview
        if ( structKeyExists( context, "result" ) ) {
            var resultStr = "";
            if ( isSimpleValue( context.result ) ) {
                resultStr = toString( context.result );
            } else if ( isStruct( context.result ) ) {
                resultStr = serializeJSON( context.result );
            } else {
                resultStr = "[#context.result.getClass().getName()#]";
            }

            // Limit to 200 chars
            if ( len( resultStr ) > 200 ) {
                resultStr = left( resultStr, 200 ) & "...";
            }
            detail &= " | Result: #resultStr#";
        }

        log( detail, "afterToolCall" );
        return AiMiddlewareResult.continueChain();
    }

    /**
     * Log suspension events
     */
    function onSuspend( required struct context ) {
        var detail = "⏸️ Execution SUSPENDED";
        if ( structKeyExists( context, "reason" ) ) {
            detail &= " | Reason: #context.reason#";
        }
        if ( structKeyExists( context, "threadId" ) ) {
            detail &= " | Thread: #context.threadId#";
        }
        log( detail, "onSuspend" );
        return AiMiddlewareResult.continueChain();
    }

}

