/**
 * RateLimitMiddleware - API rate limiting + exponential backoff - PHASE 5 COMPLETE
 * Protects against API provider rate limits with token bucket + retry logic
 */
component extends="models.middleware.BaseAiMiddleware" accessors="true" {

    /**
     * Requests per minute (RPM) limit
     */
    property name="requestsPerMinute" type="numeric" default=60;

    /**
     * Maximum retries for rate limit errors
     */
    property name="maxRetries" type="numeric" default=3;

    /**
     * Base delay between retries (ms)
     */
    property name="baseDelayMs" type="numeric" default=1000;

    /**
     * Recent request timestamps (sliding window)
     */
    property name="requestTimes" type="array" default=[];

    function init(
        numeric requestsPerMinute = 60,
        numeric maxRetries = 3,
        numeric baseDelayMs = 1000
    ) {
        variables.requestsPerMinute = arguments.requestsPerMinute;
        variables.maxRetries = arguments.maxRetries;
        variables.baseDelayMs = arguments.baseDelayMs;
        return this;
    }

    /**
     * Check rate limit before LLM calls
     */
    function beforeLLMCall( required struct context ) {
        var nowMs = getTickCount();
        var windowMs = 60000; // 1 minute sliding window
        
        // Clean old timestamps
        variables.requestTimes = variables.requestTimes.filter( t => nowMs - t < windowMs );
        
        // Check limit
        if ( arrayLen( variables.requestTimes ) >= variables.requestsPerMinute ) {
            var waitMs = windowMs / variables.requestsPerMinute;
            sleep( waitMs );
            log( "Rate limit delay: #waitMs#ms" );
        }
        
        arrayAppend( variables.requestTimes, nowMs );
        return AiMiddlewareResult.continue();
    }

    /**
     * Wrap LLM calls with retry + backoff
     */
    function wrapLLMCall( required struct context, required function serviceFn ) {
        var retries = 0;
        
        while ( retries <= variables.maxRetries ) {
            try {
                return serviceFn();
            } catch ( any e ) {
                if ( isRateLimitError( e ) && retries < variables.maxRetries ) {
                    retries++;
                    var delayMs = variables.baseDelayMs * ( 2 ^ retries ); // Exponential backoff
                    log( "Rate limit hit (#retries#/#variables.maxRetries#), waiting #delayMs#ms" );
                    sleep( delayMs );
                    continue;
                }
                rethrow;
            }
        }
        
        throw( 
            type="RateLimitExceededException",
            message="Max retries (#variables.maxRetries#) exceeded for rate limited operation"
        );
    }

    private boolean function isRateLimitError( required any error ) {
        var msg = error.message ?: "";
        return findNoCase( "429", msg ) || 
               findNoCase( "rate limit", msg ) || 
               findNoCase( "quota", msg );
    }

    private function log( required string msg ) {
        writeLog( text="[bx-ai][RateLimit] #msg#", type="warning", file="ai" );
    }

}
