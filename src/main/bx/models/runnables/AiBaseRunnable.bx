 * ----------------------------------------------------------------------------------
 * Base abstract class for all AI runnables.
 * Defines the common interface and helper methods for AI operations, including tool management and response formatting.
 * All specific runnable types (models, agents, transforms, etc.) should extend this base class
 */
import bxModules.bxai.models.util.SchemaBuilder;
import bxModules.bxai.models.middleware.StructMiddlewareAdapter;

abstract class implements="IAiRunnable" {

	/**
	 * The name of the runnable
	 */
	property name="name" type="string" default="";

	/**
	 * Default parameters for this runnable
	 */
	property name="defaultParams" type="struct" default={};

	/**
	 * Default options for this runnable (returnFormat, timeout, logging, etc.)
	 */
	property name="defaultOptions" type="struct" default={};

	/**
	 * MCP servers that can be used by this runnable for internal tool calls to sub-agents and tools. This allows the runnable to make calls to sub-agents and tools registered on those MCP servers, enabling distributed agent architectures and tool usage across multiple servers.
	 * Each entry is a struct: { url: string, toolNames: array }
	 */
	property name="mcpServers" type="array" default=[];

	/**
	 * The tools attached to this runnable for tool-augmented generation.
	 */
	property name="tools" type="array" default=[];

	/**
	 * Middleware stack for this runnable.
	 */
	property name="middleware" type="array" default=[];

    /**
	 * ---------------------------------------------------------------------------------------------------------
	 * Interface Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Run the operation with the given input
	 *
	 * @input The input to process, empty struct if none
	 * @params Optional parameters to configure the operation, these override defaults
	 * @options Optional runtime options (returnFormat, timeout, logging, etc.)
	 *
	 * @return The result of the operation
	 */
	public any function run(
		any input = {},
		struct params = {},
		struct options = {}
	){
        // Abstract method - to be implemented by subclasses
        throw( type: "NotImplementedError", message: "The 'run' method must be implemented by subclasses of AiBaseRunnable." );
    }

	/**
	 * Stream the operation with the given input, calling onChunk for each chunk
	 *
	 * @onChunk The callback function to invoke for each chunk
	 * @input The input to process, empty struct if none
	 * @params Optional parameters to configure the operation
	 * @options Optional runtime options (returnFormat, timeout, logging, etc.)
	 */
	public void function stream(
		required function onChunk,
        any input = {},
		struct params = {},
		struct options = {}
	){
        // Abstract method - to be implemented by subclasses
        throw( type: "NotImplementedError", message: "The 'stream' method must be implemented by subclasses of AiBaseRunnable." );
    }

	/**
	 * Chain this runnable with another runnable
	 * Creates a sequence that will execute this runnable followed by the next
     *
     * Example:
     * ```
     * var runnable1 = new SomeAiRunnable();
     * var runnable2 = new AnotherAiRunnable();
     * var sequence = runnable1.to( runnable2 );
     * var result = sequence.run( inputData );
     * ```
     *
     * In this example, `runnable1` is executed first, and its output is passed as input to `runnable2`.
     * The final result is obtained from `runnable2`.
	 *
	 * @next The next runnable to execute
	 *
	 * @return A new AiRunnableSequence containing both runnables in order
	 */
	public IAiRunnable function to( required IAiRunnable next ) {
		var sequence = new AiRunnableSequence( [ this, arguments.next ] );

		// Propagate default options from this runnable to the sequence
		if ( !variables.defaultOptions.isEmpty() ) {
			sequence.withOptions( variables.defaultOptions );
		}

		return sequence;
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Runnable Chaining and Composition Methods
	 * These methods allow you to easily chain runnables together, connect them to models, and apply transformations to create complex AI workflows with minimal boilerplate.
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Alias to to()
	 * Langchain style method name
	 */
	public IAiRunnable function pipe( required IAiRunnable next ) {
		return this.to( arguments.next );
	}

	/**
	 * Connect this runnable to a specific AI model
	 * Uses the specified provider and apiKey
	 * This is a convenience method
	 *
	 * Example:
	 * ```
	 * var runnable = aiMessage( "Hello ${name}" )
	 * var pipeline = runnable.toModel( "openai", "my-api-key" )
	 * var result = pipeline.run( { name: "World" } )
	 * ```
	 *
	 * This is a convenience method equivalent to: this.to( aiModel( provider, apiKey ) )
	 *
	 * @provider The AI service provider to use
	 * @apiKey The API key to use with the provider
	 *
	 * @return A new runnable sequence connected to the specified model
	 */
	public IAiRunnable function toModel(
		required string provider,
		string apiKey,
		any tools=[],
		struct params={}
		) {
		return this.to( aiModel( argumentCollection: arguments ) )
	}

	/**
	 * Apply a transformation function after this runnable
	 * Creates a sequence with a transform runnable
     *
     * Example:
     * ```
     * var runnable = new SomeAiRunnable()
     * var transformedRunnable = runnable.transform( input => input.ucase() )
     * var finalResult = transformedRunnable.run( inputData )
     * ```
     *
     * In this example, the output of `runnable` is transformed to uppercase by the provided function before being returned as `finalResult`.
     * This allows for easy post-processing of results.
	 *
	 * @transformer The transformation function or object with a transform() method to apply
	 *
	 * @return A new runnable sequence with the transform step
	 */
	public IAiRunnable function transform( required any transformer ) {
		return this.to( new AiTransformRunnable( arguments.transformer ) )
	}

	/**
	 * Connect this runnable to the default AI model
	 * Uses the provider and apiKey from module settings
     *
     * Example:
     * ```
     * var runnable = aiMessage( "Hello ${name}" )
     * var pipeline = runnable.toDefaultModel()
     * var result = pipeline.run( { name: "World" } )
     * ```
     *
     * This is a convenience method equivalent to: this.to( aiModel() )
	 *
	 * @return A new runnable sequence connected to the default model
	 */
	public IAiRunnable function toDefaultModel() {
		return this.to( aiModel() )
	}

    /**
     * Apply a transformation function and run in one step
     * Combines transform() and run() for convenience
     *
     * @transformer The transformation function or object with a transform() method to apply
     * @input The input to process
     * @params Optional parameters to configure the operation
     *
     * @return The transformed result of the operation
     */
    public any function transformAndRun(
        required any transformer,
        any input = {},
        struct params = {}
    ) {
        return this.transform( arguments.transformer )
            .run( arguments.input, arguments.params )
    }

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Configuration and Helper Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Set the name of this runnable
	 *
	 * @name The name to set
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function withName( required string name ) {
		variables.name = arguments.name
		return this
	}

	/**
	 * Get the name of this runnable
	 * Uses the explicitly set name if available, otherwise falls back to metadata
	 *
	 * @return The name of the runnable
	 */
	public string function getName() {
		if ( len( variables.name ) ) {
			return variables.name
		}
		return getMetadata( this ).name
	}

	/**
	 * Set default parameters for this runnable
	 * Merges with existing default parameters
	 *
	 * @params The parameters to merge
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function withParams( required struct params ) {
		variables.defaultParams.append( arguments.params, true );
		return this;
	}

	/**
	 * Merge incoming parameters with default parameters
	 * Runtime parameters take precedence over defaults
	 *
	 * @params Runtime parameters to merge
	 *
	 * @return The merged parameter struct
	 */
	public struct function getMergedParams( struct params = {} ) {
		var out = duplicate( variables.defaultParams );
		out.append( arguments.params, true );
		return out;
	}

    /**
     * Clear all default parameters for this runnable
     *
     * @return This runnable for chaining
     */
    public IAiRunnable function clearParams(){
        variables.defaultParams = {};
        return this;
    }

	/**
	 * Set default options for this runnable
	 * Options control runtime behavior like returnFormat, timeout, logging, etc.
	 * Merges with existing default options
	 *
	 * @options The options to merge
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function withOptions( required struct options ) {
		variables.defaultOptions.append( arguments.options, true );
		return this;
	}

	/**
	 * Merge incoming options with default options
	 * Runtime options take precedence over defaults
	 *
	 * @options Runtime options to merge
	 *
	 * @return The merged options struct
	 */
	public struct function getMergedOptions( struct options = {} ) {
		var out = duplicate( variables.defaultOptions );
		out.append( arguments.options, true );
		return out;
	}

	/**
	 * Clear all default options for this runnable
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function clearOptions(){
		variables.defaultOptions = {};
		return this;
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Tool Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	 /**
	 * Get a summary of all tools registered to this runnable.
	 *
	 * @return Array of structs: [{ name, description }]
	 */
	public array function listTools() {
		return variables.tools.map( tool => {
			return { name: tool.getName(), description: tool.getDescription() }
		} )
	}

	/**
	 * @deprecated Use withTools() instead. This method will be removed in a future version.
	 */
	public AiBaseRunnable function bindTools( required any tools ) {
		return this.withTools( arguments.tools )
	}

	/**
	 * @deprecated Use withTools() instead. This method will be removed in a future version.
	 */
	public AiBaseRunnable function addTools( required any tools ) {
		return this.withTools( arguments.tools )
	}

	/**
	 * Add a tool to the runnable's toolset.
	 * This allows the tool to be used for tool-augmented generation when this runnable is executed.
	 *
	 * @tool The tool to add
	 *
	 * @return this for chaining
	 */
	public AiBaseRunnable function addTool( required ITool tool ) {
		variables.tools.append( arguments.tool )
		return this
	}

	 /**
	  * Bind tools to this runnable
	  *
	  * @tools An array of tools to bind, or a single tool (will be wrapped as array)
	  * @return This runnable with tools bound
	  */
	public AiBaseRunnable function withTools( required any tools ) {
		// If simple value, wrap as array
		if( !isArray( arguments.tools ) ){
			arguments.tools = [ arguments.tools ]
		}
		variables.tools.append( arguments.tools, true )
		return this
	}

	/**
	 * Remove specific tools from this model, either by name or by reference
	 *
	 * @tools One or more tools to remove, specified as tool instances or tool names (will be wrapped as array if not already)
	 *
	 * @return This model with tools removed
	 */
	public AiBaseRunnable function removeTools( any tools ) {
		// If simple value, wrap as array
		if( !isArray( arguments.tools ) ){
			arguments.tools = [ arguments.tools ]
		}

		// Extract tool names from the input array, whether they are tool instances or string names
		arguments.tools
			.map( t => {
				if ( isObject( t ) && t instanceof "ITool" ) {
					return t.getName()
				}
				return t.toString()
			} )
			// Remove each tool from the current tools array
			.each( toolToRemove => {
				var index = variables.tools.findNoCase( t => t.getName() == toolToRemove )
				if ( index > 0 ) {
					variables.tools.deleteAt( index )
				}
			} )

		return this
	}

	/**
	 * Verify if a tool is registered to this runnable
	 *
	 * @tool The tool to check for, or the name of the tool to check for (matched by reference or name)
	 *
	 * @return Boolean indicating if the tool is registered
	 */
	public boolean function hasTool( required any tool ) {
		var targetTool = arguments.tool
		return variables.tools.some( t => {
			if( isObject( targetTool ) && targetTool instanceof "ITool" ) {
				return t == targetTool
			} else if ( isSimpleValue( targetTool ) ) {
				return t.getName() == targetTool
			}
			return false
		} );
	}

	/**
	 * Get a specific tool by name
	 *
	 * @name The name of the tool to retrieve
	 *
	 * @return The tool instance if found, otherwise null
	 */
	public ITool function getTool( required string name ) {
		return variables.tools.findFirst( t => t.getName() == name )
	}

	/**
	 * Clear All tools from this runnable
	 *
	 * @return This runnable with all tools removed
	 */
	public AiBaseRunnable function clearTools() {
		variables.tools = []
		return this
	}



	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Middleware Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	 /**
	 * Add middleware to this runnable. Middleware can be used to modify the input, output, or behavior of the runnable in a reusable way.
	 * Middleware can be an instance of IAiMiddleware, a struct of closures (with beforeRun, afterRun, onError, etc.), or an array of either.
	 * Structs are automatically wrapped in StructMiddlewareAdapter.
	 * Arrays are flattened — each element is added individually.
	 *
	 * @middleware IAiMiddleware instance, struct-of-closures, or array of either
	 *
	 * @return This runnable for chaining
	 */
	public AiBaseRunnable function withMiddleware( required any middleware ) {
		if ( isArray( arguments.middleware ) ) {
			arguments.middleware.each( mw => withMiddleware( mw ) )
			return this
		}
		if ( isStruct( arguments.middleware ) && !isObject( arguments.middleware ) ) {
			variables.middleware.append( new StructMiddlewareAdapter( arguments.middleware ) )
		} else {
			variables.middleware.append( arguments.middleware )
		}
		return this
	}

	/**
	 * Clear all middleware from this runnable
	 *
	 * @return This runnable with all middleware removed
	 *
	 */
	public AiBaseRunnable function clearMiddleware() {
		variables.middleware = []
		return this
	}

	/**
	 * Get a summary of all middleware registered to this runnable.
	 *
	 * @return Array of structs: [{ name, description }]
	 */
	public array function listMiddleware() {
		return variables.middleware.map( mw => {
			return { name: mw.getName(), description: mw.getDescription() }
		} )
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * MCP Server Tools Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Seed this runnable with tools from multiple MCP servers.
	 *
	 * Each entry in the array can be:
	 * - A URL string to the MCP server: "http://server:3000"
	 * - A config struct: { url: "http://server:3000", token: "...", timeout: 5000 }
	 * - A pre-configured MCPClient instance
	 *
	 * @servers  Array of MCP server descriptors
	 *
	 * @return This runnable for chaining
	 */
	public AiBaseRunnable function withMCPServers( required array servers ) {
		arguments.servers.each( mcpServer => {
			if ( isStruct( mcpServer ) && !isObject( mcpServer ) ) {
				withMCPServer( mcpServer.url ?: "", mcpServer.filter( ( k, v ) => k != "url" ) )
			} else {
				withMCPServer( mcpServer )
			}
		} )
		return this
	}

	/**
	 * Seed this model with tools discovered from an MCP server.
	 *
	 * Connects to the MCP server, calls listTools(), and wraps each discovered tool
	 * as an MCPTool instance that is added to the model's tool list.
	 *
	 * @mcpServer  A URL string pointing to the MCP server, or a pre-configured MCPClient instance.
	 * @config  Optional configuration struct with any of: token, timeout, headers, user, password.
	 *
	 * @return This runnable for chaining
	 */
	public AiBaseRunnable function withMCPServer( required any mcpServer, struct config = {} ) {
		var mcpClient   = buildMCPClient( arguments.mcpServer, arguments.config );
		var response = mcpClient.listTools();

		if ( response.isSuccess() ) {
			var data      = response.getData();
			var toolsList = isArray( data ) ? data : ( data.keyExists( "tools" ) ? data.tools : [] )
			var toolNames = [];

			toolsList.each( toolDef => {
				withTools( [ new bxModules.bxai.models.tools.MCPTool( mcpClient, toolDef ) ] )
				toolNames.append( toolDef.name ?: "" );
			} )

			// Track server metadata for config inspection and system message generation
			variables.mcpServers.append( {
				"url"      : mcpClient.getBaseURL(),
				"toolNames": toolNames
			} );
		} else{
			// Write to logs that the MCP server connection failed, but don't throw an error since the runnable can still function without the tools
			var errorData = response.getError();
			writeLog(
				text: "Failed to connect to MCP server at " & ( isSimpleValue( arguments.mcpServer ) ? arguments.mcpServer : arguments.mcpServer.getBaseURL() ) & " - " & errorData,
				type: "error",
				log: "ai"
			)
		}

		return this;
	}

	/**
	 * Build (or reuse) an MCPClient, applying optional config overrides.
	 *
	 * @serverUrl  URL string or existing MCPClient
	 * @config  Optional struct with token, timeout, headers, user, password
	 *
	 * @return Configured MCPClient
	 */
	private any function buildMCPClient( required any serverUrl, struct config = {} ) {
		var mcpClient = isSimpleValue( arguments.serverUrl )
			? mcp( arguments.serverUrl )
			: arguments.serverUrl

		if ( arguments.config.keyExists( "timeout" ) ) {
			mcpClient.withTimeout( arguments.config.timeout )
		}
		if ( arguments.config.keyExists( "token" ) )   {
			mcpClient.withBearerToken( arguments.config.token )
		}
		if ( arguments.config.keyExists( "headers" ) ) {
			mcpClient.withHeaders( arguments.config.headers )
		}
		if ( arguments.config.keyExists( "user" ) )    {
			mcpClient.withAuth( arguments.config.user, arguments.config.password ?: "" )
		}

		return mcpClient
	}

	/**
	 * ---------------------------------------------------------------------------------------------------------
	 * Response Helper Methods
	 * ---------------------------------------------------------------------------------------------------------
	 */

	/**
	 * Convenience method to set return format to 'single'
	 * Returns only the content string from the first message
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function singleMessage() {
		return this.withOptions( { returnFormat: "single" } );
	}

	/**
	 * Convenience method to set return format to 'all'
	 * Returns an array of all choice messages
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function allMessages() {
		return this.withOptions( { returnFormat: "all" } );
	}

	/**
	 * Convenience method to set return format to 'json'
	 * Returns the parsed JSON object from the content string
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function asJson() {
		return this.withOptions( { returnFormat: "json" } );
	}

	/**
	 * Convenience method to set return format to 'xml'
	 * Returns the parsed XML document from the content string
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function asXml() {
		return this.withOptions( { returnFormat: "xml" } );
	}

	/**
	 * Convenience method to set return format to 'raw'
	 * Returns the full raw response from the provider
	 *
	 * @return This runnable for chaining
	 */
	public IAiRunnable function rawResponse() {
		return this.withOptions( { returnFormat: "raw" } );
	}

	/**
	 * Define structured output using a class, struct, or JSON schema
	 * The LLM response will be validated against this schema and populated accordingly
	 *
	 * Example with class:
	 * ```
	 * class Person {
	 *     property name="firstName" type="string";
	 *     property name="age" type="numeric";
	 * }
	 * var person = aiModel().structuredOutput( new Person() ).run( "Extract: John Doe, age 30" );
	 * ```
	 *
	 * Example with struct:
	 * ```
	 * var schema = { name: "", age: 0, active: true };
	 * var result = aiModel().structuredOutput( schema ).run( "Parse this data" );
	 * ```
	 *
	 * @schema Class instance, struct definition, JSON schema, or array notation [classInstance]
	 * @return This runnable for chaining
	 */
	public IAiRunnable function structuredOutput( required any schema ) {
		return this.withOptions( { returnFormat: arguments.schema } );
	}

	/**
	 * Define structured output using a raw JSON schema
	 * Use this when you have a pre-built JSON schema object
	 *
	 * Example:
	 * ```
	 * var jsonSchema = {
	 *     "type": "object",
	 *     "properties": {
	 *         "name": { "type": "string" },
	 *         "age": { "type": "number" }
	 *     },
	 *     "required": ["name", "age"]
	 * };
	 * var result = aiModel().schema( jsonSchema ).run( "Extract data" );
	 * ```
	 *
	 * @jsonSchema JSON schema struct or string
	 * @return This runnable for chaining
	 */
	public IAiRunnable function schema( required any jsonSchema ) {
		return this.withOptions( { schema: arguments.jsonSchema } );
	}

	/**
	 * Define multiple structured outputs with named schemas
	 * Useful when you need to extract multiple different data structures
	 *
	 * Example:
	 * ```
	 * var result = aiModel()
	 *     .structuredOutputs([
	 *         { name: "contact", schema: new ContactInfo() },
	 *         { name: "event", schema: new EventDetails() }
	 *     ])
	 *     .run( "Extract contact and event info" );
	 * // result.contact.name, result.event.date, etc.
	 * ```
	 *
	 * @schemas Array of schema definitions: [{ name: "schemaName", schema: definition }]
	 * @return This runnable for chaining
	 */
	public IAiRunnable function structuredOutputs( required array schemas ) {
		// Merge the schemas into a single struct-based schema
		// Mark it so the chat request knows it's already a schema (not data to infer from)
		var mergedSchema = SchemaBuilder::merge( arguments.schemas );
		mergedSchema._isSchema = true;  // Flag to prevent re-processing
		return this.withOptions( { returnFormat: mergedSchema } );
	}

}
