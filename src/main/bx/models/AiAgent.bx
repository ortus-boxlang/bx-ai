import bxModules.bxai.models.runnables.*;
import bxModules.bxai.models.middleware.*;
import bxModules.bxai.models.memory.*;

class extends="AiBaseRunnable" {

	// =========================================================================
	// PROPERTIES
	// =========================================================================

	property name="agentName"      type="string"    default="BxAi";
	property name="description"    type="string"    default="";
	property name="instructions"   type="string"    default="";
	property name="aiModel"        type="AiModel";
	property name="tools"          type="array"     default=[];
	property name="memories"       type="array"     default=[];
	property name="params"         type="struct"    default={};
	property name="options"        type="struct"    default={};
	property name="subAgents"      type="array"     default=[];
	property name="subAgentTools"  type="array"     default=[];
	property name="middleware"     type="array"     default=[];

	// Checkpointing (HITL)
	property name="checkpointer"   type="IAiMemory";
	property name="checkpointTTL"  type="numeric"   default=30;
	property name="threadId"       type="string"    default="";

	// =========================================================================
	// CONSTANTS
	// =========================================================================

	static {
		DEFAULT_AGENT_NAME   = "BxAi";
		DEFAULT_DESCRIPTION  = "You are a helpful AI assistant";
		DEFAULT_INSTRUCTIONS = "Use available tools when needed to accomplish tasks effectively.";
	}

	// =========================================================================
	// CONSTRUCTOR
	// =========================================================================

	function init(
		string agentName         = static.DEFAULT_AGENT_NAME,
		string description       = static.DEFAULT_DESCRIPTION,
		string instructions      = static.DEFAULT_INSTRUCTIONS,
		AiModel model            = aiModel(),
		any memory               = aiMemory(),
		array tools              = [],
		array subAgents          = [],
		array middleware         = [],
		any checkpointer         = "",
		numeric checkpointTTL    = 30,
		string threadId          = "",
		struct params            = {},
		struct options           = {},
		numeric maxInteractions  = 0
	){
		super.init();

		setName( arguments.agentName );
		variables.description  = arguments.description;
		variables.instructions = arguments.instructions;
		variables.aiModel      = arguments.model.addTools( arguments.tools );
		variables.tools        = arguments.tools;
		variables.params       = arguments.params;
		variables.middleware   = [];
		param variables.options.returnFormat = "single";

		// Memory setup
		variables.memories = isArray( arguments.memory ) ? arguments.memory : [ arguments.memory ];

		// Sub-agents
		variables.subAgents     = [];
		variables.subAgentTools = [];
		arguments.subAgents.each( addSubAgent );

		// Middleware
		if( !arguments.middleware.isEmpty() ){
			withMiddleware( arguments.middleware );
		}

		// Checkpointer
		if( !isNull( arguments.checkpointer ) && isObject( arguments.checkpointer ) ){
			withCheckpointer( arguments.checkpointer, arguments.checkpointTTL );
		}

		// Thread ID
		if( len( arguments.threadId ) ){
			withThreadId( arguments.threadId );
		}

		// Backward compat — auto-add MaxToolCallsMiddleware if maxInteractions provided
		if( arguments.maxInteractions > 0 && !hasMaxToolCallsMiddleware() ){
			arrayAppend( variables.middleware,
				new MaxToolCallsMiddleware(
					maxCalls     = arguments.maxInteractions,
					exitBehavior = "end"
				)
			);
			writeLog(
				text = "[bx-ai][AiAgent] Auto-added MaxToolCallsMiddleware (max=#arguments.maxInteractions#)",
				type = "information",
				log  = "ai"
			);
		}

		return this;
	}

	// =========================================================================
	// CHECKPOINTER METHODS
	// =========================================================================

	/**
	 * Configure checkpointer (fluent)
	 */
	AiAgent function withCheckpointer( required any checkpointer, numeric ttlMinutes=30 ){
		variables.checkpointer  = arguments.checkpointer;
		variables.checkpointTTL = arguments.ttlMinutes;
		return this;
	}

	/**
	 * Set explicit thread ID (fluent)
	 */
	AiAgent function withThreadId( required string threadId ){
		variables.threadId = arguments.threadId;
		return this;
	}

	/**
	 * Get or auto-generate thread ID
	 */
	string function getThreadId(){
		if( len( variables.threadId ) ) return variables.threadId;
		if( !variables.memories.isEmpty() ){
			return hash( variables.memories[ 1 ].key() & createUUID() );
		}
		return createUUID();
	}

	/**
	 * Resume from a suspended checkpoint with a human decision.
	 * Supports approve, reject, and edit decisions.
	 *
	 * @decision AiMiddlewareResult — must be approve, reject, or edit
	 * @threadId Optional thread ID override
	 */
	any function resume( required AiMiddlewareResult decision, string threadId="" ){
		var tid = len( arguments.threadId ) ? arguments.threadId : getThreadId();

		if( isNull( variables.checkpointer ) ){
			throw(
				type    = "NoCheckpointerException",
				message = "Cannot resume without a checkpointer. Use withCheckpointer()."
			);
		}

		var state    = variables.checkpointer.loadState( tid );
		var messages = state.messages ?: [];
		var params   = state.params   ?: {};
		var options  = state.options  ?: {};
		var pending  = state.pending  ?: {};

		// Apply human decision
		if( arguments.decision.isApproved() ){
			pending.approved = true;
		} else if( arguments.decision.isRejected() ){
			arrayAppend( messages, {
				"role"        : "tool",
				"tool_call_id": pending.toolCallId ?: "",
				"content"     : "Rejected by human: #arguments.decision.getReason()#"
			});
		} else if( arguments.decision.isEdit() ){
			pending.toolArgs = arguments.decision.getData();
			pending.approved = true;
		} else {
			throw(
				type    = "InvalidDecisionException",
				message = "Decision must be approve, reject, or edit."
			);
		}

		// Clear checkpoint — one-time use
		variables.checkpointer.clearState( tid );

		return runFromMessages( messages, params, options );
	}

	/**
	 * Resume from a suspended checkpoint and stream the result.
	 *
	 * @onChunk  Callback receiving each streamed chunk
	 * @decision AiMiddlewareResult — must be approve, reject, or edit
	 * @threadId Optional thread ID override
	 */
	void function resumeStream(
		required function onChunk,
		required AiMiddlewareResult decision,
		string threadId = ""
	){
		var tid = len( arguments.threadId ) ? arguments.threadId : getThreadId();

		if( isNull( variables.checkpointer ) ){
			arguments.onChunk( AiMiddlewareResult.reject( "No checkpointer configured" ) );
			return;
		}

		try {
			var state    = variables.checkpointer.loadState( tid );
			var messages = state.messages ?: [];
			var params   = state.params   ?: {};
			var options  = state.options  ?: {};
			var pending  = state.pending  ?: {};

			if( arguments.decision.isApproved() ){
				pending.approved = true;
			} else if( arguments.decision.isRejected() ){
				arrayAppend( messages, {
					"role"        : "tool",
					"tool_call_id": pending.toolCallId ?: "",
					"content"     : "Rejected by human: #arguments.decision.getReason()#"
				});
			} else if( arguments.decision.isEdit() ){
				pending.toolArgs = arguments.decision.getData();
				pending.approved = true;
			}

			variables.checkpointer.clearState( tid );
			streamFromMessages( arguments.onChunk, messages, params, options );

		} catch( any e ){
			arguments.onChunk( AiMiddlewareResult.reject( e.message ) );
		}
	}

	// =========================================================================
	// MAIN EXECUTION
	// =========================================================================

	/**
	 * Run the agent synchronously
	 */
	public any function run( any input="", struct params={}, struct options={} ){
		var userMessage = isStruct( input ) && input.keyExists( "content" )
			? input
			: { "role": "user", "content": toString( input ) };

		var messages = [];
		if( len( buildSystemMessage() ) ){
			arrayAppend( messages, { "role": "system", "content": buildSystemMessage() } );
		}
		arrayAppend( messages, loadMemoryMessages(), true );
		arrayAppend( messages, userMessage );

		var effectiveParams  = duplicate( variables.params ).append( arguments.params );
		var effectiveOptions = duplicate( variables.options ).append( arguments.options );

		var chatRequest  = new AiChatRequest().addMiddleware( variables.middleware );
		var agentContext = {
			"agent"   : this,
			"input"   : input,
			"messages": messages,
			"params"  : effectiveParams,
			"options" : effectiveOptions
		};

		// beforeAgentRun
		var beforeResult = chatRequest.fireMiddleware( "beforeAgentRun", agentContext );
		if( beforeResult.isTerminal() ) return beforeResult;

		// Execute via model
		var response = variables.aiModel.run( messages, effectiveParams, effectiveOptions );

		// Handle suspension
		if( isInstanceOf( response, "AiMiddlewareResult" ) && response.isSuspended() ){
			if( !isNull( variables.checkpointer ) ){
				variables.checkpointer.saveState(
					getThreadId(),
					{
						"messages": messages,
						"params"  : effectiveParams,
						"options" : effectiveOptions,
						"pending" : response.getData()
					},
					variables.checkpointTTL
				);
			}
			return response;
		}

		// Store in memory
		storeInMemory( userMessage, response );

		// afterAgentRun (reverse order)
		agentContext.response = response;
		chatRequest.fireMiddleware( "afterAgentRun", agentContext, true );

		return response;
	}

	/**
	 * Run the agent with streaming output
	 */
	public void function stream( required function onChunk, any input="", struct params={}, struct options={} ){
		var userMessage = isStruct( input ) && input.keyExists( "content" )
			? input
			: { "role": "user", "content": toString( input ) };

		var messages = [];
		if( len( buildSystemMessage() ) ){
			arrayAppend( messages, { "role": "system", "content": buildSystemMessage() } );
		}
		arrayAppend( messages, loadMemoryMessages(), true );
		arrayAppend( messages, userMessage );

		var effectiveParams  = duplicate( variables.params ).append( arguments.params );
		var effectiveOptions = duplicate( variables.options ).append( arguments.options );

		var chatRequest  = new AiChatRequest().addMiddleware( variables.middleware );
		var agentContext = {
			"agent"   : this,
			"input"   : input,
			"messages": messages,
			"params"  : effectiveParams,
			"options" : effectiveOptions
		};

		// beforeAgentRun
		var beforeResult = chatRequest.fireMiddleware( "beforeAgentRun", agentContext );
		if( beforeResult.isTerminal() ){
			arguments.onChunk( beforeResult );
			return;
		}

		streamFromMessages( arguments.onChunk, messages, effectiveParams, effectiveOptions );
	}

	// =========================================================================
	// PRIVATE HELPERS
	// =========================================================================

	/**
	 * Continue execution from a pre-built messages array (used by resume)
	 */
	private any function runFromMessages( required array messages, struct params={}, struct options={} ){
		var chatRequest  = new AiChatRequest().addMiddleware( variables.middleware );
		var agentContext = {
			"agent"   : this,
			"messages": arguments.messages,
			"params"  : arguments.params,
			"options" : arguments.options
		};

		var beforeResult = chatRequest.fireMiddleware( "beforeAgentRun", agentContext );
		if( beforeResult.isTerminal() ) return beforeResult;

		var response = variables.aiModel.run( arguments.messages, arguments.params, arguments.options );

		if( isInstanceOf( response, "AiMiddlewareResult" ) && response.isSuspended() ){
			if( !isNull( variables.checkpointer ) ){
				variables.checkpointer.saveState(
					getThreadId(),
					{
						"messages": arguments.messages,
						"params"  : arguments.params,
						"options" : arguments.options,
						"pending" : response.getData()
					},
					variables.checkpointTTL
				);
			}
			return response;
		}

		storeInMemory( arguments.messages[ arrayLen( arguments.messages ) ], response );
		agentContext.response = response;
		chatRequest.fireMiddleware( "afterAgentRun", agentContext, true );

		return response;
	}

	/**
	 * Stream from a pre-built messages array (used by resumeStream)
	 */
	private void function streamFromMessages(
		required function onChunk,
		required array messages,
		struct params  = {},
		struct options = {}
	){
		var chatRequest  = new AiChatRequest().addMiddleware( variables.middleware );
		var agentContext = {
			"agent"   : this,
			"messages": arguments.messages,
			"params"  : arguments.params,
			"options" : arguments.options
		};

		var beforeResult = chatRequest.fireMiddleware( "beforeAgentRun", agentContext );
		if( beforeResult.isTerminal() ){
			arguments.onChunk( beforeResult );
			return;
		}

		// Wrap callback to handle suspension and completion
		var self         = this;
		var wrappedChunk = function( chunk ){
			// Suspension detected mid-stream
			if( isInstanceOf( chunk, "AiMiddlewareResult" ) && chunk.isSuspended() ){
				if( !isNull( self.checkpointer ) ){
					self.checkpointer.saveState(
						self.getThreadId(),
						{
							"messages": messages,
							"params"  : params,
							"options" : options,
							"pending" : chunk.getData()
						},
						self.checkpointTTL
					);
				}
				onChunk( chunk );
				agentContext.response = chunk;
				chatRequest.fireMiddleware( "afterAgentRun", agentContext, true );
				return;
			}

			// Pass normal chunks through
			onChunk( chunk );

			// On final chunk, store memory and fire afterAgentRun
			if( isStruct( chunk ) && chunk.keyExists( "finish_reason" ) ){
				var finalResponse = {
					"role"   : "assistant",
					"content": chunk.choices[ 1 ].delta.content ?: ""
				};
				storeInMemory( messages[ arrayLen( messages ) ], finalResponse );
				agentContext.response = finalResponse;
				chatRequest.fireMiddleware( "afterAgentRun", agentContext, true );
			}
		};

		variables.aiModel.stream( wrappedChunk, arguments.messages, arguments.params, arguments.options );
	}

	private string function buildSystemMessage(){
		var parts = [];
		if( len( variables.description ) )  arrayAppend( parts, "Role: #variables.description#" );
		if( len( variables.instructions ) ) arrayAppend( parts, variables.instructions );
		return arrayToList( parts, chr( 10 ) & chr( 10 ) );
	}

	private array function loadMemoryMessages(){
		var allMessages = [];
		variables.memories.each( function( mem ){
			arrayAppend( allMessages, mem.getAll(), true );
		});
		return allMessages;
	}

	private void function storeInMemory( required struct userMessage, required any response ){
		if( variables.memories.isEmpty() ) return;

		variables.memories.each( function( mem ){
			mem.add( arguments.userMessage );
		});

		var content = "";
		if( isStruct( arguments.response ) && arguments.response.keyExists( "content" ) ){
			content = arguments.response.content;
		} else if( isSimpleValue( arguments.response ) ){
			content = arguments.response;
		}

		if( len( content ) ){
			variables.memories.each( function( mem ){
				mem.add( { "role": "assistant", "content": content } );
			});
		}
	}

	private boolean function hasMaxToolCallsMiddleware(){
		if( variables.middleware.isEmpty() ) return false;
		return variables.middleware.any( function( mw ){
			return isInstanceOf( mw, "MaxToolCallsMiddleware" );
		});
	}

	private void function addSubAgent( required any subAgent ){
		variables.subAgents.append( arguments.subAgent );
	}

	// =========================================================================
	// CONFIGURATION (FLUENT)
	// =========================================================================

	AiAgent function withInstructions( required string instructions ){
		variables.instructions = arguments.instructions;
		return this;
	}

	AiAgent function setName( required string name ){
		variables.agentName = arguments.name;
		variables.name      = "AiAgent-#arguments.name#";
		return this;
	}

	AiAgent function setModel( required AiModel model ){
		variables.aiModel = arguments.model.addTools( variables.tools );
		return this;
	}

	AiAgent function addTool( required any tool ){
		variables.tools.append( arguments.tool );
		variables.aiModel.addTools( [ arguments.tool ] );
		return this;
	}

	AiAgent function addMemory( required IAiMemory memory ){
		variables.memories.append( arguments.memory );
		return this;
	}

	AiAgent function withMiddleware( required any middleware ){
		if( !isArray( arguments.middleware ) ) arguments.middleware = [ arguments.middleware ];
		variables.middleware.append( arguments.middleware, true );
		return this;
	}

	AiAgent function withLogging(){
		return withMiddleware( new LoggingMiddleware( logLevel="info" ) );
	}

}