/**
 * ValidationMiddleware - Input/output validation + auto-correction - PHASE 5 COMPLETE
 * Validates tool arguments against schemas and suggests fixes
 */
component extends="models.middleware.BaseAiMiddleware" accessors="true" {

    /**
     * Validate tool arguments before execution
     */
    property name="validateToolArgs" type="boolean" default=true;

    /**
     * Validate LLM responses against expected formats
     */
    property name="validateResponses" type="boolean" default=false;

    /**
     * Auto-fix simple validation errors
     */
    property name="autoFix" type="boolean" default=true;

    /**
     * Maximum validation errors allowed before rejection
     */
    property name="maxErrors" type="numeric" default=3;

    function init(
        boolean validateToolArgs = true,
        boolean validateResponses = false,
        boolean autoFix = true,
        numeric maxErrors = 3
    ) {
        variables.validateToolArgs = arguments.validateToolArgs;
        variables.validateResponses = arguments.validateResponses;
        variables.autoFix = arguments.autoFix;
        variables.maxErrors = arguments.maxErrors;
        return this;
    }

    /**
     * MAIN HOOK: Validate tool arguments against schema
     */
    function beforeToolCall( required struct context ) {
        if ( !variables.validateToolArgs ) return AiMiddlewareResult.continue();

        var toolName = context.toolName;
        var toolArgs = context.toolArgs ?: {};
        var errors = [];

        // Find tool and get schema
        var tool = context.chatRequest.getTool( toolName );
        if ( !tool.isPresent() ) {
            return AiMiddlewareResult.reject( 
                reason="Tool '#toolName#' not found in request" 
            );
        }

        var schema = tool.get().getSchema();
        if ( !schema.keyExists( "parameters" ) ) return AiMiddlewareResult.continue();

        errors = validateAgainstSchema( toolArgs, schema.parameters.properties );
        
        if ( arrayLen( errors ) > variables.maxErrors ) {
            return AiMiddlewareResult.reject( 
                reason="Too many validation errors (#arrayLen(errors)#): #arrayToList(errors,', ')#"
            );
        }

        if ( arrayLen( errors ) > 0 ) {
            if ( variables.autoFix ) {
                // Auto-fix simple missing required fields with defaults
                context.toolArgs = fixToolArgs( context.toolArgs, schema.parameters.properties, errors );
                log( "Auto-fixed #arrayLen(errors)# validation issues for #toolName#" );
                return AiMiddlewareResult.edit( 
                    data=context.toolArgs,
                    reason="Fixed #arrayLen(errors)# validation issues"
                );
            } else {
                return AiMiddlewareResult.reject( 
                    reason="Validation failed: #arrayToList(errors,', ')#",
                    data={ "errors": errors, "schema": schema.parameters.properties }
                );
            }
        }

        return AiMiddlewareResult.continue();
    }

    /**
     * Validate LLM response format (if enabled)
     */
    function afterLLMCall( required struct context ) {
        if ( !variables.validateResponses || !structKeyExists( context, "response" ) ) {
            return AiMiddlewareResult.continue();
        }

        var response = context.response;
        if ( !response.keyExists( "choices" ) || !arrayLen( response.choices ) ) {
            return AiMiddlewareResult.reject( 
                reason="Invalid LLM response format - missing choices array" 
            );
        }

        var content = response.choices[1].message?.content ?: "";
        if ( !len( content ) && !response.choices[1].message.keyExists( "tool_calls" ) ) {
            return AiMiddlewareResult.reject( 
                reason="LLM response is empty and contains no tool calls" 
            );
        }

        return AiMiddlewareResult.continue();
    }

    /**
     * Validate tool args against JSON schema
     */
    private array function validateAgainstSchema( required struct args, required struct schema ) {
        var errors = [];

        for ( var propName in schema ) {
            var propSchema = schema[ propName ];
            
            // Required field missing
            if ( propSchema.keyExists( "required" ) && propSchema.required && 
                 !args.keyExists( propName ) ) {
                arrayAppend( errors, "#propName# is required" );
                continue;
            }

            // Type validation
            if ( args.keyExists( propName ) ) {
                var value = args[ propName ];
                var expectedType = propSchema.type ?: "string";
                
                if ( !isValidType( value, expectedType ) ) {
                    arrayAppend( errors, "#propName# must be #expectedType# (got #getTypeName(value)#)" );
                }

                // String length validation
                if ( expectedType == "string" && propSchema.keyExists( "maxLength" ) && 
                     len( toString( value ) ) > propSchema.maxLength ) {
                    arrayAppend( errors, "#propName# exceeds maxLength #propSchema.maxLength#" );
                }
            }
        }

        return errors;
    }

    /**
     * Check if value matches expected type
     */
    private boolean function isValidType( required any value, required string type ) {
        switch( arguments.type ) {
            case "string":  return isSimpleValue( arguments.value );
            case "number":  return isNumeric( arguments.value );
            case "integer": return isNumeric( arguments.value ) && arguments.value == int( arguments.value );
            case "boolean": return isBoolean( arguments.value );
            case "array":   return isArray( arguments.value );
            case "object":  return isStruct( arguments.value );
            default:        return true;
        }
    }

    /**
     * Auto-fix common validation issues
     */
    private struct function fixToolArgs( required struct args, required struct schema, required array errors ) {
        var fixedArgs = duplicate( arguments.args );

        for ( var propName in arguments.schema ) {
            var propSchema = arguments.schema[ propName ];
            
            if ( propSchema.keyExists( "required" ) && propSchema.required && 
                 !fixedArgs.keyExists( propName ) ) {
                
                // Use default if available
                if ( propSchema.keyExists( "default" ) ) {
                    fixedArgs[ propName ] = propSchema.default;
                } else {
                    // Reasonable defaults
                    switch( propSchema.type ?: "string" ) {
                        case "string":  fixedArgs[ propName ] = "";
                        case "number":  fixedArgs[ propName ] = 0;
                        case "boolean": fixedArgs[ propName ] = false;
                        case "array":   fixedArgs[ propName ] = [];
                        case "object":  fixedArgs[ propName ] = {};
                    }
                }
            }
        }

        return fixedArgs;
    }

    private function log( required string msg ) {
        writeLog( text="[bx-ai][Validation] #msg#", type="information", file="ai" );
    }

}
