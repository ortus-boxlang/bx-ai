 * aiModel() DSL BIF - PHASE 6
 * Fluent factory for AI Models with middleware support
 */
import bxModules.bxai.models.*;
import bxModules.bxai.models.middleware.*;
import bxModules.bxai.models.middleware.builtin.*;
import bxModules.bxai.services.*;

@BoxBIF
class {

    /**
     * Create an AiModel instance for the given provider.
     *
     * Constructor-style middleware wiring:
     *   aiModel( "openai", middleware: [ new RetryMiddleware( maxRetries: 3 ) ] )
     *
     * Fluent middleware wiring:
     *   aiModel( "openai" ).withMiddleware( new RetryMiddleware() )
     *
     * @provider  Required provider name: "openai", "anthropic", "azure", "ollama"
     * @params    Model parameters (model, temperature, max_tokens, etc.)
     * @tools     Array of ITool instances to register with the model
     * @middleware Single middleware instance, struct-of-closures, or array of either
     * @options   Additional model options passed through to the service
     *
     * @return AiModel instance ready for use
     */
    function invoke(
        required string provider,
        struct  params     = {},
        array   tools      = [],
        any     middleware = [],
        struct  options    = {}
    ) {
        // Resolve service by provider name
        var service = getAIService( arguments.provider.lCase() );

        // Create the model
        var model = new AiModel(
            service  : service,
            tools    : arguments.tools,
            params   : arguments.params,
            options  : arguments.options
        );

        // Wire constructor-supplied middleware item by item so that
        // struct-of-closures auto-wrapping in addMiddleware() fires per item
        var middlewareItems = isArray( arguments.middleware )
            ? arguments.middleware
            : [ arguments.middleware ];

        for ( var mw in middlewareItems ) {
            if ( !isNull( mw ) && !( isSimpleValue( mw ) && !len( trim( mw ) ) ) ) {
                model.withMiddleware( mw );
            }
        }

        return model;
    }

    // =========================================================================
    // PRIVATE HELPERS
    // =========================================================================

    /**
     * Resolve a provider name string to a concrete service instance.
     * Throws UnknownAIProviderException for unrecognised provider names.
     *
     * @provider Already lowercased provider identifier
     */
    private function getAIService( required string provider ) {
        switch ( arguments.provider ) {
            case "openai":
            case "gpt":
                return new OpenAIService();

            case "anthropic":
            case "claude":
                return new AnthropicService();

            case "azure":
                return new AzureOpenAIService();

            case "ollama":
                return new OllamaService();

            default:
                throw(
                    type    : "UnknownAIProviderException",
                    message : "AI provider '#arguments.provider#' is not supported.",
                    detail  : "Supported providers: openai, gpt, anthropic, claude, azure, ollama"
                );
        }
    }

}