 * aiModel() DSL BIF - PHASE 6 COMPLETE
 * Fluent factory for AI Models with full Phase 5 middleware integration
 */
@BoxBIF
class {

	/** 
	 * Create AI Model with full Phase 3-6 fluent DSL support
	 *
	 * @provider Required provider name: "openai", "anthropic", "azure", "ollama", "claude", "gpt"
	 * @params Model parameters (model, temperature, max_tokens, etc.)
	 * @tools Array of Tool objects
	 * @middleware Array of middleware (Phase 5)
	 * @options Additional model options
	 *
	 * @return Production-ready AiModel instance
	 */
	function invoke(
		required string provider,
		struct params = {},
		array tools = [],
		array middleware = [],
		struct options = {}
	) {
		
		// Create AI service by provider
		var service = getAIService( arguments.provider.lcase() );
		
		// Create model instance with full Phase 6 support
		var model = new AiModel(
			service = service,
			tools = arguments.tools,
			middleware = arguments.middleware,
			params = arguments.params,
			options = arguments.options
		);

		// 🔥 PHASE 6: DEFAULT PRODUCTION MIDDLEWARE (if none provided)
		if ( arrayLen( arguments.middleware ) == 0 ) {
			model.withMiddleware( [
				new RateLimitMiddleware( requestsPerMinute = 120 ),
				new LoggingMiddleware( logLevel = "info" )
			] );
			
			writeLog(
				text = "[bx-ai][aiModel()] Added default production middleware stack for #arguments.provider#",
				type = "information",
				file = "ai"
			);
		}

		// Announce model creation for module lifecycle
		BoxAnnounce( "onAIModelCreate", { 
			model = model, 
			provider = arguments.provider,
			params = arguments.params 
		});

		return model;
	}

	/**
	 * Get AI service instance by provider name
	 * @provider Provider identifier
	 * @return IService implementation
	 */
	private function getAIService( required string provider ) {
		switch( arguments.provider ) {
			case "openai":
			case "gpt":
				return new OpenAIService();
				
			case "anthropic":
			case "claude":
				return new AnthropicService();
				
			case "azure":
				return new AzureOpenAIService();
				
			case "ollama":
				return new OllamaService();
				
			default:
				throw(
					type = "UnknownAIProviderException",
					message = "AI provider '#arguments.provider#' not supported.",
					detail = "Supported providers: openai, gpt, anthropic, claude, azure, ollama"
				);
		}
	}

}
