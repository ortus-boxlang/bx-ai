 * governing permissions and limitations under the License.
 * ----------------------------------------------------------------------------------
 * Translate audio from any supported language to English text using an AI provider.
 * This is audio translation (speech-in → English text out), not text-to-text translation.
 * Accepts a local file path, a remote URL, or raw binary audio data.
 *
 * @example
 * ```
 * // Translate a Spanish audio file to English text
 * text = aiTranslate( "/path/to/spanish-audio.mp3" )
 * println( text )
 *
 * // Get structured response
 * response = aiTranslate(
 *     audio  : "/path/to/audio.mp3",
 *     options: { returnFormat: "response" }
 * )
 *
 * // Use a specific provider
 * text = aiTranslate(
 *     audio  : "/path/to/audio.mp3",
 *     params : { model: "whisper-1" },
 *     options: { provider: "openai" }
 * )
 * ```
 */
@BoxBIF
class {

	static {
		final VALID_RESPONSE_FORMATS = [ "text", "response", "raw" ]
		final DEFAULT_OPTIONS = {
			returnFormat : "text"
		}
	}

	/**
	 * Translate audio to English text, or return a fluent AiTranscriptionRequest builder when
	 * called with no audio. Builder usage: aiTranslate().file("/path/audio.mp3").translate()
	 *
	 * @audio   The audio source: local file path (string), remote URL (string), or binary data.
	 *          Omit (or pass "") to get a fluent builder instead.
	 * @params  Provider API parameters (model, response_format, etc.)
	 * @options High-level options (provider, apiKey, returnFormat, timeout, logging)
	 *
	 * @return String (returnFormat "text"), AiTranscriptionResponse, or AiTranscriptionRequest (fluent builder)
	 */
	function invoke(
		any audio = "",
		struct params = {},
		struct options = {}
	){
		// Seed audio-specific defaults directly — do NOT merge all moduleRecord.settings into options
		// because that would overwrite options.apiKey with the module global key, which breaks cross-provider
		// key resolution inside aiService() (e.g. GROQ_API_KEY convention check)
		var audioSettings = moduleRecord.settings.audio ?: {}
		if ( audioSettings.defaultTranscriptionModel.len() && !arguments.options.keyExists( "model" ) && !arguments.params.keyExists( "model" ) ) {
			arguments.params.model = audioSettings.defaultTranscriptionModel
		}
		// Seed audio-specific provider default
		if ( !arguments.options.keyExists( "provider" ) && len( audioSettings.defaultProvider ?: "" ) ) {
			arguments.options.provider = audioSettings.defaultProvider
		}
		// Seed audio-specific apiKey — only when no convention env var exists for the resolved provider,
		// so the convention check in aiService() is not inadvertently bypassed.
		if ( !len( arguments.options.apiKey ?: "" ) && len( audioSettings.defaultApiKey ?: "" ) ) {
			var resolvedProvider = arguments.options.provider ?: moduleRecord.settings.provider
			if ( !len( getSystemSetting( "#resolvedProvider.ucase()#_API_KEY", "" ) ) ) {
				arguments.options.apiKey = audioSettings.defaultApiKey
			}
		}
		// Seed inputFormat: options.format wins, then audio.defaultOutputFormat, so the provider
		// can write the binary temp file with the correct extension.
		if ( !arguments.params.keyExists( "inputFormat" ) && !arguments.options.keyExists( "inputFormat" ) ) {
			var resolvedFormat = arguments.options.format ?: audioSettings.defaultOutputFormat ?: ""
			if ( len( resolvedFormat ) ) {
				arguments.params.inputFormat = resolvedFormat
			}
		}

		// Create request (reuse AiTranscriptionRequest — same structure, different operation)
		var transcriptionRequest = new bxModules.bxai.models.requests.AiTranscriptionRequest(
			audio   = arguments.audio,
			params  = arguments.params,
			options = arguments.options,
			methodDefaults = static.DEFAULT_OPTIONS  // Pass method defaults separately
		)

		// Return fluent builder when called with no audio
		if ( isSimpleValue( arguments.audio ) && !len( arguments.audio ) ) {
			return transcriptionRequest
		}

		// Guard: audio source required
		if ( !transcriptionRequest.hasAudio() ) {
			throw(
				type    : "InvalidArgument",
				message : "aiTranslate() requires a valid audio source (file path, URL, or binary data)."
			)
		}

		// Get the service
		var service = aiService( arguments.options?.provider, arguments.options )

		if ( !isInstanceOf( service, "IAiTranscriptionService" ) ) {
			throw(
				type    : "UnsupportedCapability",
				message : "Unsupported capability: provider [#service.getName()#] does not support audio translation. Use a provider that implements IAiTranscriptionService."
			)
		}

		// Fire before event
		BoxAnnounce( "beforeAITranslation", { transcriptionRequest: transcriptionRequest, service: service } )

		// Invoke translation (speech-to-English-text)
		var result = service.translate( transcriptionRequest )

		// Fire after event
		BoxAnnounce( "afterAITranslation", { transcriptionRequest: transcriptionRequest, service: service, result: result } )

		// Return plain text or full response based on returnFormat
		if ( transcriptionRequest.getReturnFormat() == "text" && isInstanceOf( result, "AiTranscriptionResponse" ) ) {
			return result.getText()
		}

		return result
	}

}
