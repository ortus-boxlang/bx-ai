 * ----------------------------------------------------------------------------------
 * Convert text to speech using an AI provider.
 * Returns an AiSpeechResponse with the binary audio data, or saves the audio to a file
 * when options.outputFile is specified.
 *
 * @example
 * ```
 * // Synthesize speech and get binary audio
 * response = aiSpeak( "Hello, welcome to BoxLang!" )
 * response.saveToFile( "/tmp/welcome.mp3" )
 *
 * // Save directly to a file
 * aiSpeak(
 *     text   : "Hello World",
 *     options: { outputFile: "/tmp/hello.mp3" }
 * )
 *
 * // Use a specific provider, voice, and model
 * response = aiSpeak(
 *     text   : "The quick brown fox",
 *     params : { model: "tts-1-hd", voice: "nova" },
 *     options: { provider: "openai", outputFormat: "wav" }
 * )
 * ```
 */
@BoxBIF
class {

	/**
	 * Convert text to synthesized speech, or return a fluent AiSpeechRequest builder when called
	 * with no text. Builder usage: aiSpeak().text("...").female().asWav().speak()
	 *
	 * @text    The text to convert to speech. Omit (or pass "") to get a fluent builder instead.
	 * @params  Provider API parameters (model, voice, speed, response_format, etc.)
	 * @options High-level options (provider, apiKey, outputFile, outputFormat, returnFormat, timeout, logging)
	 *
	 * @return AiSpeechResponse, a file path string (when outputFile is set), or AiSpeechRequest (fluent builder)
	 */
	function invoke(
		string text = "",
		struct params = {},
		struct options = {}
	){
		// Seed audio-specific defaults directly — do NOT merge all moduleRecord.settings into options
		// because that would overwrite options.apiKey with the module global key, which breaks cross-provider
		// key resolution inside aiService() (e.g. GROQ_API_KEY convention check)
		var audioSettings = moduleRecord.settings.audio ?: {};
		if ( audioSettings.defaultVoice.len() && !arguments.options.keyExists( "voice" ) && !arguments.params.keyExists( "voice" ) ) {
			arguments.options.voice = audioSettings.defaultVoice
		}
		if ( audioSettings.defaultOutputFormat.len() && !arguments.options.keyExists( "outputFormat" ) && !arguments.params.keyExists( "outputFormat" ) ) {
			arguments.options.outputFormat = audioSettings.defaultOutputFormat
		}
		if ( audioSettings.defaultSpeechModel.len() && !arguments.options.keyExists( "model" ) && !arguments.params.keyExists( "model" ) ) {
			arguments.params.model = audioSettings.defaultSpeechModel
		}
		// Seed audio-specific provider default
		if ( !arguments.options.keyExists( "provider" ) && len( audioSettings.defaultProvider ?: "" ) ) {
			arguments.options.provider = audioSettings.defaultProvider
		}
		// Seed audio-specific apiKey — only when no convention env var exists for the resolved provider,
		// so the convention check in aiService() is not inadvertently bypassed.
		if ( !len( arguments.options.apiKey ?: "" ) && len( audioSettings.defaultApiKey ?: "" ) ) {
			var resolvedProvider = arguments.options.provider ?: moduleRecord.settings.provider
			if ( !len( getSystemSetting( "#resolvedProvider.ucase()#_API_KEY", "" ) ) ) {
				arguments.options.apiKey = audioSettings.defaultApiKey
			}
		}

		// Return fluent builder when called with no text.
		// Gender resolution is deferred so the builder can be re-pointed at a different provider
		// before .speak() is called; resolution fires again on the .speak() invocation.
		if ( !len( arguments.text ) ) {
			return new bxModules.bxai.models.requests.AiSpeechRequest(
				params  = arguments.params,
				options = arguments.options
			)
		}

		// Resolve gender keywords ("male"/"female") to provider-specific voice names
		// so providers always receive a concrete voice identifier, not a keyword.
		var effectiveVoice = arguments.params.voice ?: arguments.options.voice ?: "";
		if ( len( effectiveVoice ) && listFindNoCase( "male,female", effectiveVoice ) ) {
			var resolvedProviderForVoice = arguments.options.provider ?: audioSettings.defaultProvider ?: moduleRecord.settings.provider ?: "openai";
			var genderMap               = audioSettings.voiceGenderMap ?: {};
			var providerGenderMap       = genderMap[ resolvedProviderForVoice ] ?: {};
			var mappedVoice             = providerGenderMap[ effectiveVoice.lcase() ] ?: "";
			if ( len( mappedVoice ) ) {
				arguments.params.voice = mappedVoice;
			}
		}

		// Create request
		var speechRequest = new bxModules.bxai.models.requests.AiSpeechRequest(
			text   = arguments.text,
			params  = arguments.params,
			options = arguments.options
		)

		// Get the service
		var service = aiService( arguments.options?.provider, arguments.options )

		if ( !isInstanceOf( service, "IAiSpeechService" ) ) {
			throw(
				type    : "UnsupportedCapability",
				message : "Unsupported capability: provider [#service.getName()#] does not support text-to-speech. Use a provider that implements IAiSpeechService."
			)
		}

		// Fire before event
		BoxAnnounce( "beforeAISpeech", { speechRequest: speechRequest, service: service } )

		// Invoke TTS
		var result = service.speak( speechRequest )

		// Fire after event
		BoxAnnounce( "afterAISpeech", { speechRequest: speechRequest, service: service, result: result } )

		// If an output file was requested, save it and return the path
		if ( arguments.options.keyExists( "outputFile" ) && arguments.options.outputFile.len() ) {
			return result.saveToFile( arguments.options.outputFile )
		}

		return result
	}

}
