/**
 * Test scheduler for SchedulerToolsTest
 * Registers reporting-related tasks for testing purposes
 */
class {

	property name="scheduler";

	function configure() {
		scheduler
			.setSchedulerName( "reporting" )
			.setTimezone( "America/Chicago" );

		scheduler.task( "daily-report", "reports" )
			.call( () => {
				return "Daily report generated";
			} )
			.everyDayAt( "02:00" );

		scheduler.task( "weekly-summary", "reports" )
			.call( () => {
				return "Weekly summary created";
			} )
			.everyWeekOn( 1, "08:00" );

		scheduler.task( "send-notifications", "alerts" )
			.call( () => {
				return "Notifications sent";
			} )
			.every( 10, "minute" );
	}

}
